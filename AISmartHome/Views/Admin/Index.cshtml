@model IEnumerable<AISmartHome.Models.YeuCauLapDat>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Dashboard Quản Trị";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-all relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-16 h-16 bg-cyan-50 rounded-bl-full flex items-center justify-center -mr-2 -mt-2 group-hover:scale-110 transition-transform text-cyan-500">
            <i class="fa-solid fa-wallet text-xl"></i>
        </div>
        <p class="text-slate-400 text-[11px] font-bold uppercase tracking-wider mb-1">Tổng doanh thu</p>
        <p class="text-2xl font-black text-slate-800">@(((decimal)(ViewBag.TotalRevenue ?? 0)).ToString("#,##0")) <span class="text-xs text-slate-400">đ</span></p>
        <p class="text-[10px] text-emerald-500 font-bold mt-2 flex items-center gap-1"><i class="fa-solid fa-arrow-up"></i> +12.5%</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-all relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-16 h-16 @(ViewBag.NewOrdersCount > 0 ? "bg-amber-50 text-amber-500" : "bg-blue-50 text-blue-500") rounded-bl-full flex items-center justify-center -mr-2 -mt-2 group-hover:scale-110 transition-transform">
            <i class="fa-solid fa-box-open text-xl @(ViewBag.NewOrdersCount > 0 ? "animate-bounce" : "")"></i>
        </div>
        <p class="text-slate-400 text-[11px] font-bold uppercase tracking-wider mb-1">Đơn hàng mới</p>
        <p class="text-2xl font-black text-slate-800">@(ViewBag.NewOrdersCount ?? 0) <span class="text-xs text-slate-400">đơn</span></p>
        <p class="text-[10px] @(ViewBag.NewOrdersCount > 0 ? "text-amber-500 font-bold" : "text-slate-400") mt-2">@(ViewBag.NewOrdersCount > 0 ? "Cần xử lý ngay" : "Đã xử lý hết")</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-all relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-16 h-16 bg-purple-50 rounded-bl-full flex items-center justify-center -mr-2 -mt-2 group-hover:scale-110 transition-transform text-purple-500">
            <i class="fa-solid fa-users text-xl"></i>
        </div>
        <p class="text-slate-400 text-[11px] font-bold uppercase tracking-wider mb-1">Khách hàng</p>
        <p class="text-2xl font-black text-slate-800">@(ViewBag.TotalCustomers ?? 0) <span class="text-xs text-slate-400">người</span></p>
        <p class="text-[10px] text-slate-400 mt-2">Tăng trưởng ổn định</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-all relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-16 h-16 bg-rose-50 rounded-bl-full flex items-center justify-center -mr-2 -mt-2 group-hover:scale-110 transition-transform text-rose-500">
            <i class="fa-solid fa-screwdriver-wrench text-xl"></i>
        </div>
        <p class="text-slate-400 text-[11px] font-bold uppercase tracking-wider mb-1">Yêu cầu lắp đặt</p>
        <p class="text-2xl font-black text-slate-800">@(ViewBag.PendingInstallations ?? 0) <span class="text-xs text-slate-400">ca</span></p>
        <p class="text-[10px] text-rose-500 font-bold mt-2 animate-pulse">Đang chờ xếp lịch</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col">
        <div class="flex justify-between items-center mb-6">
            <div>
                <h3 class="text-base font-black text-slate-800">Xu hướng doanh thu</h3>
                <p class="text-[10px] text-slate-400 font-medium uppercase tracking-widest">Thống kê 6 tháng gần nhất</p>
            </div>
            <div class="flex gap-2">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-cyan-50 text-cyan-600 text-[10px] font-bold border border-cyan-100">
                    <i class="fa-solid fa-calendar-days"></i> Tháng hiện tại
                </span>
            </div>
        </div>
        <div class="h-[300px] w-full mt-auto">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <div class="lg:col-span-1 bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col h-full">
        <div class="p-5 border-b border-slate-100 bg-slate-50/30">
            <h3 class="text-sm font-black text-slate-800 flex items-center gap-2">
                <i class="fa-solid fa-money-bill-transfer text-emerald-500"></i> Giao dịch mới
            </h3>
        </div>
        <div class="overflow-y-auto max-h-[350px]">
            <table class="w-full text-left">
                <tbody class="divide-y divide-slate-50">
                    @if (ViewBag.RecentRevenue != null)
                    {
                        foreach (var item in (List<AISmartHome.Models.DonHang>)ViewBag.RecentRevenue)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="p-4">
                                    <p class="text-xs font-black text-slate-800 mb-0.5">#@item.MaDonHang</p>
                                    <p class="text-[10px] text-slate-400 font-medium italic">@item.NgayDatHang?.ToString("dd/MM, HH:mm")</p>
                                </td>
                                <td class="p-4 text-right">
                                    <p class="text-xs font-black text-emerald-600">+@item.TongTien?.ToString("#,##0") <span class="text-[10px]">đ</span></p>
                                    <div class="flex items-center justify-end gap-1 mt-1">
                                        <span class="size-1.5 rounded-full bg-emerald-500"></span>
                                        <span class="text-[9px] font-bold text-emerald-500 uppercase">Paid</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <a href="/DonHangs" class="mt-auto p-4 border-t border-slate-50 text-center text-[10px] font-black text-slate-400 hover:text-cyan-500 uppercase tracking-widest transition-colors">
            Xem toàn bộ lịch sử đơn &rarr;
        </a>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <div class="xl:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col">
        <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50 text-blue-500">
            <h3 class="text-base font-black text-slate-800 flex items-center gap-2">
                <i class="fa-solid fa-screwdriver-wrench"></i> Yêu cầu lắp đặt mới
            </h3>
            <a href="/YeuCauLapDats" class="text-[10px] font-black uppercase text-cyan-600 hover:underline">Xem tất cả &rarr;</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50/50 border-b border-slate-100">
                    <tr class="text-slate-400 text-[9px] uppercase font-black tracking-widest">
                        <th class="p-4">Thông tin đơn</th>
                        <th class="p-4">Phụ trách</th>
                        <th class="p-4">Trạng thái</th>
                        <th class="p-4 text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var yeuCau in Model.Take(5))
                    {
                        <tr class="hover:bg-slate-50/30 transition-colors">
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="size-8 rounded-lg bg-slate-100 text-slate-500 flex items-center justify-center text-[10px] font-bold border border-slate-200">#@yeuCau.MaDonHang</div>
                                    <div class="min-w-0">
                                        <p class="text-xs font-black text-slate-800">Hạng mục: Lắp đặt thiết bị</p>
                                        <p class="text-[10px] text-slate-400 italic truncate w-40 md:w-56">@yeuCau.DiaChiLapDat</p>
                                    </div>
                                </div>
                            </td>
                            <td class="p-4">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-indigo-50 text-indigo-500 flex items-center justify-center text-[8px]"><i class="fa-solid fa-user-gear"></i></div>
                                    <span class="text-[11px] font-bold text-slate-600">@(yeuCau.MaNhanVienNavigation?.TenNhanVien ?? "Chờ xử lý")</span>
                                </div>
                            </td>
                            <td class="p-4">
                                <span class="px-2 py-0.5 rounded-full text-[9px] font-black border @(yeuCau.TrangThaiLapDat == "Chưa lắp đặt" ? "bg-amber-50 text-amber-500 border-amber-100" : "bg-emerald-50 text-emerald-500 border-emerald-100")">
                                    @yeuCau.TrangThaiLapDat
                                </span>
                            </td>
                            <td class="p-4 text-right">
                                <a href="/YeuCauLapDats/Details/@yeuCau.MaYeuCauLapDat" class="text-slate-300 hover:text-slate-900 transition-colors">
                                    <i class="fa-solid fa-circle-arrow-right text-lg"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="xl:col-span-1 bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col h-fit">
        <div class="p-4 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center text-rose-500">
            <h3 class="text-sm font-black text-slate-800 flex items-center gap-2">
                <span class="flex h-2 w-2 rounded-full bg-rose-500 animate-ping"></span>
                Tồn kho thấp
            </h3>
            <span class="text-[9px] font-bold text-slate-400 uppercase">Dưới 5 SP</span>
        </div>
        <div class="p-2 overflow-hidden">
            <table class="w-full text-left border-separate border-spacing-y-1">
                <tbody>
                    @if (ViewBag.LowStockProducts != null)
                    {
                        foreach (var p in (List<AISmartHome.Models.SanPham>)ViewBag.LowStockProducts)
                        {
                            <tr class="hover:bg-slate-50 transition-colors rounded-lg">
                                <td class="p-2">
                                    <div class="flex items-center gap-2">
                                        <img src="~/img/@p.HinhAnh" class="size-8 object-cover rounded-lg border border-slate-100 shadow-sm" onerror="this.src='/img/no-image.png'">
                                        <div class="min-w-0">
                                            <p class="text-[10px] font-bold text-slate-800 truncate w-24">@p.TenSanPham</p>
                                            <p class="text-[9px] text-rose-500 font-bold italic">Còn @p.SoLuong cái</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-2 text-right">
                                    <span class="px-2 py-0.5 rounded text-[8px] font-black uppercase bg-rose-50 text-rose-500 border border-rose-100">
                                        Nhập gấp
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="p-3 border-t border-slate-50 bg-slate-50/10">
            <a href="/SanPhams" class="block text-center py-2 rounded-xl bg-white border border-slate-200 text-[10px] font-black text-slate-500 hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all shadow-sm">
                ĐI ĐẾN KHO HÀNG
            </a>
        </div>
    </div>
</div>

<script>
    const ctx = document.getElementById('revenueChart').getContext('2d');
    const labels = @Html.Raw(Json.Serialize(ViewBag.ChartLabels));
    const dataValues = @Html.Raw(Json.Serialize(ViewBag.ChartData));

    // Gradient màu xanh hiện đại
    let gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(6, 182, 212, 0.4)');
    gradient.addColorStop(1, 'rgba(6, 182, 212, 0.0)');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Doanh thu',
                data: dataValues,
                borderColor: '#06b6d4',
                borderWidth: 3,
                backgroundColor: gradient,
                fill: true,
                tension: 0.4,
                pointRadius: 0, // Ẩn điểm để trơn mượt
                pointHoverRadius: 6,
                pointHoverBackgroundColor: '#06b6d4',
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#0f172a',
                    padding: 12,
                    titleFont: { size: 10, family: 'sans-serif' },
                    bodyFont: { size: 12, weight: 'bold' },
                    callbacks: {
                        label: function(context) {
                            return ' ' + context.parsed.y.toLocaleString() + ' đ';
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: '#f1f5f9', drawBorder: false },
                    ticks: {
                        callback: value => (value / 1000000).toFixed(1) + 'Tr',
                        font: { size: 9, weight: 'bold' },
                        color: '#94a3b8'
                    }
                },
                x: {
                    grid: { display: false },
                    ticks: { font: { size: 9, weight: 'bold' }, color: '#94a3b8' }
                }
            }
        }
    });
</script>