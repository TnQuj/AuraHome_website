@model AISmartHome.Models.BaiViet

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xác nhận xóa Bài viết";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-3xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Gỡ bỏ nội dung bài viết
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Cảnh báo: Bài viết sẽ bị xóa vĩnh viễn khỏi cơ sở dữ liệu.</p>
            </div>
            <a asp-action="Index" class="text-gray-400 hover:text-gray-600 font-medium transition-colors">
                Hủy và Quay lại
            </a>
        </div>

        <div class="bg-white rounded-3xl shadow-xl border-2 border-red-50 overflow-hidden">

            <div class="bg-red-50 border-b border-red-100 px-6 py-5 flex items-center gap-4">
                <div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-red-500">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                <div>
                    <h3 class="font-black text-red-900 text-lg uppercase">Xác nhận xóa vĩnh viễn?</h3>
                    <p class="text-sm text-red-600/80">Bạn đang thực hiện xóa bài viết: <strong>@Model.TieuDe</strong></p>
                </div>
            </div>

            <div class="p-8">
                <div class="flex flex-col md:flex-row gap-6 mb-8 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <div class="w-full md:w-40 h-28 rounded-xl overflow-hidden shadow-sm shrink-0 border border-gray-200">
                        <img src="~/img/@Model.HinhAnh" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'" />
                    </div>
                    <div class="space-y-3">
                        <div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tiêu đề bài viết</span>
                            <p class="text-[#001F3F] font-bold leading-tight">@Model.TieuDe</p>
                        </div>
                        <div class="flex gap-4">
                            <div>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Ngày đăng</span>
                                <p class="text-xs text-slate-600">@Model.NgayDang?.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Danh mục</span>
                                <p class="text-xs text-slate-600">@Model.MaDanhMucBaiVietNavigation?.TenDanhMuc</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-center gap-4">
                    <form asp-action="Delete" class="w-full sm:w-auto flex-1">
                        <input type="hidden" asp-for="MaBaiViet" />
                        <button type="submit" class="w-full py-3.5 rounded-2xl font-black text-white bg-red-600 hover:bg-red-700 shadow-lg shadow-red-200 transition-all flex items-center justify-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            XÁC NHẬN XÓA BÀI VIẾT
                        </button>
                    </form>

                    <a asp-action="Index" class="w-full sm:w-auto px-8 py-3.5 rounded-2xl font-bold text-gray-500 bg-gray-100 hover:bg-gray-200 transition-all text-center">
                        Quay lại
                    </a>
                </div>
            </div>

            <div class="bg-slate-50 px-8 py-4 border-t border-slate-100 text-center">
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">
                    ID Bài viết: #@Model.MaBaiViet | Hệ thống CMS AI Smart Home
                </p>
            </div>
        </div>
    </div>
</div>