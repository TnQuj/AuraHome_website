@model IEnumerable<AISmartHome.Models.BaiViet>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý & Thu thập Bài viết";
    ViewData["HeaderIcon"] = @"<svg class=""w-8 h-8 text-[#00E5FF]"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z""></path></svg>";

}

<div class="px-6 pb-6 pt-2 bg-slate-50 min-h-screen">
    @section HeaderActions {

        <button onclick="startScanning()" id="scanBtn" class="group flex items-center gap-2 bg-emerald-50 text-emerald-600 border border-emerald-200 px-4 py-2.5 rounded-xl font-bold hover:bg-emerald-500 hover:text-white transition-all duration-300 shadow-sm">
            <svg id="scanIcon" class="w-5 h-5 transition-transform duration-500 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <span id="scanText" class="text-sm">Quét tin mới</span>
        </button>

        <a asp-action="Create" class="flex items-center gap-2 px-6 py-3 bg-brand-cyan text-white hover:bg-cyan-600 rounded-xl font-bold transition-all duration-300 shadow-lg shadow-brand-cyan/20 hover:-translate-y-0.5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
            </svg>
            <span class="text-sm whitespace-nowrap">Viết bài mới</span>
        </a>
        <div class="h-6 w-px bg-slate-200 mx-1 hidden sm:block"></div>
        <div class="hidden sm:flex items-center gap-3 bg-slate-50 border border-slate-200 px-4 py-2 rounded-xl mr-2 shadow-sm">
            <div class="w-7 h-7 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </div>
            <div class="flex items-baseline gap-1.5">
                <span class="text-[11px] text-slate-500 font-bold uppercase tracking-wider">Bài viết:</span>
                <span class="text-lg font-black text-[#001F3F] leading-none">@Model.Count()</span>
            </div>
        </div>

    }
    <div class="max-w-7xl mx-auto">

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-[#001F3F] text-white">
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider w-1/3">Nội dung bài viết</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Nguồn & Danh mục</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Ngày đăng</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Trạng thái</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 transition-colors group">
                                <td class="px-6 py-2">
                                    <div class="flex items-center gap-4">
                                        <div class="w-20 h-14 rounded-lg bg-gray-100 overflow-hidden shrink-0 border border-gray-100 shadow-sm">
                                            @if (!string.IsNullOrEmpty(item.HinhAnh) && item.HinhAnh != "news-default.jpg")
                                            {
                                                <img src="~/img/@item.HinhAnh" class="w-full h-full object-cover" onerror="this.onerror=null;this.src='/img/news-default.jpg';" />
                                            }
                                            else
                                            {
                                                <img src="~/img/news-default.jpg" class="w-full h-full object-cover" />
                                            }
                                        </div>
                                        <div class="max-w-xs">
                                            <div class="font-bold text-[#001F3F] line-clamp-1 group-hover:text-blue-600 transition-colors" title="@item.TieuDe">
                                                @item.TieuDe
                                            </div>
                                            <div class="text-xs text-gray-400 line-clamp-1 mt-1">
                                                @System.Text.RegularExpressions.Regex.Replace(item.NoiDung ?? "", "<.*?>", string.Empty)
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-2">
                                    <div class="flex flex-col gap-1">
                                        <span class="text-[10px] font-black text-blue-500 uppercase">@item.MaDanhMucBaiVietNavigation?.TenDanhMuc</span>
                                        <span class="text-[7px] text-gray-400 italic">Nguồn: @(string.IsNullOrEmpty(item.NguonTin) ? "Hệ thống" : item.NguonTin)</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500 font-medium">
                                    @item.NgayDang?.ToString("dd/MM/yyyy")
                                </td>

                                <td class="px-6 py-4">
                                    @if (item.IsApproved)
                                    {
                                        <span class="px-2.5 py-1 rounded-lg text-[10px] font-bold bg-emerald-50 text-emerald-600 border border-emerald-100 uppercase">
                                            Đã đăng
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-1 rounded-lg text-[10px] font-bold bg-amber-50 text-amber-600 border border-amber-100 uppercase">
                                            Chờ duyệt
                                        </span>
                                    }
                                </td>

                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-end gap-2">

                                        @if (!item.IsApproved)
                                        {
                                            <form asp-action="Approve" asp-route-id="@item.MaBaiViet" method="post" style="display:inline;">
                                                <button type="submit" class="p-2 text-white bg-emerald-500 hover:bg-emerald-600 rounded-lg transition-all shadow-sm" title="Duyệt xuất bản bài này">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="Hide" asp-route-id="@item.MaBaiViet" method="post" style="display:inline;">
                                                <button type="submit" class="p-2 text-white bg-amber-500 hover:bg-amber-600 rounded-lg transition-all shadow-sm" title="Khóa / Hạ bài viết này">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                                </button>
                                            </form>
                                        }

                                        <a asp-action="Edit" asp-route-id="@item.MaBaiViet" class="p-2 text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-all" title="Sửa bài">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        </a>

                                        <form asp-action="DeleteConfirmed" asp-route-id="@item.MaBaiViet" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn bài viết này không?');" style="display:inline;">
                                            <button type="submit" class="p-2 text-rose-600 bg-rose-50 hover:bg-rose-100 rounded-lg transition-all" title="Xóa bài viết">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function startScanning() {
            const btn = document.getElementById('scanBtn');
            const text = document.getElementById('scanText');
            btn.disabled = true;
            text.innerText = "Đang quét...";
            fetch('/BaiViets/CrawlNews', {
                method: 'POST',
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert("Lỗi: " + data.message);
                    btn.disabled = false;
                    text.innerText = "Quét tin mới";
                }
            })
            .catch(error => {
                console.error("Error:", error);
                alert("Lỗi kết nối server!");
                btn.disabled = false;
                text.innerText = "Quét tin mới";
            });
        }
    </script>
}