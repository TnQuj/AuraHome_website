@model AISmartHome.Models.GioHang

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Giỏ Hàng của bạn";

    // Mặc định ban đầu hiển thị tổng tiền của tất cả sản phẩm
    decimal tongTien = Model?.ChiTietGioHangs?.Sum(x => (x.Gia ?? 0) * (x.SoLuong ?? 0)) ?? 0;
}

<style>
    /* ... (Phần style bong bóng ambient-blob của bạn giữ nguyên) ... */
    .ambient-blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
        animation: float 10s infinite alternate ease-in-out;
    }

    @@keyframes float {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(30px, -50px) scale(1.1);
        }
    }
</style>

<body class="bg-[#FAFCFF] font-body text-slate-800 relative overflow-x-hidden">
    <div class="ambient-blob bg-cyan-300/40 w-[30rem] h-[30rem] rounded-full top-[-10%] left-[-10%]"></div>
    <div class="ambient-blob bg-indigo-300/30 w-[40rem] h-[40rem] rounded-full top-[20%] right-[-15%]" style="animation-delay: -5s;"></div>

    <main class="w-full pb-20 pt-8 relative z-10">
        <div class="container mx-auto px-4 md:px-8">
            <nav class="flex items-center gap-2 text-sm text-slate-500 mb-10 font-medium">
                <a class="hover:text-brand-cyan transition-colors" asp-controller="Customers" asp-action="Index">Trang chủ</a>
                <i class="fa-solid fa-chevron-right text-[10px]"></i>
                <span class="text-brand-navy font-bold px-2 py-1 bg-slate-100 rounded-md">Giỏ hàng của bạn</span>
            </nav>

            <div class="flex items-end justify-between mb-8">
                <h1 class="text-3xl md:text-4xl font-black text-brand-navy tracking-tight">Giỏ hàng</h1>
                <span class="text-slate-500 font-medium">@(Model?.ChiTietGioHangs?.Count ?? 0) sản phẩm</span>
            </div>

            <form id="cartForm" action="/Customers/Checkout" method="get" onsubmit="return validateCheckout()">
                <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

                    <div class="w-full lg:w-[65%]">
                        @if (Model != null && Model.ChiTietGioHangs != null && Model.ChiTietGioHangs.Any())
                        {
                            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 mb-4 flex items-center gap-3">
                                <input type="checkbox" id="selectAll" checked onchange="toggleAllCheckboxes(this)" class="w-5 h-5 text-cyan-500 bg-slate-100 border-slate-300 rounded focus:ring-cyan-500 transition-all cursor-pointer">
                                <label for="selectAll" class="font-bold text-slate-700 cursor-pointer select-none">Chọn tất cả (@Model.ChiTietGioHangs.Count)</label>
                            </div>

                            <div class="flex flex-col gap-5 lg:pr-2">
                                @foreach (var item in Model.ChiTietGioHangs)
                                {
                                    var sp = item.MaSanPhamNavigation;
                                    decimal tamTinh = (item.Gia ?? 0) * (item.SoLuong ?? 0);

                                    <div class="bg-white p-5 rounded-3xl shadow-sm border border-slate-100 flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-6 relative group transition-all duration-300 hover:shadow-lg hover:border-cyan-100">

                                        <a href="/Customers/RemoveFromCart?id=@item.MaSanPham" class="absolute right-4 top-4 md:static w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:bg-rose-50 hover:text-rose-500 transition-colors" title="Xóa khỏi giỏ">
                                            <i class="fa-solid fa-trash-can text-sm"></i>
                                        </a>

                                        <div class="flex items-center">
                                            <input type="checkbox" name="selectedProducts" value="@item.MaSanPham" checked
                                                   class="item-checkbox w-5 h-5 text-cyan-500 bg-slate-100 border-slate-300 rounded focus:ring-cyan-500 transition-all cursor-pointer"
                                                   data-price="@item.Gia" onchange="calculateSelectedTotal()">
                                        </div>

                                        <div class="w-24 h-24 bg-slate-50 rounded-2xl p-3 flex-shrink-0 border border-slate-100 group-hover:scale-105 transition-transform duration-500">
                                            <img src="@(string.IsNullOrEmpty(sp?.HinhAnh) ? "https://via.placeholder.com/150" : $"/img/{sp?.HinhAnh}")" alt="@sp?.TenSanPham" class="w-full h-full object-contain mix-blend-multiply" />
                                        </div>

                                        <div class="flex-1 flex flex-col w-full">
                                            <a href="/Customers/Details?id=@item.MaSanPham" class="text-[16px] font-bold text-brand-navy hover:text-brand-cyan transition-colors leading-snug line-clamp-2 mb-2 pr-8 md:pr-0">
                                                @sp?.TenSanPham
                                            </a>
                                            <span class="text-brand-cyan font-black text-lg">
                                                @item.Gia?.ToString("N0") ₫
                                            </span>
                                        </div>

                                        <div class="flex items-center justify-between w-full md:w-auto gap-8 mt-2 md:mt-0 pt-4 md:pt-0 border-t md:border-none border-slate-100">
                                            <div class="flex items-center border border-slate-200 rounded-full overflow-hidden h-10 w-[110px] bg-white shadow-inner">
                                                <button type="button" onclick="updateQty('@item.MaSanPham', -1)" class="w-9 h-full flex justify-center items-center text-slate-500 hover:bg-slate-100 hover:text-brand-cyan transition-colors"><i class="fa-solid fa-minus text-xs"></i></button>

                                                <input id="qty-@item.MaSanPham"
                                                       type="text"
                                                       value="@item.SoLuong"
                                                       data-stock="@(sp?.SoLuong ?? 0)"
                                                       data-name="@sp?.TenSanPham"
                                                       readonly
                                                       class="w-full h-full text-center border-none p-0 text-sm font-bold text-brand-navy focus:ring-0 bg-transparent pointer-events-none" />
                                               
                                                       <button type="button" onclick="updateQty('@item.MaSanPham', 1)" class="w-9 h-full flex justify-center items-center text-slate-500 hover:bg-slate-100 hover:text-brand-cyan transition-colors"><i class="fa-solid fa-plus text-xs"></i></button>
                                            </div>

                                            <div class="text-right flex flex-col md:min-w-[100px]">
                                                <span class="text-xs text-slate-400 font-medium md:hidden mb-1">Thành tiền</span>
                                                <span id="subtotal-@item.MaSanPham" class="font-black text-rose-600 text-lg">
                                                    @tamTinh.ToString("N0") ₫
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mt-8">
                                <a href="/Customers/Index" class="inline-flex items-center gap-3 text-slate-500 hover:text-brand-cyan font-bold transition-colors group">
                                    <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center group-hover:bg-cyan-50 transition-colors">
                                        <i class="fa-solid fa-arrow-left-long group-hover:-translate-x-1 transition-transform"></i>
                                    </span>
                                    Tiếp tục chọn thiết bị
                                </a>
                            </div>
                        }
                        else
                        {
                        }
                    </div>

                    <div class="w-full lg:w-[35%]">
                        <div class="bg-white p-6 md:p-8 border border-slate-100 shadow-xl shadow-slate-200/40 rounded-3xl md:sticky md:top-28">
                            <h2 class="text-xl font-extrabold text-brand-navy mb-6 flex items-center gap-3">
                                <i class="fa-solid fa-receipt text-brand-cyan"></i> Tóm tắt đơn hàng
                            </h2>

                            <div class="flex justify-between items-center mb-4 text-sm font-medium">
                                <span class="text-slate-500">
                                    Đã chọn (<span id="total-selected-qty">@(Model?.ChiTietGioHangs?.Sum(x => x.SoLuong) ?? 0)</span> sản phẩm)
                                </span>
                                <span id="subtotal-summary" class="text-brand-navy">@tongTien.ToString("N0") ₫</span>
                            </div>

                            <div class="flex justify-between items-center mb-6 text-sm font-medium">
                                <span class="text-slate-500">Phí vận chuyển</span>
                                <span class="text-emerald-500">Miễn phí</span>
                            </div>

                            <div class="w-full border-t border-dashed border-slate-200 my-6"></div>

                            <div class="flex justify-between items-end mb-8">
                                <span class="text-slate-900 font-bold">Tổng thanh toán</span>
                                <div class="text-right">
                                    <span id="cart-total" class="block font-black text-rose-600 text-3xl">
                                        @tongTien.ToString("N0") ₫
                                    </span>
                                    <span class="text-[11px] text-slate-400 font-medium">(Đã bao gồm VAT)</span>
                                </div>
                            </div>
                          
                            <button type="submit" id="btnCheckoutSubmit" class="w-full flex items-center justify-center gap-2 bg-gradient-to-r from-cyan-500 to-blue-600 text-white py-4 rounded-2xl font-bold text-[15px] hover:shadow-lg hover:shadow-cyan-500/30 hover:-translate-y-1 transition-all duration-300 uppercase tracking-wider mb-6 h-[56px]">
                                Tiến hành thanh toán <i class="fa-solid fa-arrow-right-long ml-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </main>
    <!--Thông báo số lượng sản phẩm khi mua lố-->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <div id="custom-alert-modal" class="fixed inset-0 z-[99999] hidden items-center justify-center p-4 sm:p-6">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity opacity-0" id="custom-alert-overlay" onclick="closeCustomAlert()"></div>

        <div id="custom-alert-content" class="relative w-full max-w-sm bg-white dark:bg-slate-900 rounded-3xl shadow-2xl p-6 md:p-8 transform scale-95 opacity-0 transition-all duration-300 flex flex-col items-center text-center z-10">

            <div id="alert-icon-container" class="w-16 h-16 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center mb-4 text-3xl shadow-inner">
                <i id="alert-icon" class="fa-solid fa-circle-exclamation animate-pulse"></i>
            </div>

            <h3 id="alert-title" class="text-xl font-black text-slate-900 dark:text-white mb-2">Thông báo</h3>
            <p id="alert-message" class="text-[15px] text-slate-600 dark:text-slate-400 mb-8 leading-relaxed">
                Nội dung thông báo sẽ hiện ở đây.
            </p>

            <button onclick="closeCustomAlert()" class="w-full flex items-center justify-center bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-bold py-3.5 rounded-xl hover:shadow-lg hover:shadow-cyan-500/30 transition-all duration-300 active:scale-95 uppercase tracking-wider text-sm">
                Đã hiểu
            </button>
        </div>
    </div>
</body>
<script>
    // 1. HÀM ĐIỀU KHIỂN HỘP THOẠI
    function showCustomAlert(title, message, type = 'warning') {
        const modal = document.getElementById('custom-alert-modal');
        const overlay = document.getElementById('custom-alert-overlay');
        const content = document.getElementById('custom-alert-content');

        document.getElementById('alert-title').innerText = title;
        document.getElementById('alert-message').innerText = message;

        const iconContainer = document.getElementById('alert-icon-container');
        const icon = document.getElementById('alert-icon');

        if (type === 'error') {
            iconContainer.className = "w-16 h-16 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center mb-4 text-3xl shadow-inner";
            icon.className = "fa-solid fa-circle-xmark animate-bounce";
        } else {
            iconContainer.className = "w-16 h-16 rounded-full bg-amber-100 text-amber-500 flex items-center justify-center mb-4 text-3xl shadow-inner";
            icon.className = "fa-solid fa-triangle-exclamation animate-pulse";
        }

        modal.classList.remove('hidden');
        modal.classList.add('flex');

        setTimeout(() => {
            overlay.classList.remove('opacity-0');
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeCustomAlert() {
        const modal = document.getElementById('custom-alert-modal');
        const overlay = document.getElementById('custom-alert-overlay');
        const content = document.getElementById('custom-alert-content');

        overlay.classList.add('opacity-0');
        content.classList.remove('scale-100', 'opacity-100');
        content.classList.add('scale-95', 'opacity-0');

        setTimeout(() => {
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }, 300);
    }

    // 2. Tính toán tổng tiền
    function calculateSelectedTotal() {
        let totalAmount = 0;
        let totalQty = 0;

        const checkboxes = document.querySelectorAll('.item-checkbox:checked');

        checkboxes.forEach(cb => {
            const price = parseFloat(cb.getAttribute('data-price')) || 0;
            const id = cb.value;
            const qty = parseInt(document.getElementById(`qty-${id}`).value) || 0;

            totalAmount += (price * qty);
            totalQty += qty;
        });

        const totalQtyElement = document.getElementById('total-selected-qty');
        if(totalQtyElement) totalQtyElement.innerText = totalQty;

        const formattedAmount = totalAmount.toLocaleString('vi-VN') + ' ₫';

        const subtotalSummary = document.getElementById('subtotal-summary');
        if(subtotalSummary) subtotalSummary.innerText = formattedAmount;

        const cartTotal = document.getElementById('cart-total');
        if(cartTotal) cartTotal.innerText = formattedAmount;

        const allCheckboxes = document.querySelectorAll('.item-checkbox');
        const selectAllCb = document.getElementById('selectAll');
        if(selectAllCb) {
            selectAllCb.checked = (checkboxes.length === allCheckboxes.length && allCheckboxes.length > 0);
        }
    }

    function toggleAllCheckboxes(source) {
        const checkboxes = document.querySelectorAll('.item-checkbox');
        checkboxes.forEach(cb => cb.checked = source.checked);
        calculateSelectedTotal();
    }

    // 3. KIỂM TRA TRƯỚC KHI THANH TOÁN (Đã dùng showCustomAlert)
     // 1. KIỂM TRA TRƯỚC KHI THANH TOÁN
    function validateCheckout() {
        const selectedCheckboxes = document.querySelectorAll('input[name="selectedProducts"]:checked');

        if (selectedCheckboxes.length === 0) {
            // 👇 Hộp thoại cảnh báo xịn sò
            Swal.fire({
                title: 'Chưa chọn sản phẩm!',
                text: 'Vui lòng chọn ít nhất một thiết bị trong giỏ hàng để tiến hành thanh toán nhé.',
                icon: 'warning',
                confirmButtonText: 'Đã hiểu',
                confirmButtonColor: '#06b6d4' // Màu cyan-500 chuẩn AuraHome
            });
            return false;
        }

        for (let i = 0; i < selectedCheckboxes.length; i++) {
            const productId = selectedCheckboxes[i].value;
            const qtyInput = document.getElementById('qty-' + productId);

            if (qtyInput) {
                const currentQty = parseInt(qtyInput.value) || 0;
                const maxStock = parseInt(qtyInput.getAttribute('data-stock')) || 0;
                const productName = qtyInput.getAttribute('data-name');

                if (currentQty > maxStock) {
                    // 👇 Hộp thoại lỗi xịn sò
                    Swal.fire({
                        title: 'Cháy hàng mất rồi!',
                        text: `Sản phẩm "${productName}" hiện chỉ còn ${maxStock} chiếc trong kho. Vui lòng giảm số lượng.`,
                        icon: 'error',
                        confirmButtonText: 'Chỉnh sửa ngay',
                        confirmButtonColor: '#e3001f' // Màu đỏ nổi bật
                    });
                    return false;
                }
            }
        }
        return true;
    }

    // 4. HÀM TĂNG GIẢM SỐ LƯỢNG (Đã dùng showCustomAlert)
    function updateQty(id, change) {
        const input = document.getElementById(`qty-${id}`);
        if (!input) return;

        let currentVal = parseInt(input.value) || 0;
        let newVal = currentVal + change;

        const maxStock = parseInt(input.getAttribute('data-stock')) || 0;
        const productName = input.getAttribute('data-name') || "Sản phẩm này";

        if (newVal < 1) newVal = 1;

        if (newVal > maxStock) {
        Swal.fire({
            title: 'Vượt quá tồn kho!',
            text: `Rất tiếc! "${productName}" hiện chỉ còn tối đa ${maxStock} chiếc trong kho.`,
            icon: 'info',
            confirmButtonText: 'OK',
            confirmButtonColor: '#2b3a82' // Màu brand-navy
        });
        return;
    }

        input.value = newVal;

        const checkbox = document.querySelector(`.item-checkbox[value="${id}"]`);
        if (checkbox) {
            const price = parseFloat(checkbox.getAttribute('data-price')) || 0;
            const subtotalStr = (price * newVal).toLocaleString('vi-VN') + ' ₫';

            const subtotalElement = document.getElementById(`subtotal-${id}`);
            if(subtotalElement) subtotalElement.innerText = subtotalStr;
        }

        calculateSelectedTotal();

        fetch('/Customers/UpdateCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ProductId: parseInt(id), Quantity: newVal })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                    const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 2000, // Tự tắt sau 2 giây
                    timerProgressBar: true
                });

                Toast.fire({
                    icon: 'success',
                    title: 'Đã cập nhật giỏ hàng'
                });
                fetch('/Customers/GetMiniCartAjax')
                    .then(r => r.json())
                    .then(miniData => {
                        if (miniData.success) {
                            const cartBadge = document.getElementById('cartCountBadge');
                            if (cartBadge) cartBadge.innerText = miniData.totalItems;
                        }
                    });
            }
        })
        .catch(error => console.error('Lỗi khi cập nhật giỏ hàng:', error));
    }
</script>