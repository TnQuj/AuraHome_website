@model AISmartHome.Models.GioHang
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Http
@inject AISmartHome.Data.AISmartHomeDbContext _context

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thanh toán đơn hàng";

    decimal tongTienHang = Model?.ChiTietGioHangs?.Sum(x => (x.Gia ?? 0) * (x.SoLuong ?? 0)) ?? 0;

    decimal tienGiamGia = ViewBag.TienGiamGia ?? 0;

   
    decimal tongTienSauGiam = tongTienHang - tienGiamGia;
    if (tongTienSauGiam < 0) tongTienSauGiam = 0;

  
    decimal tienCoc = tongTienSauGiam * 0.3m;

    decimal tienConLai = tongTienSauGiam - tienCoc;

    string serverVerifiedPhone = Context.Request.Cookies["VerifiedPhone"] ?? "";
    bool isUserLoggedIn = User.Identity?.IsAuthenticated ?? false;
    string loggedInUserPhone = "";

    if (isUserLoggedIn)
    {
        var userEmail = User.Identity.Name;
        var user = _context.KhachHangs.FirstOrDefault(k => k.Email == userEmail);
        loggedInUserPhone = user?.SoDienThoai ?? "";
    }
}
<style>
    .ambient-blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
        animation: float 10s infinite alternate ease-in-out;
    }

    @@keyframes float {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(30px, -50px) scale(1.1);
        }
    }
</style>
<div class="bg-[#FAFCFF] dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display min-h-screen relative overflow-hidden">

    <div class="ambient-blob bg-cyan-300/40 w-[30rem] h-[30rem] rounded-full top-[-5%] left-[-10%] pointer-events-none dark:opacity-10"></div>
    <div class="ambient-blob bg-indigo-300/30 w-[40rem] h-[40rem] rounded-full top-[20%] right-[-15%] pointer-events-none dark:opacity-10" style="animation-delay: -5s;"></div>

    <main class="w-full pb-20 pt-8 bg-slate-50/50">
        <div class="container mx-auto px-4 md:px-8">

            <div class="relative group w-full mx-auto">
                <div class="absolute -inset-1.5 bg-gradient-to-r from-brand-cyan via-blue-500 to-indigo-500 rounded-[2.5rem] blur-lg opacity-40 group-hover:opacity-75 transition duration-1000 group-hover:duration-200 animate-pulse"></div>

                <div class="relative bg-slate-50 rounded-3xl p-6 md:p-10 shadow-2xl h-full w-full border border-white/50">

                    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-10 font-medium relative z-10">
                        <a class="hover:text-brand-cyan transition-colors" asp-controller="Customers" asp-action="Index">Trang chủ</a>
                        <i class="fa-solid fa-chevron-right text-[10px]"></i>
                        <a class="hover:text-brand-cyan transition-colors" asp-action="Cart">Giỏ hàng</a>
                        <i class="fa-solid fa-chevron-right text-[10px]"></i>
                        <span class="text-brand-navy font-bold px-2 py-1 bg-white shadow-sm rounded-md border border-slate-100">Thanh toán</span>
                    </nav>

                    <form id="checkoutForm" asp-action="PlaceOrder" method="post" onsubmit="event.preventDefault(); return false;" class="relative z-10">
                        @if (Model?.ChiTietGioHangs != null)
                        {
                            foreach (var item in Model.ChiTietGioHangs)
                            {
                                <input type="hidden" name="SelectedProducts" value="@item.MaSanPham" />
                            }
                        }
                        <div class="flex flex-col lg:flex-row gap-12">

                            <div class="w-full lg:w-[60%]">
                                <h2 class="text-xl font-black text-brand-navy uppercase tracking-wider mb-8 border-b-2 border-slate-100 pb-2">
                                    Thông tin liên hệ & Giao hàng
                                </h2>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Họ và tên *</label>
                                        <input type="text" id="FullName" name="FullName" value="@ViewBag.VipName" placeholder="Nhập họ và tên"
                                               class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/20 outline-none transition-all">
                                    </div>

                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Số điện thoại *</label>

                                        <input type="tel" id="checkoutPhone" name="Phone"
                                               value="@ViewBag.VipPhone"
                                        @(ViewBag.IsVerified == true ? "readonly" : "")
                                               required placeholder="Nhập số điện thoại"
                                               class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/20 outline-none transition-all @(ViewBag.IsVerified == true ? "bg-slate-100 text-slate-500 cursor-not-allowed" : "bg-white")">

                                        @if (ViewBag.IsVerified == true)
                                        {
                                            <input type="hidden" id="isPhoneVerified" value="true" />
                                            <p class="text-xs text-emerald-600 font-bold mt-2 flex items-center gap-1">
                                                <i class="fa-solid fa-circle-check"></i> Số điện thoại đã được xác thực
                                            </p>
                                        }
                                        else
                                        {
                                            <input type="hidden" id="hiddenOtpCode" name="OtpCode" value="" />
                                        }
                                    </div>

                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Địa chỉ email *</label>
                                        <input type="email" id="Email" name="Email"
                                               value="@ViewBag.VipEmail"
                                               required placeholder="Nhập địa chỉ email"
                                               class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/20 outline-none transition-all bg-white">
                                    </div>

                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Tỉnh/Thành phố *</label>
                                        <select id="province" name="Province" required
                                                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan outline-none transition-all bg-white">
                                            <option value="">Chọn Tỉnh/Thành phố</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Quận/Huyện *</label>
                                        <select id="district" name="District" required
                                                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan outline-none transition-all bg-white">
                                            <option value="">Chọn Quận/Huyện</option>
                                        </select>
                                    </div>

                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-bold text-slate-700 mb-2">Địa chỉ nhận hàng *</label>
                                        <input type="text" name="Address" required placeholder="Nhập địa chỉ cụ thể. Số nhà, tên đường..."
                                               class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/20 outline-none transition-all">
                                    </div>
                                </div>

                                <h2 class="text-xl font-black text-brand-navy uppercase tracking-wider mt-12 mb-8 border-b-2 border-slate-100 pb-2">
                                    Thông tin bổ sung
                                </h2>
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Ghi chú đơn hàng (tuỳ chọn)</label>
                                    <textarea name="GhiChu" rows="4" placeholder="Ghi chú về đơn hàng, ví dụ: thời gian hay chỉ dẫn địa điểm giao hàng chi tiết hơn."
                                              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-1 focus:ring-brand-cyan/20 outline-none transition-all"></textarea>
                                </div>
                            </div>
                            <!--Thông tin đơn hàng-->
                            <div class="w-full lg:w-[40%]">
                                <div class="bg-white p-6 md:p-8 rounded-[2rem] border border-slate-100 sticky top-28 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-cyan-400 to-blue-600"></div>

                                    <h2 class="text-xl font-black text-slate-800 uppercase mb-6 tracking-wide flex items-center gap-2">
                                        <span class="w-8 h-8 rounded-full bg-cyan-50 flex items-center justify-center text-cyan-500 shadow-sm">
                                            <i class="fa-solid fa-receipt text-sm"></i>
                                        </span>
                                        Tổng quan đơn hàng
                                    </h2>

                                    <div class="space-y-3 mb-6 border-b-2 border-dashed border-slate-100 pb-6 max-h-72 overflow-y-auto custom-scrollbar pr-2">
                                        @if (Model?.ChiTietGioHangs != null)
                                        {
                                            @foreach (var item in Model.ChiTietGioHangs)
                                            {
                                                <div class="flex items-center gap-4 text-sm bg-white hover:bg-slate-50 p-3 rounded-2xl border border-slate-100 hover:border-slate-200 transition-colors shadow-sm group">
                                                    <div class="w-14 h-14 bg-white rounded-xl p-1.5 shrink-0 border border-slate-100 shadow-[0_2px_10px_rgba(0,0,0,0.02)] group-hover:shadow-[0_2px_10px_rgba(6,182,212,0.1)] transition-shadow">
                                                        <img src="/img/@item.MaSanPhamNavigation?.HinhAnh" alt="Ảnh" class="w-full h-full object-contain" onerror="this.src='https://via.placeholder.com/150'" />
                                                    </div>
                                                    <div class="flex-1 min-w-0">
                                                        <span class="text-slate-700 font-bold line-clamp-1 group-hover:text-cyan-600 transition-colors">@item.MaSanPhamNavigation?.TenSanPham</span>
                                                        <span class="text-[11px] text-slate-400 font-medium uppercase tracking-wider block mt-0.5">Đơn giá: @(item.Gia?.ToString("N0")) đ</span>
                                                    </div>
                                                    <div class="text-right shrink-0 pl-2">
                                                        <div class="text-[11px] font-bold text-slate-400 mb-0.5 bg-slate-100 rounded-md inline-block px-1.5 py-0.5">SL: @item.SoLuong</div>
                                                        <div class="font-black text-slate-800 text-[13px]">@(((item.Gia ?? 0) * (item.SoLuong ?? 0)).ToString("N0")) đ</div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                    <!--Vouchers-->
                                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm mb-6">
                                        <div class="flex items-center justify-between mb-4">
                                            <h3 class="text-lg font-bold text-slate-800"><i class="fa-solid fa-ticket text-brand-cyan mr-2"></i>Mã giảm giá</h3>
                                            <button type="button" onclick="showMyVouchers()" class="text-sm font-bold text-cyan-600 hover:text-cyan-700 underline underline-offset-2">
                                                <i class="fa-solid fa-gift mr-1"></i> Xem ưu đãi của tôi
                                            </button>
                                        </div>

                                        <div class="flex gap-3 relative">
                                            <input type="text" id="voucherCode" placeholder="Nhập mã AuraHome của bạn..." class="w-full border border-slate-300 rounded-xl px-4 py-3 outline-none focus:border-brand-cyan uppercase font-semibold text-slate-700 transition-colors">
                                            <button type="button" onclick="checkVoucher()" id="btnApplyVoucher" class="bg-slate-800 text-white font-bold px-6 py-3 rounded-xl hover:bg-brand-cyan transition-colors whitespace-nowrap">
                                                Áp dụng
                                            </button>
                                        </div>

                                        <p id="voucherMessage" class="text-sm mt-3 font-medium hidden"></p>
                                    </div>

                                    <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200">
                                        <div class="flex justify-between mb-2 text-slate-600">
                                            <span>Tạm tính:</span>
                                            <span id="subTotalDisplay" data-value="@tongTienHang">@String.Format("{0:N0}", tongTienHang) đ</span>
                                        </div>

                                        <div id="discountRow" class="flex justify-between mb-2 text-emerald-600 font-bold hidden">
                                            <span>Đã giảm (Voucher):</span>
                                            <span id="discountDisplay">-0 đ</span>
                                        </div>

                                        <hr class="my-4 border-slate-200">

                                        <div class="flex justify-between text-xl font-black text-slate-900">
                                            <span>Tổng thanh toán:</span>
                                            <span id="finalTotalDisplay">@String.Format("{0:N0}", tongTienHang) đ</span>
                                        </div>
                                    </div>

                                    <div class="mb-6">
                                        <label for="CanLapDat" class="cursor-pointer relative flex items-center p-4 rounded-2xl border border-slate-200 bg-white transition-all overflow-hidden group hover:shadow-md hover:border-cyan-300">
                                            <input id="CanLapDat" name="CanLapDat" type="checkbox" value="true" checked class="peer sr-only">

                                            <div class="absolute inset-0 bg-cyan-50/50 opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none"></div>
                                            <div class="absolute inset-0 border-2 border-cyan-400 rounded-2xl opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none"></div>

                                            <div class="relative flex items-center justify-center w-6 h-6 shrink-0 rounded-md border-2 border-slate-300 bg-white peer-checked:bg-cyan-500 peer-checked:border-cyan-500 peer-checked:[&>i]:scale-100 transition-all shadow-sm pointer-events-none">
                                                <i class="fa-solid fa-check text-white text-[12px] scale-0 transition-transform duration-300"></i>
                                            </div>

                                            <div class="relative ml-4 pointer-events-none flex-1">
                                                <span class="font-bold text-slate-800 block text-sm peer-checked:text-cyan-700 transition-colors">Cần kỹ thuật viên lắp đặt</span>
                                                <span class="text-slate-500 text-[11px] leading-tight block mt-0.5">Phí thi công sẽ được báo sau. Bỏ chọn nếu tự lắp.</span>
                                            </div>

                                            <div class="relative shrink-0 w-10 h-10 bg-slate-50 rounded-full flex items-center justify-center text-slate-400 peer-checked:bg-cyan-100 peer-checked:text-cyan-500 transition-colors pointer-events-none">
                                                <i class="fa-solid fa-screwdriver-wrench"></i>
                                            </div>
                                        </label>
                                        <input name="CanLapDat" type="hidden" value="false" />
                                    </div>

                                    <div class="mb-8">
                                        <h3 class="text-[12px] font-bold text-slate-400 mb-3 uppercase tracking-[0.1em] flex items-center gap-2">
                                            <i class="fa-solid fa-money-check-dollar"></i> Hình thức thanh toán
                                        </h3>
                                        <div class="grid grid-cols-2 gap-3 sm:gap-4">

                                            <label class="cursor-pointer relative h-full">
                                                <input type="radio" name="PaymentMode" value="100" class="peer sr-only" checked>
                                                <div class="h-full p-3 sm:p-4 text-center rounded-2xl border-2 border-slate-100 bg-white peer-checked:border-brand-navy peer-checked:bg-slate-50 peer-checked:shadow-[0_0_0_4px_rgba(15,23,42,0.05)] transition-all hover:border-slate-300 flex flex-col justify-center items-center gap-1">
                                                    <i class="fa-solid fa-circle-check text-brand-navy opacity-0 peer-checked:opacity-100 absolute top-3 right-3 transition-opacity"></i>
                                                    <div class="font-black text-brand-navy text-sm sm:text-base">Trả trước 100%</div>
                                                    <div class="text-[11px] text-slate-500 font-medium">Thanh toán toàn bộ</div>
                                                </div>
                                            </label>

                                            <label class="cursor-pointer relative h-full" id="depositOptionWrapper">
                                                <input type="radio" name="PaymentMode" value="30" id="radioDeposit" class="peer sr-only">
                                                <div class="h-full p-3 sm:p-4 text-center rounded-2xl border-2 border-slate-100 bg-white peer-checked:border-rose-500 peer-checked:bg-rose-50 peer-checked:shadow-[0_0_0_4px_rgba(244,63,94,0.1)] transition-all hover:border-slate-300 flex flex-col justify-center items-center gap-1">
                                                    <i class="fa-solid fa-circle-check text-rose-500 opacity-0 peer-checked:opacity-100 absolute top-3 right-3 transition-opacity"></i>
                                                    <div class="font-black text-rose-600 text-sm sm:text-base">Cọc 30% giữ đơn</div>
                                                    <div class="text-[11px] text-slate-500 font-medium">Thu phần còn lại sau</div>
                                                </div>
                                            </label>

                                        </div>
                                    </div>

                                    <div class="relative overflow-hidden bg-gradient-to-br from-slate-900 to-slate-800 p-6 sm:p-8 rounded-3xl border border-slate-700/50 shadow-2xl mb-6 group transition-all duration-300 hover:border-slate-600">
                                        <div class="absolute -top-16 -right-16 w-40 h-40 bg-brand-cyan/20 rounded-full blur-[40px] pointer-events-none group-hover:bg-brand-cyan/30 transition-colors duration-700"></div>
                                        <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-cyan-500 to-transparent opacity-50"></div>

                                        <div class="relative z-10 flex flex-col sm:flex-row justify-between sm:items-end gap-5">
                                            <div class="flex flex-col items-start gap-3">
                                                <div class="flex items-center gap-2">
                                                    <i class="fa-solid fa-wallet text-cyan-400"></i>
                                                    <span class="text-slate-400 text-xs font-bold uppercase tracking-[0.15em]">Số tiền cần chuyển</span>
                                                </div>
                                                <span id="badgePaymentType" class="inline-flex items-center gap-1.5 text-[11px] font-black uppercase tracking-wider bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 px-3 py-1.5 rounded-lg backdrop-blur-md shadow-sm">
                                                    <i class="fa-solid fa-check-circle text-[10px]"></i> Thanh toán 100%
                                                </span>
                                            </div>

                                            <div class="text-left sm:text-right mt-2 sm:mt-0">
                                                <span class="block text-[11px] text-slate-500 font-medium mb-1 uppercase tracking-widest">Tổng cộng (VNĐ)</span>

                                                @if (tongTienHang > tongTienSauGiam)
                                                {
                                                    <span class="block text-sm text-slate-400 line-through mb-1 font-bold">
                                                        @tongTienHang.ToString("N0")
                                                    </span>
                                                }

                                                <span class="font-black text-4xl sm:text-5xl tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-white via-cyan-100 to-cyan-500 drop-shadow-[0_0_15px_rgba(6,182,212,0.4)]"
                                                      id="depositAmountDisplay"
                                                      data-total="@tongTienSauGiam"
                                                      data-deposit="@tienCoc"
                                                      data-value="@tongTienSauGiam">
                                                    @tongTienSauGiam.ToString("N0")
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <input type="hidden" id="hiddenVoucherCode" name="VoucherCode" value="" />

                                    <button id="btn-checkout" type="button" onclick="processCheckout()" class="w-full relative group flex justify-center items-center gap-3 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white py-5 rounded-2xl font-black uppercase tracking-[0.1em] text-[15px] transition-all duration-300 shadow-[0_10px_30px_-10px_rgba(6,182,212,0.6)] hover:shadow-[0_15px_40px_-10px_rgba(6,182,212,0.8)] hover:-translate-y-1">
                                        <i class="fa-solid fa-shield-halved text-[18px] opacity-90"></i>
                                        <span>Thanh toán an toàn</span>
                                        <i class="fa-solid fa-arrow-right text-[15px] opacity-70 group-hover:opacity-100 group-hover:translate-x-1.5 transition-all duration-300"></i>
                                    </button>

                                </div>
                            </div>

                        </div>
                    </form>
                </div>
            </div>

        </div>

        <div id="otpModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm transition-all">
            <div class="bg-white p-8 rounded-2xl shadow-2xl w-[90%] max-w-md transform scale-100 transition-transform">
                <h3 class="text-2xl font-black text-brand-navy mb-2 text-center uppercase">Xác thực số điện thoại</h3>
                <p class="text-slate-500 text-sm text-center mb-6">
                    Chúng tôi đã gửi một mã gồm 6 chữ số đến số điện thoại <br />
                    <strong id="displayPhone" class="text-brand-cyan"></strong>
                </p>

                <div class="mb-6">
                    <input type="text" id="otpInput" maxlength="6" placeholder="Nhập mã OTP (VD: 123456)"
                           class="w-full text-center tracking-widest text-2xl font-bold px-4 py-3 rounded-xl border-2 border-slate-200 focus:border-brand-cyan focus:ring-4 focus:ring-brand-cyan/20 outline-none transition-all">
                </div>

                <div class="flex gap-4">
                    <button id="btnCancelOtp" type="button" class="w-1/2 py-3 font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors">
                        Hủy bỏ
                    </button>
                    <button id="btnVerifyOtp" type="button" class="w-full py-3 font-bold text-white bg-brand-cyan hover:bg-cyan-600 rounded-xl transition-colors shadow-lg shadow-cyan-600/30">
                        Xác nhận
                    </button>
                </div>
                <p class="text-center text-xs text-slate-400 mt-4">
                    Chưa nhận được mã?
                    <button type="button" id="btnResendOtp" class="text-brand-cyan font-bold hover:underline disabled:opacity-50 disabled:cursor-not-allowed disabled:no-underline" disabled>
                        Gửi lại (<span id="otpTimer">60</span>s)
                    </button>
                </p>
            </div>
        </div>

        <div id="qrModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-brand-navy/90 backdrop-blur-sm transition-all p-4">
            <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-sm overflow-hidden flex flex-col transform scale-100 transition-transform">

                <div class="bg-gradient-to-br from-brand-navy to-slate-800 p-6 pt-8 pb-16 text-center relative">
                    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
                    <h3 id="qrModalTitle" class="text-xl font-black text-white uppercase tracking-widest relative z-10">Thanh toán đơn hàng</h3>
                    <p class="text-brand-cyan text-sm mt-1 relative z-10 font-medium">Mã đơn: <strong id="qrOrderId" class="text-white text-base tracking-wider">#...</strong></p>
                </div>

                <div class="px-6 pb-6 flex flex-col items-center bg-slate-50 relative rounded-t-[2rem] -mt-10">

                    <div class="bg-white p-3 rounded-2xl shadow-xl -mt-12 w-48 h-48 flex items-center justify-center border border-slate-100 relative z-20">
                        <img id="qrImage" src="" alt="QR Code" class="w-full h-full object-contain hidden" />
                        <div id="qrLoading" class="text-brand-cyan flex flex-col items-center">
                            <i class="fa-solid fa-spinner fa-spin text-3xl mb-2"></i>
                            <span class="text-xs font-bold uppercase tracking-wider">Đang tạo mã...</span>
                        </div>
                    </div>

                    <div class="w-full mt-6 bg-white rounded-xl border border-slate-100 p-1 shadow-sm">
                        <div class="p-3 border-b border-slate-50 flex justify-between items-center">
                            <span id="qrAmountLabel" class="text-slate-500 text-xs font-bold uppercase">Số tiền cần quét:</span>
                            <span id="qrAmount" class="font-black text-rose-600 text-xl">0 đ</span>
                        </div>
                        <div class="p-3 flex justify-between items-center bg-slate-50/50 rounded-b-lg">
                            <span class="text-slate-500 text-xs font-bold uppercase">Nội dung:</span>
                            <span id="qrContent" class="font-bold text-brand-navy text-sm max-w-[160px] truncate text-right">...</span>
                        </div>
                    </div>
                </div>

                <div class="p-6 bg-white border-t border-slate-100 flex flex-col gap-3">
                    <button id="btnFinishOrder" type="button" class="w-full py-4 font-black text-white bg-brand-cyan hover:bg-cyan-600 rounded-xl transition-all shadow-lg shadow-cyan-600/30 uppercase tracking-widest flex justify-center items-center gap-2">
                        <i class="fa-solid fa-check-double"></i> Đã chuyển khoản xong
                    </button>

                    <button id="btnCancelTransaction" type="button" class="w-full py-3.5 font-bold text-slate-500 bg-slate-100 hover:bg-rose-50 hover:text-rose-600 rounded-xl transition-colors flex justify-center items-center gap-2">
                        <i class="fa-solid fa-xmark"></i> Hủy giao dịch
                    </button>

                    <button id="btnSimulateWebhook" type="button" class="w-full py-3 mt-2 font-bold text-emerald-600 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 rounded-xl transition-colors flex justify-center items-center gap-2">
                        <i class="fa-solid fa-magic"></i> Giả lập Khách đã chuyển khoản (Demo)
                    </button>

                    <p id="qrFooterNote" class="text-[11px] text-slate-400 mt-2 text-center px-2 leading-relaxed">
                        <i class="fa-solid fa-circle-notch fa-spin text-brand-cyan mr-1"></i> Hệ thống đang tự động quét trạng thái thanh toán...
                    </p>
                </div>

            </div>
        </div>

        <div id="voucherModal" class="fixed inset-0 z-[10001] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm px-4">
            <div class="bg-white rounded-[2rem] p-6 w-full max-w-md shadow-2xl relative animate-fade-in scale-95 transition-transform" id="voucherModalContent">

                <button type="button" onclick="closeVoucherModal()" class="absolute top-4 right-4 size-8 flex items-center justify-center rounded-full bg-slate-100 text-slate-500 hover:bg-rose-500 hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>

                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-cyan-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-cyan-500">
                        <span class="material-symbols-outlined text-3xl">confirmation_number</span>
                    </div>
                    <h3 class="text-xl font-black text-slate-900">Ưu đãi của bạn</h3>
                    <p class="text-sm text-slate-500">Chọn một mã để áp dụng cho đơn hàng</p>
                </div>

                <div id="voucherListContainer" class="space-y-3 max-h-[350px] overflow-y-auto pr-2 custom-scrollbar">
                    <div class="py-10 text-center text-slate-400">
                        <i class="fa-solid fa-spinner fa-spin text-2xl mb-2"></i>
                        <p>Đang kiểm tra kho quà tặng...</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>

<script>
    // =====================================================================
    // BIẾN TOÀN CỤC & TỰ ĐIỀN THÔNG TIN
    // =====================================================================
    let checkoutTimerInterval;
    let isGlobalLocked = false; // 👈 Ổ KHÓA CHỐNG DOUBLE CLICK TUYỆT ĐỐI
    let isOrderSuccessfullyCreated = false;

    const serverVerifiedPhone = '@serverVerifiedPhone';
    const isUserLoggedIn = @(isUserLoggedIn.ToString().ToLower());
    const loggedInUserPhone = '@loggedInUserPhone';

        function showMyVouchers() {
        // 1. Kiểm tra xem khách đã nhập Email chưa (Vì Voucher của Vòng quay may mắn gắn theo Email)
        const emailInput = document.querySelector('input[name="Email"]');
        const email = emailInput?.value.trim();

        if (!email) {
            Swal.fire({
                icon: 'warning',
                title: 'Chưa có Email',
                text: 'Bạn vui lòng điền Email trước để hệ thống kiểm tra danh sách quà tặng dành riêng cho bạn nhé!',
                confirmButtonColor: '#06b6d4'
            });
            emailInput?.focus();
            return;
        }

        // 2. Mở Modal
        const modal = document.getElementById('voucherModal');
        const container = document.getElementById('voucherListContainer');

        if (modal && container) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');

            // Hiệu ứng phóng to nhẹ khi mở
            setTimeout(() => {
                document.getElementById('voucherModalContent')?.classList.remove('scale-95');
            }, 10);

            // 3. Gọi API lấy danh sách Voucher từ Server
            fetch(`/Cart/GetMyVouchers?email=${encodeURIComponent(email)}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success && res.data.length > 0) {
                        let html = '';
                        res.data.forEach(v => {
                            html += `
                            <div class="p-4 rounded-2xl border-2 border-dashed border-slate-100 hover:border-cyan-500 hover:bg-cyan-50 transition-all cursor-pointer group"
                                 onclick="selectVoucher('${v.code}')">
                                <div class="flex justify-between items-center">
                                    <div>
                                        <h4 class="font-black text-slate-800 group-hover:text-cyan-600">${v.code}</h4>
                                        <p class="text-xs text-slate-500">${v.moTa || 'Giảm giá trực tiếp đơn hàng'}</p>
                                    </div>
                                    <span class="material-symbols-outlined text-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity">add_circle</span>
                                </div>
                            </div>`;
                        });
                        container.innerHTML = html;
                    } else {
                        container.innerHTML = `<div class="text-center py-10 text-slate-400 font-medium">Bạn chưa có mã giảm giá nào cho email này.</div>`;
                    }
                })
                .catch(() => {
                    container.innerHTML = `<div class="text-center py-10 text-rose-500 font-medium">Lỗi kết nối máy chủ!</div>`;
                });
        }
    }

    // Hàm đóng Modal
    function closeVoucherModal() {
        const modal = document.getElementById('voucherModal');
        if (modal) {
            document.getElementById('voucherModalContent')?.classList.add('scale-95');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    }

    // Hàm khi chọn 1 mã từ danh sách
    function selectVoucher(code) {
        const voucherInput = document.getElementById('voucherCode');
        if (voucherInput) {
            voucherInput.value = code;
            closeVoucherModal();
            checkVoucher(); // Tự động bấm "Áp dụng" luôn cho khách
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        // 1. Xử lý tự điền Số điện thoại (Code cũ của bạn)
        const phoneInput = document.getElementById('checkoutPhone');
        const defaultPhone = isUserLoggedIn ? loggedInUserPhone : serverVerifiedPhone;

        if (phoneInput && phoneInput.value === "") {
            // Nếu có số từ Server (Vip/Cookie) thì ưu tiên dùng trước
            if (defaultPhone) {
                phoneInput.value = defaultPhone;
            } else {
                // Nếu không thì mới lấy từ LocalStorage
                let storagePhone = localStorage.getItem('guestPhone');
                if (storagePhone) phoneInput.value = storagePhone;
            }
        }

        // =========================================================
        // 🚀 CHÈN ĐOẠN CODE TỰ ĐỘNG CHECK VOUCHER KHI NHẬP EMAIL VÀO ĐÂY
        // =========================================================
        const emailInput = document.querySelector('input[name="Email"]');
        if (emailInput) {
            emailInput.addEventListener('change', function() {
                const voucherCodeInput = document.getElementById('voucherCode');
                const currentVoucher = voucherCodeInput ? voucherCodeInput.value.trim() : "";

                // Nếu khách đã lỡ nhập mã Voucher trước đó rồi mới quay lại nhập Email
                if (currentVoucher !== "") {
                    console.log("Email đã nhập, tự động kiểm tra lại mã giảm giá...");
                    checkVoucher();
                }
            });
        }
        // =========================================================
    });

    // KHÓA TÍNH NĂNG TỰ ĐỘNG SUBMIT CỦA FORM KHI NHẤN ENTER
    const checkoutForm = document.getElementById('checkoutForm');
    if (checkoutForm) {
        checkoutForm.onsubmit = function(e) {
            e.preventDefault();
            return false;
        };
    }

    // =====================================================================
    // 1. XỬ LÝ KHI BẤM NÚT "THANH TOÁN AN TOÀN"
    // =====================================================================
        function processCheckout() {
        if (window.isGlobalLocked) return;

        const form = document.getElementById('checkoutForm');
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        // Làm sạch số điện thoại
        let currentPhone = document.getElementById('checkoutPhone').value.trim();
        let cleanCurrent = currentPhone.replace(/\D/g, '');

        // Gán biến an toàn tránh lỗi 'undefined'
        let svPhone = typeof serverVerifiedPhone !== 'undefined' ? serverVerifiedPhone : '';
        let logPhone = typeof loggedInUserPhone !== 'undefined' ? loggedInUserPhone : '';
        let isLogged = typeof isUserLoggedIn !== 'undefined' ? isUserLoggedIn : false;

        let cleanServer = svPhone ? svPhone.replace(/\D/g, '') : '';
        let cleanLoggedIn = logPhone ? logPhone.replace(/\D/g, '') : '';

        if (cleanCurrent.startsWith('84')) cleanCurrent = '0' + cleanCurrent.substring(2);
        if (cleanServer.startsWith('84')) cleanServer = '0' + cleanServer.substring(2);
        if (cleanLoggedIn.startsWith('84')) cleanLoggedIn = '0' + cleanLoggedIn.substring(2);

        // Kiểm tra miễn OTP
        const isExemptFromOtp = (isLogged && cleanCurrent === cleanLoggedIn) ||
                                (cleanCurrent !== '' && cleanCurrent === cleanServer);

        const hiddenOtpElement = document.getElementById('hiddenOtpCode');
        const hiddenOtp = hiddenOtpElement ? hiddenOtpElement.value.trim() : '';

        if (!isExemptFromOtp && hiddenOtp.length !== 6) {
            // MỞ BẢNG OTP NẾU LÀ SỐ MỚI HOẶC CHƯA XÁC THỰC
            const otpModal = document.getElementById('otpModal');
            if (otpModal) {
                otpModal.classList.remove('hidden');
                otpModal.classList.add('flex');
                const displayPhone = document.getElementById('displayPhone');
                if (displayPhone) displayPhone.innerText = currentPhone;

                if (typeof sendOtpCheckoutLogic === "function") {
                    sendOtpCheckoutLogic(currentPhone);
                }
            }
        } else {
            // TẠO ĐƠN HÀNG NGAY NẾU ĐÃ CÓ OTP HOẶC ĐƯỢC MIỄN
            submitOrderAjax();
        }
    }
    // =====================================================================
    // 2. CÁC HÀM XỬ LÝ BÊN TRONG BẢNG OTP
    // =====================================================================
    function sendOtpCheckoutLogic(rawPhone) {
        let cleanPhoneForApi = rawPhone.replace(/\D/g, '');
        if (cleanPhoneForApi.startsWith('84')) {
            cleanPhoneForApi = '0' + cleanPhoneForApi.substring(2);
        }

        const btnResend = document.getElementById('btnResendOtp');
        if(btnResend) {
            btnResend.disabled = true;
            btnResend.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi...';
        }

        fetch('/api/Otp/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone: cleanPhoneForApi })
        })
        .then(res => res.json())
        .then(data => {
               if (data.success) {
        document.getElementById('otpInput').value = '';

        if (data.otp) {
            // 🌟 NÂNG CẤP UI (Dành cho lúc test/demo có trả mã OTP về)
            Swal.fire({
                toast: true,
                position: 'top-end', // Trượt từ góc trên bên phải
                icon: 'info',
                title: 'Tin nhắn hệ thống',
                html: `Mã OTP của bạn là: <b class="text-xl text-cyan-600 tracking-[0.2em] ml-1">${data.otp}</b>`,
                showConfirmButton: false,
                timer: 8000, // Hiện 8 giây cho khách kịp nhìn
                timerProgressBar: true,
                customClass: {
                    popup: 'rounded-2xl shadow-xl border border-slate-100 bg-white mt-14 mr-4',
                    title: 'text-sm text-slate-500 font-normal',
                }
            });
        } else {
            // 🌟 NÂNG CẤP UI (Dành cho thực tế khi gửi qua SMS/Email)
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: 'Đã gửi mã xác nhận!',
                text: 'Vui lòng kiểm tra tin nhắn điện thoại.',
                showConfirmButton: false,
                timer: 4000,
                customClass: {
                    popup: 'rounded-2xl shadow-xl border border-slate-100 bg-white mt-14 mr-4'
                }
            });
        }

        // Xử lý đếm ngược nút "Gửi lại" (Giữ nguyên của bạn)
        let timeLeft = 30;
        clearInterval(checkoutTimerInterval);

        if (btnResend) {
            checkoutTimerInterval = setInterval(() => {
                if (timeLeft <= 0) {
                    clearInterval(checkoutTimerInterval);
                    btnResend.innerText = 'Gửi lại mã';
                    btnResend.disabled = false;
                } else {
                    btnResend.innerText = `Gửi lại (${timeLeft}s)`;
                    btnResend.disabled = true; // Khóa nút lúc đang đếm
                    timeLeft--;
                }
            }, 1000);
        }
    } else {
        Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'error',
            title: 'Lỗi gửi mã',
            text: data.message,
            showConfirmButton: false,
            timer: 4000,
            customClass: { popup: 'rounded-2xl shadow-xl border border-slate-100 mt-14 mr-4' }
        });
        if (btnResend) { btnResend.innerText = 'Gửi lại mã'; btnResend.disabled = false; }
    }
        });
    }

     const btnCancelOtp = document.getElementById('btnCancelOtp');
    if(btnCancelOtp) {
        btnCancelOtp.onclick = function() {
            document.getElementById('otpModal').classList.add('hidden');
            document.getElementById('otpModal').classList.remove('flex');
            clearInterval(checkoutTimerInterval);
        };
    }

    const btnResendOtp = document.getElementById('btnResendOtp');
    if(btnResendOtp) {
        btnResendOtp.onclick = function() {
            const currentPhone = document.getElementById('checkoutPhone').value.trim();
            sendOtpCheckoutLogic(currentPhone);
        };
    }
    // =====================================================================
    // 1. SỰ KIỆN NÚT XÁC NHẬN OTP (CHỐNG DOUBLE CLICK TUYỆT ĐỐI)
    // =====================================================================
    window.isGlobalLocked = false; // Khai báo khóa ở cấp độ toàn cục

    const otpInput = document.getElementById('otpInput');
    const btnVerifyOtp = document.getElementById('btnVerifyOtp');

    if (otpInput && btnVerifyOtp) {
        otpInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                if (!window.isGlobalLocked) {
                    btnVerifyOtp.click();
                }
                return false;
            }
        });

        btnVerifyOtp.onclick = function(e) {
            e.preventDefault();

            // 🚨 BỨC TƯỜNG THÉP: Đang xử lý thì cấm bấm tiếp
            if (window.isGlobalLocked) return;

            const otpValue = otpInput.value.trim();

            if (otpValue.length === 6) {
                // ĐÓNG KHÓA NGAY LẬP TỨC
                window.isGlobalLocked = true;

                document.getElementById('hiddenOtpCode').value = otpValue;
                document.getElementById('otpModal').classList.add('hidden');
                document.getElementById('otpModal').classList.remove('flex');

                submitOrderAjax();
            } else {
                Swal.fire('Chú ý', 'Vui lòng nhập đủ 6 số OTP', 'warning');
            }
        };
    }

    // =====================================================================
    // 2. HÀM TẠO ĐƠN HÀNG AJAX TỔNG HỢP (QR + POLLING + AUTO LOGIN)
    // =====================================================================
    let isSubmittingOrder = false;
    function submitOrderAjax(event) {

            if (event && event.preventDefault) {
            event.preventDefault();
        }

        // Nếu đang xử lý rồi thì bỏ qua không làm gì cả
        if (isSubmittingOrder) return;

        // Đánh dấu là đang xử lý
        isSubmittingOrder = true;
        const btnSubmit = document.getElementById('btn-checkout');
        const originalBtnText = btnSubmit ? btnSubmit.innerHTML : '';

        if (btnSubmit) {
            btnSubmit.disabled = true;
            btnSubmit.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...';
        }

        Swal.fire({
            title: 'Đang khởi tạo đơn hàng...',
            text: 'Vui lòng chờ trong giây lát.',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        const form = document.getElementById('checkoutForm');
        const formData = new FormData(form);

        const correctOtp = document.getElementById('hiddenOtpCode') ? document.getElementById('hiddenOtpCode').value.trim() : '';
        formData.set('OtpCode', correctOtp);

        fetch(form.action, {
            method: 'POST',
            body: formData,
            credentials: 'same-origin'
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                Swal.close();

                // 1. Hàm hiển thị Modal QR (Chỉ định nghĩa, chưa gọi)
                const showQRModal = () => {
                    const amountDisplay = document.getElementById('depositAmountDisplay');
                    const checkedMode = document.querySelector('input[name="PaymentMode"]:checked');
                    const paymentMode = checkedMode ? checkedMode.value : "100";

                    let amountToPay = 0;
                    if (amountDisplay) {
                        amountToPay = (paymentMode === "30")
                                    ? amountDisplay.getAttribute('data-deposit')
                                    : amountDisplay.getAttribute('data-total');
                    }

                    const qrModal = document.getElementById('qrModal');
                    if (qrModal) {
                        qrModal.classList.remove('hidden');
                        qrModal.classList.add('flex');
                        document.getElementById('qrOrderId').innerText = '#' + data.orderId;

                        const formattedAmount = parseInt(amountToPay).toLocaleString('vi-VN') + ' đ';
                        document.getElementById('qrAmount').innerText = formattedAmount;
                        document.getElementById('qrContent').innerText = 'Thanh toan don ' + data.orderId;

                        const bankBin = "970436";
                        const bankAcc = "0123456789";
                        const accountName = "AURA HOME";

                        const qrUrl = `https://img.vietqr.io/image/${bankBin}-${bankAcc}-compact2.png?amount=${parseInt(amountToPay)}&addInfo=Thanh toan don ${data.orderId}&accountName=${encodeURIComponent(accountName)}`;

                        document.getElementById('qrImage').src = qrUrl;
                        document.getElementById('qrImage').classList.remove('hidden');
                        document.getElementById('qrLoading').classList.add('hidden');

                        const btnFinish = document.getElementById('btnFinishOrder');
                        if (btnFinish) {
                            btnFinish.style.display = 'flex';
                            btnFinish.onclick = function() {
                                Swal.fire({
                                    icon: 'success', title: 'Thanh toán thành công!',
                                    text: 'Hệ thống đã xác nhận đơn hàng của bạn.',
                                    timer: 2000, showConfirmButton: false
                                }).then(() => {
                                    window.location.href = '/Customers/OrderHistory?phone=' + encodeURIComponent(data.guestPhone);
                                });
                            };
                        }

                        const btnCancel = document.getElementById('btnCancelTransaction');
                        if (btnCancel) {
                            btnCancel.onclick = function() {
                                Swal.fire({
                                    title: 'Hủy giao dịch?', text: 'Đơn hàng của bạn sẽ bị hủy bỏ.',
                                    icon: 'warning', showCancelButton: true,
                                    confirmButtonColor: '#e11d48', cancelButtonColor: '#94a3b8',
                                    confirmButtonText: 'Đồng ý hủy', cancelButtonText: 'Không, tiếp tục'
                                }).then((result) => {
                                    if (result.isConfirmed) {
                                        fetch(`/api/Otp/CancelOrder?orderId=${data.orderId}`, { method: 'POST' })
                                            .then(() => { window.location.href = '/Customers/Cart'; });
                                    }
                                });
                            };
                        }

                        const qrFooterNote = document.getElementById('qrFooterNote');
                        if(qrFooterNote) qrFooterNote.style.display = 'none';

                        const btnSimulate = document.getElementById('btnSimulateWebhook');
                        if (btnSimulate) btnSimulate.style.display = 'none';
                    } else {
                        window.location.href = '/Customers/OrderHistory?phone=' + encodeURIComponent(data.guestPhone);
                    }
                };

                // 2. Logic Báo hỷ & Tự động đăng nhập
                if (data.isNewAccount) {
                    // Lưu vào LocalStorage
                    localStorage.setItem('savedGuestName', data.guestName);
                    localStorage.setItem('savedGuestPhone', data.guestPhone);
                    localStorage.setItem('savedGuestEmail', data.guestEmail);

                    // Đổi Header ngay lập tức
                    const accountBtn = document.getElementById('headerAccountBtn');
                    const accountText = document.getElementById('headerAccountText');
                    if (accountText) accountText.innerText = data.guestName;
                    if (accountBtn) {
                        accountBtn.removeAttribute('onclick');
                        accountBtn.innerHTML = `<i class="fa-solid fa-user-check text-cyan-500"></i> Xin chào, <span class="font-bold text-slate-900">${data.guestName}</span>`;
                    }
                    showQRModal();

                    // Hiện bảng báo hỷ
                   setTimeout(() => {
                        Swal.fire({
                            toast: true,
                            position: 'top-end', // Trượt ra ở góc trên bên phải
                            icon: 'success',
                            title: 'Tạo tài khoản thành công!',
                            html: `<span class="text-sm text-slate-500">SĐT <b>${data.guestPhone}</b> đã được lưu làm tài khoản thành viên.</span>`,
                            showConfirmButton: false,
                            timer: 6000, // Hiện 6 giây rồi tự biến mất
                            timerProgressBar: true,
                            customClass: {
                                popup: 'rounded-xl shadow-2xl border border-slate-100 mt-16 mr-4 bg-white'
                            }
                        });
                    }, 600);
                } 
                else {
                   showQRModal();
                }

            } else {
                // LỖI (Giỏ trống, CSDL...)
                window.isGlobalLocked = false;

                if (data.emptyCart) {
                    Swal.fire({
                        icon: 'info', title: 'Giỏ hàng đã trống!',
                        text: data.message, confirmButtonText: 'Quay lại mua sắm',
                        confirmButtonColor: '#06b6d4', allowOutsideClick: false
                    }).then(() => { window.location.href = '/Customers/Index'; });
                } else {
                    Swal.fire('Lỗi tạo đơn!', data.message, 'error');
                    if (btnSubmit) { btnSubmit.disabled = false; btnSubmit.innerHTML = originalBtnText; }
                    const hiddenOtp = document.getElementById('hiddenOtpCode');
                    if (hiddenOtp) hiddenOtp.value = '';
                }
            }
        })
        .catch(err => {
            // LỖI MẠNG
            window.isGlobalLocked = false;
            Swal.fire('Lỗi', 'Đã xảy ra sự cố kết nối với máy chủ!', 'error');
            if (btnSubmit) { btnSubmit.disabled = false; btnSubmit.innerHTML = originalBtnText; }
        });
    }
  

    function selectVoucher(code) { document.getElementById('voucherCode').value = code; Swal.close(); checkVoucher(); }

    function checkVoucher() {
            const codeInput = document.getElementById('voucherCode');
            const code = codeInput.value.trim().toUpperCase();

            const emailInput = document.querySelector('input[name="Email"]');
            const emailValue = emailInput?.value.trim();

            const subTotalElement = document.getElementById('subTotalDisplay');
            const originalTotal = parseFloat(subTotalElement.getAttribute('data-value'));
            const msgElement = document.getElementById('voucherMessage');

            if (!emailValue) {
                msgElement.textContent = "⚠️ Vui lòng nhập Email trước khi áp dụng mã!";
                msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
                emailInput?.focus();
                return;
            }

            if (!code) {
                msgElement.textContent = "Vui lòng nhập mã giảm giá!";
                msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
                return;
            }

            const btn = document.getElementById('btnApplyVoucher');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.disabled = true;

            fetch(`/Cart/ApplyVoucher?code=${encodeURIComponent(code)}&totalAmount=${originalTotal}&email=${encodeURIComponent(emailValue)}`, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                btn.innerHTML = 'Áp dụng';
                btn.disabled = false;
                msgElement.classList.remove('hidden');

                const depositDisplay = document.getElementById('depositAmountDisplay'); // Bắt lấy cái số to đùng

                if (data.success) {
                    msgElement.textContent = data.message;
                    msgElement.className = "text-sm mt-3 font-bold text-emerald-600 block";
                    codeInput.classList.add('border-emerald-500', 'bg-emerald-50');

                    document.getElementById('discountRow').classList.remove('hidden');
                    document.getElementById('discountDisplay').textContent = `-${data.discountAmount.toLocaleString('vi-VN')} đ`;
                    document.getElementById('finalTotalDisplay').textContent = `${data.newTotal.toLocaleString('vi-VN')} đ`;
                    document.getElementById('hiddenVoucherCode').value = code;

                    // 👉 CẬP NHẬT "SỐ TIỀN CẦN CHUYỂN" MỚI NHẤT
                    if (depositDisplay) {
                        const newDeposit = data.newTotal * 0.3;
                        depositDisplay.setAttribute('data-total', data.newTotal);
                        depositDisplay.setAttribute('data-deposit', newDeposit);
                    }

                } else {
                    msgElement.textContent = data.message;
                    msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
                    codeInput.classList.remove('border-emerald-500', 'bg-emerald-50');
                    document.getElementById('discountRow').classList.add('hidden');
                    document.getElementById('finalTotalDisplay').textContent = `${originalTotal.toLocaleString('vi-VN')} đ`;
                    document.getElementById('hiddenVoucherCode').value = '';

                    // 👉 TRẢ LẠI SỐ TIỀN CŨ NẾU MÃ LỖI
                    if (depositDisplay) {
                        depositDisplay.setAttribute('data-total', originalTotal);
                        depositDisplay.setAttribute('data-deposit', originalTotal * 0.3);
                    }
                }

                // Kích hoạt sự kiện đổi tiền để hiển thị ra màn hình
                const checkedRadio = document.querySelector('input[name="PaymentMode"]:checked');
                if (checkedRadio) checkedRadio.dispatchEvent(new Event('change'));
            })
            .catch(error => {
                msgElement.textContent = "Lỗi kết nối máy chủ!";
                btn.innerHTML = 'Áp dụng'; btn.disabled = false;
            });
        }

</script>