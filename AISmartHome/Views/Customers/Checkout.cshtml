<script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>

<script>
    // Khai báo biến đếm ngược OTP
    let checkoutTimerInterval;

    // Khai báo biến serverVerifiedPhone lấy từ C# (Bắt buộc phải có dòng này ở đầu script)
    const serverVerifiedPhone = '@serverVerifiedPhone';

    // =====================================================================
    // 1. HÀM HIỂN THỊ POPUP KHO VOUCHER (Tính năng Ví Voucher thông minh)
    // =====================================================================
    function showMyVouchers() {
        // Lấy email từ ô input của form
        const emailInput = document.querySelector('input[name="Email"]')?.value.trim();

        if (!emailInput) {
            Swal.fire('Nhắc nhở', 'Vui lòng nhập Email liên hệ ở form bên trái trước để hệ thống tìm ưu đãi của bạn!', 'warning');
            return;
        }

        Swal.fire({
            title: 'Đang tìm ưu đãi...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        fetch(`/Cart/GetMyVouchers?email=${encodeURIComponent(emailInput)}`)
        .then(res => res.json())
        .then(data => {
            if (!data.success) {
                Swal.fire('Rất tiếc', data.message, 'info');
                return;
            }

            let htmlList = '<div class="space-y-3 mt-4 text-left">';
            data.data.forEach(v => {
                const dateObj = new Date(v.ngayHetHan);
                const dateStr = dateObj.toLocaleDateString('vi-VN') + ' ' + dateObj.toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'});

                htmlList += `
                    <div class="p-3 border border-cyan-200 bg-cyan-50 rounded-xl flex justify-between items-center cursor-pointer hover:bg-cyan-100 transition-colors shadow-sm"
                         onclick="selectVoucher('${v.code}')">
                        <div>
                            <div class="font-bold text-slate-800">${v.moTa}</div>
                            <div class="text-[11px] text-slate-500 mt-1"><i class="fa-regular fa-clock"></i> HSD: ${dateStr}</div>
                        </div>
                        <div class="font-black font-mono text-cyan-600 bg-white px-2 py-1 rounded border border-cyan-100">${v.code}</div>
                    </div>
                `;
            });
            htmlList += '</div><p class="text-xs text-slate-400 mt-4 italic text-center">Bấm vào một mã bất kỳ để áp dụng ngay</p>';

            Swal.fire({
                title: '<span class="text-xl font-black text-slate-800">Kho Voucher của bạn</span>',
                html: htmlList,
                showConfirmButton: false,
                showCloseButton: true,
                width: '28em'
            });
        })
        .catch(err => {
            Swal.fire('Lỗi', 'Không thể kết nối máy chủ', 'error');
        });
    }

    // Hàm phụ: Tự động điền mã khi khách bấm chọn trong Popup
    function selectVoucher(code) {
        document.getElementById('voucherCode').value = code;
        Swal.close();
        checkVoucher();
    }

    // =====================================================================
    // 2. KHỞI TẠO VÀ LẮNG NGHE SỰ KIỆN SỐ ĐIỆN THOẠI
    // =====================================================================
    document.addEventListener("DOMContentLoaded", function () {
       const phoneInput = document.getElementById('checkoutPhone');

        // Ưu tiên điền số điện thoại từ Server trước, nếu không có mới lấy ở Browser
        const savedPhone = serverVerifiedPhone || localStorage.getItem('savedGuestPhone');
        if(savedPhone) {
            phoneInput.value = savedPhone;
        }

        // Chạy hàm kiểm tra ngay lúc vừa load trang
        checkPhoneVerification(phoneInput.value.trim());

        // Lắng nghe mỗi khi gõ phím
        phoneInput.addEventListener('input', function() {
            checkPhoneVerification(this.value.trim());
        });
    });

    // HÀM KIỂM TRA "CHỐNG ĐẠN" (BỎ QUA KHOẢNG TRẮNG)
    function checkPhoneVerification(currentPhone) {
        const savedPhoneBrowser = localStorage.getItem('savedGuestPhone') || '';
        const btnOtp = document.getElementById('btnSendOtpCheckout');
        const otpContainer = document.getElementById('otpContainerCheckout');
        const otpInput = document.getElementById('checkoutOtpCode');

        if (!currentPhone) return;

        // Xóa bỏ mọi khoảng trắng, dấu chấm, dấu gạch ngang để so sánh
        let cleanCurrent = currentPhone.replace(/\D/g, '');
        let cleanBrowser = savedPhoneBrowser.replace(/\D/g, '');
        let cleanServer = serverVerifiedPhone.replace(/\D/g, '');

        // Quy chuẩn tất cả đầu 84 về đầu 0 để so sánh
        if (cleanCurrent.startsWith('84')) cleanCurrent = '0' + cleanCurrent.substring(2);
        if (cleanBrowser.startsWith('84')) cleanBrowser = '0' + cleanBrowser.substring(2);
        if (cleanServer.startsWith('84')) cleanServer = '0' + cleanServer.substring(2);

        // KỊCH BẢN 1: Số ĐT hiện tại GIỐNG số đã lưu
        if (cleanCurrent !== '' && (cleanCurrent === cleanBrowser || cleanCurrent === cleanServer)) {
            btnOtp.classList.add('hidden'); // Giấu nút
            otpContainer.classList.add('hidden'); // Giấu ô nhập
            otpInput.value = ''; // Xóa mã cũ
            otpInput.removeAttribute('required'); // Bỏ ràng buộc

            const phoneInput = document.getElementById('checkoutPhone');
            phoneInput.classList.add('border-emerald-400', 'bg-emerald-50/30');
            phoneInput.classList.remove('border-slate-200');
        }
        // KỊCH BẢN 2: Số mới hoàn toàn
        else {
            btnOtp.classList.remove('hidden'); // Hiện nút nhận mã
            btnOtp.innerHTML = 'Nhận mã OTP';
            btnOtp.disabled = false;

            otpInput.setAttribute('required', 'required'); // Bắt buộc nhập mã

            const phoneInput = document.getElementById('checkoutPhone');
            phoneInput.classList.remove('border-emerald-400', 'bg-emerald-50/30');
            phoneInput.classList.add('border-slate-200');
        }
    }

     // =====================================================================
     // 3. XỬ LÝ GỬI OTP VÀ SUBMIT FORM
     // =====================================================================
     function sendOtpCheckout() {
         const phone = document.getElementById('checkoutPhone').value.trim();
         const btn = document.getElementById('btnSendOtpCheckout');

         if (phone.length < 9) {
             Swal.fire('Chú ý', 'Vui lòng nhập số điện thoại hợp lệ.', 'warning');
             return;
         }

         btn.disabled = true;
         btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi...';

         fetch('/api/Otp/send', {
             method: 'POST',
             headers: { 'Content-Type': 'application/json' },
             body: JSON.stringify({ phone: phone })
         })
         .then(res => res.json())
         .then(data => {
             if (data.success) {
                 document.getElementById('otpContainerCheckout').classList.remove('hidden');

                 // (Xóa dòng này khi chạy thật để khách tự nhập)
                 if(data.otp) document.getElementById('checkoutOtpCode').value = data.otp;

                 btn.innerHTML = '<i class="fa-solid fa-check"></i> Đã gửi';

                 let timeLeft = 60;
                 clearInterval(checkoutTimerInterval);
                 checkoutTimerInterval = setInterval(() => {
                     if (timeLeft <= 0) {
                         clearInterval(checkoutTimerInterval);
                         document.getElementById('otpTimerCheckout').innerText = '';
                         btn.innerHTML = 'Gửi lại mã';
                         btn.disabled = false;
                     } else {
                         document.getElementById('otpTimerCheckout').innerText = `${timeLeft}s`;
                         timeLeft--;
                     }
                 }, 1000);

             } else {
                 Swal.fire('Lỗi', data.message, 'error');
                 btn.disabled = false;
                 btn.innerHTML = 'Nhận mã OTP';
             }
         });
     }

     // Ràng buộc trước khi form Checkout được Submit
     document.getElementById('checkoutForm').addEventListener('submit', function(e) {
         const currentPhone = document.getElementById('checkoutPhone').value.replace(/\D/g, '');
         let cleanServer = serverVerifiedPhone.replace(/\D/g, '');

         if (currentPhone.startsWith('84')) currentPhone = '0' + currentPhone.substring(2);
         if (cleanServer.startsWith('84')) cleanServer = '0' + cleanServer.substring(2);

         const otpInput = document.getElementById('checkoutOtpCode').value.trim();

         // Nếu số điện thoại KHÁC số máy chủ lưu, MÀ lại chưa nhập OTP thì chặn lại
         if (currentPhone !== cleanServer && otpInput.length !== 6) {
             e.preventDefault();
             Swal.fire('Bảo mật', 'Bạn đang dùng số điện thoại mới. Vui lòng nhận mã và nhập đủ 6 số OTP trước khi thanh toán!', 'warning');
         }
     });

    // =====================================================================
    // 4. HÀM KIỂM TRA VÀ ÁP DỤNG VOUCHER
    // =====================================================================
    function checkVoucher() {
        const codeInput = document.getElementById('voucherCode');
        const code = codeInput.value.trim().toUpperCase();
        const emailInput = document.querySelector('input[name="Email"]')?.value.trim();

        const subTotalElement = document.getElementById('subTotalDisplay');
        const originalTotal = parseFloat(subTotalElement.getAttribute('data-value'));
        const msgElement = document.getElementById('voucherMessage');

        if (!emailInput) {
            msgElement.textContent = "Vui lòng nhập Email liên hệ ở form bên trái trước!";
            msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
            return;
        }

        if (!code) {
            msgElement.textContent = "Vui lòng nhập mã giảm giá!";
            msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
            return;
        }

        const btn = document.getElementById('btnApplyVoucher');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
        btn.disabled = true;

        fetch(`/Cart/ApplyVoucher?code=${encodeURIComponent(code)}&totalAmount=${originalTotal}&email=${encodeURIComponent(emailInput)}`, { method: 'POST' })
        .then(res => res.json())
        .then(data => {
            btn.innerHTML = 'Áp dụng';
            btn.disabled = false;
            msgElement.classList.remove('hidden');

            const depositAmountDisplay = document.getElementById('depositAmountDisplay');

            if (data.success) {
                msgElement.textContent = data.message;
                msgElement.className = "text-sm mt-3 font-bold text-emerald-600 block";
                codeInput.classList.add('border-emerald-500', 'bg-emerald-50');

                document.getElementById('discountRow').classList.remove('hidden');
                document.getElementById('discountDisplay').textContent = `-${data.discountAmount.toLocaleString('vi-VN')} đ`;
                document.getElementById('finalTotalDisplay').textContent = `${data.newTotal.toLocaleString('vi-VN')} đ`;

                const newTotal = data.newTotal;
                const newDeposit = newTotal * 0.3;

                if(depositAmountDisplay) {
                    depositAmountDisplay.setAttribute('data-total', newTotal);
                    depositAmountDisplay.setAttribute('data-deposit', newDeposit);
                }

                document.getElementById('hiddenVoucherCode').value = code;

            } else {
                msgElement.textContent = data.message;
                msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
                codeInput.classList.remove('border-emerald-500', 'bg-emerald-50');

                document.getElementById('discountRow').classList.add('hidden');
                document.getElementById('finalTotalDisplay').textContent = `${originalTotal.toLocaleString('vi-VN')} đ`;

                if(depositAmountDisplay) {
                    depositAmountDisplay.setAttribute('data-total', originalTotal);
                    depositAmountDisplay.setAttribute('data-deposit', originalTotal * 0.3);
                }

                document.getElementById('hiddenVoucherCode').value = '';
            }

            const checkedRadio = document.querySelector('input[name="PaymentMode"]:checked');
            if (checkedRadio) {
                checkedRadio.dispatchEvent(new Event('change'));
            }
        })
        .catch(error => {
            msgElement.textContent = "Lỗi kết nối đến máy chủ!";
            msgElement.className = "text-sm mt-3 font-medium text-rose-500 block";
            btn.innerHTML = 'Áp dụng';
            btn.disabled = false;
        });
    }
</script>