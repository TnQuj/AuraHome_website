@model AISmartHome.Models.SanPham
@using Microsoft.EntityFrameworkCore
@inject AISmartHome.Data.AISmartHomeDbContext _context

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model?.TenSanPham ?? "Chi tiết thiết bị";
    var activeCatId = Context.Request.Query["category"].ToString();
    bool isCategorySelected = !string.IsNullOrEmpty(activeCatId);

    // Xử lý gộp tất cả ảnh lại an toàn (Ảnh chính + Ảnh phụ)
    var tatCaHinhAnh = new List<string>();
    if (!string.IsNullOrEmpty(Model?.HinhAnh))
    {
        tatCaHinhAnh.Add(Model.HinhAnh);
    }
    if (Model?.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any())
    {
        tatCaHinhAnh.AddRange(Model.HinhAnhSanPhams.Select(x => x.UrlHinhAnh));
    }
}
@{
    // Biến lưu tổng số lượng
    int cartCount = 0;
    int maKhachHangHienTai = 1; // Khách hàng số 1 (như đã thiết lập ở Controller)

    // Truy vấn nhanh vào DB để đếm số lượng
    var cart = _context.GioHangs
        .Include(g => g.ChiTietGioHangs)
        .FirstOrDefault(g => g.MaKhachHang == maKhachHangHienTai);

    if (cart != null && cart.ChiTietGioHangs != null)
    {
        cartCount = cart.ChiTietGioHangs.Sum(c => c.SoLuong ?? 0);
    }
}

<style>
    .ambient-blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
        animation: float 10s infinite alternate ease-in-out;
    }

    @@keyframes float {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(30px, -50px) scale(1.1);
        }
    }
</style>
<!DOCTYPE html>

<html class="light" lang="en">
<body class="bg-[#FAFCFF] font-body text-slate-800 relative overflow-x-hidden">

    <div class="ambient-blob bg-cyan-300/40 w-[30rem] h-[30rem] rounded-full top-[-10%] left-[-10%]"></div>
    <div class="ambient-blob bg-indigo-300/30 w-[40rem] h-[40rem] rounded-full top-[20%] right-[-15%]" style="animation-delay: -5s;"></div>
    <main class="w-full pb-20 pt-8">
        <div class="container mx-auto px-4 md:px-8">

            <nav class="inline-flex items-center gap-1 sm:gap-1.5 text-[12px] sm:text-[13px] font-medium text-slate-500 dark:text-slate-400 mb-8 bg-white/70 dark:bg-slate-800/60 backdrop-blur-md border border-slate-200/80 dark:border-slate-700 px-3 sm:px-5 py-2 sm:py-2.5 rounded-full shadow-sm max-w-full transition-all hover:shadow-md">

                <a class="flex items-center gap-1.5 hover:text-cyan-600 dark:hover:text-cyan-400 transition-all duration-300 hover:-translate-y-[1px] shrink-0" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-house-chimney text-cyan-500"></i>
                    <span class="hidden sm:inline">Trang chủ</span>
                </a>

                <i class="fa-solid fa-chevron-right text-[9px] text-slate-300 dark:text-slate-600 mx-0.5 sm:mx-1 shrink-0"></i>

                <a class="hover:text-cyan-600 dark:hover:text-cyan-400 transition-all duration-300 hover:-translate-y-[1px] shrink-0 whitespace-nowrap" asp-controller="Customers" asp-action="Index">
                    Thiết bị thông minh
                </a>

                <i class="fa-solid fa-chevron-right text-[9px] text-slate-300 dark:text-slate-600 mx-0.5 sm:mx-1 shrink-0"></i>

                <span class="text-cyan-700 dark:text-cyan-300 font-bold px-2 sm:px-3 py-1 bg-cyan-50 dark:bg-cyan-900/30 rounded-full border border-cyan-100 dark:border-cyan-800 shadow-inner truncate max-w-[100px] sm:max-w-[200px] md:max-w-xs" title="@Model?.TenSanPham">
                    @Model?.TenSanPham
                </span>

            </nav>

            <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-800 p-6 md:p-12 mb-12">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

                    <div class="flex flex-col gap-4">
                        <div class="relative w-full aspect-square bg-slate-50 dark:bg-slate-800/50 rounded-2xl flex items-center justify-center p-8 border border-slate-100 dark:border-slate-700">
                            <img id="main-product-img"
                                 src="@(tatCaHinhAnh.Any() ? $"/img/{tatCaHinhAnh.First()}" : "https://via.placeholder.com/500?text=No+Image")"
                                 alt="@Model?.TenSanPham"
                                 class="max-h-full max-w-full object-contain drop-shadow-xl transition-all duration-300" />
                        </div>

                        @if (tatCaHinhAnh.Count > 1)
                        {
                            <div class="flex gap-4 overflow-x-auto pb-2 hide-scrollbar w-full mt-2 justify-start sm:justify-center">
                                @for (int i = 0; i < tatCaHinhAnh.Count; i++)
                                {
                                    string borderClass = (i == 0) ? "border-brand-cyan shadow-md" : "border-transparent opacity-60 hover:opacity-100";
                                    <div class="w-20 h-20 shrink-0 rounded-xl border-2 @borderClass overflow-hidden bg-white dark:bg-slate-800 p-2 cursor-pointer transition-all hover:border-slate-300 dark:hover:border-slate-600 detail-thumb"
                                         onclick="changeMainImage('/img/@tatCaHinhAnh[i]', this)">
                                        <img src="/img/@tatCaHinhAnh[i]" class="w-full h-full object-contain" onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="flex flex-col py-2">
                        <div class="flex items-center gap-2 mb-3">
                            <span class="bg-brand-cyan/10 text-brand-cyan px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">AuraHome AI</span>
                            <div class="flex text-amber-400 text-[12px]">
                                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                            </div>
                            <span class="text-sm text-slate-400 ml-1">(128 đánh giá)</span>
                        </div>

                        <h1 class="text-3xl md:text-4xl font-extrabold text-brand-navy dark:text-white mb-4 leading-tight">
                            @Model?.TenSanPham
                        </h1>

                        <div class="flex items-end gap-4 mb-6 pb-6 border-b border-slate-100 dark:border-slate-800">
                            <span class="text-4xl font-black text-rose-600 dark:text-rose-400">@Model?.GiaBan.ToString("N0") ₫</span>
                            <span class="text-lg text-slate-400 line-through font-medium mb-1">@((Model?.GiaBan * 1.2m)?.ToString("N0")) ₫</span>
                        </div>

                        <div class="text-slate-600 dark:text-slate-300 text-[15px] leading-relaxed mb-8">
                            <p>@Model?.MoTa</p>
                        </div>

                        <form onsubmit="addToCartAjax(event)">
                            <input type="hidden" name="id" value="@Model?.MaSanPham" />

                            <div class="mb-8">
                                <label for="quantity-input" class="block text-sm font-bold text-slate-900 dark:text-white mb-3">Số lượng</label>

                                <div class="flex flex-col sm:flex-row gap-4 mt-auto">
                                    <div class="flex items-center justify-between w-full md:w-auto gap-8 mt-2 md:mt-0 pt-4 md:pt-0 border-t md:border-none border-slate-100">

                                        <div class="flex items-center border border-slate-200 rounded-full overflow-hidden h-10 w-[110px] bg-white shadow-inner">
                                            <button type="button" onclick="decreaseDetailQty()" class="w-9 h-full flex justify-center items-center text-slate-500 hover:bg-slate-100 hover:text-brand-cyan transition-colors">
                                                <i class="fa-solid fa-minus text-xs"></i>
                                            </button>

                                            <input id="detail-qty" name="quantity" type="text" value="1" readonly data-price="@Model.GiaBan" class="w-full h-full text-center border-none p-0 text-sm font-bold text-brand-navy focus:ring-0 bg-transparent pointer-events-none" />

                                            <button type="button" onclick="increaseDetailQty()" class="w-9 h-full flex justify-center items-center text-slate-500 hover:bg-slate-100 hover:text-brand-cyan transition-colors">
                                                <i class="fa-solid fa-plus text-xs"></i>
                                            </button>
                                        </div>

                                        <div class="text-right flex flex-col md:min-w-[100px]">
                                            <span class="text-xs text-slate-400 font-medium md:hidden mb-1">Tạm tính</span>
                                            <span id="detail-subtotal" class="font-black text-rose-600 text-lg">
                                                @Model.GiaBan.ToString("N0") ₫
                                            </span>
                                        </div>
                                    </div>

                                    <button type="submit" class="flex-1 bg-slate-900 hover:bg-cyan-500 text-white h-[56px] rounded-2xl font-bold text-[15px] flex items-center justify-center gap-2 transition-all duration-300 shadow-lg shadow-slate-900/20 hover:shadow-cyan-500/40">
                                        <i class="fa-solid fa-cart-plus"></i>
                                        Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                            <button type="button" onclick="buyNowWithQuantity(@Model.MaSanPham)" class="w-full bg-rose-600 hover:bg-rose-700 text-white h-[56px] rounded-2xl font-bold text-[15px] flex items-center justify-center gap-2 transition-colors shadow-lg shadow-rose-600/20 uppercase tracking-wider mt-4">
                                <i class="fa-solid fa-cart-arrow-down"></i> Mua ngay
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="mb-16">

                <div class="bg-gradient-to-br from-white to-slate-50 dark:from-slate-900 dark:to-slate-800/80 rounded-[2.5rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100/80 dark:border-slate-800 p-8 md:p-12 relative overflow-hidden">

                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-brand-cyan/[0.03] dark:bg-brand-cyan/[0.02] rounded-full blur-3xl pointer-events-none"></div>
                    <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-blue-500/[0.03] dark:bg-blue-500/[0.02] rounded-full blur-3xl pointer-events-none"></div>

                    <div class="flex items-center gap-5 mb-10 relative z-10">
                        <div class="w-14 h-14 rounded-2xl bg-brand-cyan/10 dark:bg-brand-cyan/20 flex items-center justify-center text-brand-cyan shrink-0">
                            <i class="fa-solid fa-microchip text-2xl"></i>
                        </div>
                        <div>
                            <h2 class="text-2xl md:text-3xl font-black text-slate-800 dark:text-white tracking-tight">Thông số kỹ thuật</h2>
                            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1.5 font-medium">Chi tiết cấu hình và đặc điểm nổi bật của sản phẩm</p>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200/60 dark:border-slate-700/60 bg-white dark:bg-slate-900/50 relative z-10 shadow-sm overflow-hidden">
                        <table class="w-full text-left border-collapse">
                            <tbody class="text-sm font-medium">

                                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/50 transition-colors border-b border-slate-100 dark:border-slate-800/60">
                                    <td class="py-5 px-6 text-slate-500 dark:text-slate-400 w-1/3 sm:w-1/4 align-top border-r border-slate-50 dark:border-slate-800/30">
                                        <div class="flex items-center gap-3">
                                            <div class="w-6 h-6 rounded-md bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
                                                <i class="fa-solid fa-box text-[10px]"></i>
                                            </div>
                                            Tên sản phẩm
                                        </div>
                                    </td>
                                    <td class="py-5 px-6 text-slate-800 dark:text-slate-200 font-bold text-[15px]">@Model?.TenSanPham</td>
                                </tr>

                                <tr class="bg-slate-50/30 dark:bg-slate-800/20 hover:bg-slate-50/80 dark:hover:bg-slate-800/60 transition-colors border-b border-slate-100 dark:border-slate-800/60">
                                    <td class="py-5 px-6 text-slate-500 dark:text-slate-400 align-top border-r border-slate-50 dark:border-slate-800/30">
                                        <div class="flex items-center gap-3">
                                            <div class="w-6 h-6 rounded-md bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
                                                <i class="fa-solid fa-tag text-[10px]"></i>
                                            </div>
                                            Thương hiệu
                                        </div>
                                    </td>
                                    <td class="py-5 px-6 font-bold">
                                        <span class="text-brand-navy dark:text-brand-cyan tracking-wide">AuraHome Smart</span>
                                    </td>
                                </tr>

                                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/50 transition-colors border-b border-slate-100 dark:border-slate-800/60">
                                    <td class="py-5 px-6 text-slate-500 dark:text-slate-400 align-top border-r border-slate-50 dark:border-slate-800/30">
                                        <div class="flex items-center gap-3">
                                            <div class="w-6 h-6 rounded-md bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
                                                <i class="fa-solid fa-layer-group text-[10px]"></i>
                                            </div>
                                            Tình trạng
                                        </div>
                                    </td>
                                    <td class="py-5 px-6 font-bold">
                                        @if (Model?.SoLuong > 0)
                                        {
                                            <div class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400">
                                                <i class="fa-solid fa-circle-check"></i>
                                                <span>Còn hàng (@Model?.SoLuong)</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex items-center gap-2 text-rose-500 dark:text-rose-400">
                                                <i class="fa-solid fa-circle-xmark"></i>
                                                <span>Hết hàng tạm thời</span>
                                            </div>
                                        }
                                    </td>
                                </tr>

                                <tr class="bg-slate-50/30 dark:bg-slate-800/20 hover:bg-slate-50/80 dark:hover:bg-slate-800/60 transition-colors border-b border-slate-100 dark:border-slate-800/60">
                                    <td class="py-5 px-6 text-slate-500 dark:text-slate-400 align-top border-r border-slate-50 dark:border-slate-800/30">
                                        <div class="flex items-center gap-3">
                                            <div class="w-6 h-6 rounded-md bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
                                                <i class="fa-solid fa-shield-halved text-[10px]"></i>
                                            </div>
                                            Bảo hành
                                        </div>
                                    </td>
                                    <td class="py-5 px-6 text-slate-800 dark:text-slate-200 font-bold flex items-center flex-wrap gap-2.5">
                                        24 Tháng
                                        <span class="text-[11px] font-semibold text-brand-cyan bg-brand-cyan/10 px-2.5 py-1 rounded-md">
                                            1 đổi 1 trong 30 ngày
                                        </span>
                                    </td>
                                </tr>

                                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td class="py-5 px-6 text-slate-500 dark:text-slate-400 align-top border-r border-slate-50 dark:border-slate-800/30">
                                        <div class="flex items-center gap-3">
                                            <div class="w-6 h-6 rounded-md bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
                                                <i class="fa-solid fa-file-lines text-[10px]"></i>
                                            </div>
                                            Chi tiết mô tả
                                        </div>
                                    </td>
                                    <td class="py-6 px-6 text-slate-600 dark:text-slate-300 leading-relaxed font-normal">
                                        <div class="prose prose-sm dark:prose-invert max-w-none prose-p:mb-2 prose-p:last:mb-0">
                                            @Html.Raw(Model?.MoTa?.Replace("\n", "<br/>"))
                                        </div>
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div>
                <div class="flex items-center justify-between mb-8 border-b border-slate-100 pb-4">
                    <h2 class="text-2xl font-extrabold text-brand-navy dark:text-white flex items-center gap-3">
                        <i class="fa-solid fa-layer-group text-brand-cyan"></i> Sản phẩm tương tự
                    </h2>
                    <a asp-controller="Customers" asp-action="Index" class="text-sm font-bold text-brand-cyan hover:text-cyan-700 transition-colors">Xem tất cả <i class="fa-solid fa-arrow-right ml-1"></i></a>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    @if (ViewBag.SanPhamsTuongTu != null)
                    {
                        foreach (var sp in ViewBag.SanPhamsTuongTu)
                        {
                            <div class="group relative bg-white rounded-2xl border border-slate-100 hover:border-cyan-200 hover:shadow-xl transition-all duration-300 p-4 flex flex-col h-full">
                                <div class="relative aspect-square bg-slate-50 overflow-hidden p-4 flex items-center justify-center rounded-xl mb-4">
                                    <img class="block max-w-full max-h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                         src="@(string.IsNullOrEmpty(sp.HinhAnh) ? "https://via.placeholder.com/300" : $"/img/{sp.HinhAnh}")" alt="@sp.TenSanPham" />
                                </div>
                                <div class="flex flex-col flex-1">
                                    <a href="/Customers/Details?id=@sp.MaSanPham" class="font-bold text-[15px] text-slate-900 hover:text-cyan-600 transition-colors line-clamp-2 mb-2">
                                        @sp.TenSanPham
                                    </a>
                                    <div class="mt-auto">
                                        <span class="text-lg font-black text-rose-600">@sp.GiaBan.ToString("N0") ₫</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-span-full py-10 text-center text-slate-500 bg-slate-50 rounded-2xl border border-dashed border-slate-200">
                            Vui lòng cập nhật Controller để truyền <strong>ViewBag.SanPhamsTuongTu</strong> nhé!
                        </div>
                    }
                </div>
            </div>

        </div>
    </main>
</body>

</html>

<script>
    function buyNowWithQuantity(productId) {
        // 1. Lấy số lượng khách hàng vừa bấm chọn
        var qty = document.getElementById('detail-qty').value;

        // 2. Gom cả ID sản phẩm và Số lượng vào đường link để gửi lên Controller
        window.location.href = `/Customers/BuyNow?id=${productId}&quantity=${qty}`;
    }
</script>