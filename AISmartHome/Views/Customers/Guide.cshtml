@model IEnumerable<AISmartHome.Models.HuongDanSuDung>
@{
    ViewData["Title"] = "Hướng dẫn sử dụng - AuraHome";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        /* Hiệu ứng đốm sáng nền lung linh (Ambient Blurs) */
        .ambient-blob {
            position: absolute;
            filter: blur(80px);
            z-index: 0;
            opacity: 0.6;
            animation: float 10s infinite alternate ease-in-out;
        }
        @@keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(30px, -50px) scale(1.1); }
        }

        /* Hiệu ứng thẻ kính mờ (Glass Card) */
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="bg-[#FAFCFF] font-body text-slate-800 relative overflow-x-hidden">

    <div class="ambient-blob bg-cyan-300/40 w-[30rem] h-[30rem] rounded-full top-[-10%] left-[-10%]"></div>
    <div class="ambient-blob bg-indigo-300/30 w-[40rem] h-[40rem] rounded-full top-[20%] right-[-15%]" style="animation-delay: -5s;"></div>

    <div class="pt-24 pb-24 min-h-screen max-w-screen-xl mx-auto px-6 relative z-10">

        <header class="text-center max-w-3xl mx-auto mb-20 space-y-8">
            <h1 class="text-4xl md:text-6xl font-extrabold font-headline tracking-tight text-slate-900 leading-tight">
                Làm chủ không gian <br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-500 to-indigo-600">thông minh của bạn</span>
            </h1>
            <p class="text-lg text-slate-500 max-w-xl mx-auto font-medium">
                Khám phá các video hướng dẫn trực quan để tận dụng tối đa sức mạnh của hệ sinh thái AuraHome.
            </p>

            <div class="relative max-w-2xl mx-auto group mt-8">
                <div class="absolute inset-0 bg-gradient-to-r from-cyan-400 to-indigo-400 rounded-full blur opacity-25 group-focus-within:opacity-50 transition-opacity duration-500"></div>
                <div class="relative bg-white/90 backdrop-blur-md rounded-full p-2 flex items-center shadow-xl border border-white/50">
                    <span class="material-symbols-outlined text-slate-400 ml-4">search</span>
                    <input type="text" placeholder="Tìm kiếm cách cài đặt khóa cửa, camera..."
                           class="w-full bg-transparent border-none focus:ring-0 text-slate-700 px-4 py-3 outline-none" />
                    <button class="bg-slate-900 text-white px-8 py-3 rounded-full font-bold hover:bg-slate-800 transition-colors shadow-md">
                        Đi
                    </button>
                </div>
            </div>
        </header>

        <section>
            <div class="flex items-center justify-between mb-10">
                <h2 class="text-2xl font-bold font-headline text-slate-900">Mới cập nhật</h2>
                <div class="flex gap-2">
                    <button class="w-10 h-10 rounded-full glass-card flex items-center justify-center hover:bg-white transition-colors text-slate-600"><span class="material-symbols-outlined">chevron_left</span></button>
                    <button class="w-10 h-10 rounded-full glass-card flex items-center justify-center hover:bg-white transition-colors text-slate-600"><span class="material-symbols-outlined">chevron_right</span></button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="group relative rounded-[2rem] p-4 glass-card hover:-translate-y-2 transition-transform duration-500 cursor-pointer">

                            <a asp-action="GuideDetail" asp-route-id="@item.MaHuongDan" class="block h-full flex flex-col">

                                <div class="relative aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 shadow-inner">
                                    @{
                                        string imgUrl = "/images/default-thumbnail.jpg";
                                        if (item.MaSanPhamNavigation != null && !string.IsNullOrEmpty(item.MaSanPhamNavigation.HinhAnh))
                                        {
                                            imgUrl = $"/img/{item.MaSanPhamNavigation.HinhAnh}";
                                        }
                                    }
                                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                                         src="@imgUrl" alt="@item.TieuDe" />

                                    <div class="absolute inset-0 bg-slate-900/10 group-hover:bg-slate-900/30 transition-colors duration-500 flex items-center justify-center">
                                        <div class="w-16 h-16 bg-white/30 backdrop-blur-md rounded-full flex items-center justify-center text-white scale-90 group-hover:scale-110 transition-transform duration-500 shadow-[0_0_30px_rgba(255,255,255,0.3)]">
                                            <span class="material-symbols-outlined text-4xl ml-1">play_arrow</span>
                                        </div>
                                    </div>

                                    <div class="absolute top-4 left-4 bg-white/80 backdrop-blur text-slate-800 text-[11px] font-extrabold px-3 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
                                        @(item.MaSanPhamNavigation?.TenSanPham ?? "Hướng dẫn chung")
                                    </div>
                                </div>

                                <div class="px-2 flex-1 flex flex-col justify-start">
                                    <h3 class="text-xl font-bold text-slate-900 mb-2 line-clamp-2 leading-snug group-hover:text-cyan-600 transition-colors">
                                        @item.TieuDe
                                    </h3>
                                    <p class="text-slate-500 text-sm line-clamp-2 mb-4">
                                        @Html.Raw(item.NoiDung)
                                    </p>

                                    <div class="mt-auto flex items-center gap-2 text-sm font-bold text-cyan-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                        Xem chi tiết <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-span-full py-20 flex flex-col items-center justify-center glass-card rounded-[2rem]">
                        <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">video_library</span>
                        <h3 class="text-xl font-bold text-slate-700 mb-2">Chưa có video nào</h3>
                        <p class="text-slate-500">Hệ thống đang cập nhật các video hướng dẫn mới nhất.</p>
                    </div>
                }
            </div>
        </section>
    </div>
</body>
</html>