@model AISmartHome.Models.HuongDanSuDung
@{
    ViewData["Title"] = Model.TieuDe + " - AuraHome";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Đoạn code C# nhỏ này giúp tự động chuyển link Youtube thường thành link Embed (để nhúng vào Iframe)
    string embedUrl = "";
    if (!string.IsNullOrEmpty(Model.VideoUrl))
    {
        if (Model.VideoUrl.Contains("watch?v="))
        {
            embedUrl = Model.VideoUrl.Replace("watch?v=", "embed/");
            // Cắt bỏ các tham số thừa phía sau (nếu có)
            int ampersandIndex = embedUrl.IndexOf('&');
            if (ampersandIndex > 0)
            {
                embedUrl = embedUrl.Substring(0, ampersandIndex);
            }
        }
        else if (Model.VideoUrl.Contains("youtu.be/"))
        {
            embedUrl = Model.VideoUrl.Replace("youtu.be/", "www.youtube.com/embed/");
        }
        else
        {
            embedUrl = Model.VideoUrl; // Trường hợp đã là link embed sẵn
        }
    }
}
<style>
    .ambient-blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
        animation: float 10s infinite alternate ease-in-out;
    }

    @@keyframes float {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(30px, -50px) scale(1.1);
        }
    }
</style>

<div class="bg-[#FAFCFF] dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display min-h-screen relative overflow-hidden">

    <div class="ambient-blob bg-cyan-300/40 w-[30rem] h-[30rem] rounded-full top-[-5%] left-[-10%] pointer-events-none dark:opacity-10"></div>
    <div class="ambient-blob bg-indigo-300/30 w-[40rem] h-[40rem] rounded-full top-[20%] right-[-15%] pointer-events-none dark:opacity-10" style="animation-delay: -5s;"></div>
    
    <div class="max-w-5xl mx-auto px-6">

        <div class="mb-8">
            <a asp-action="Guide" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-secondary font-bold transition-colors">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                Quay lại thư viện Video
            </a>
        </div>

        <header class="mb-10 text-center md:text-left">
            <span class="inline-block px-4 py-1.5 bg-secondary/10 text-secondary text-xs font-black rounded-full mb-4 uppercase tracking-widest border border-secondary/20">
                <span class="material-symbols-outlined text-[14px] align-middle mr-1">box</span>
                @(Model.MaSanPhamNavigation?.TenSanPham ?? "Hướng dẫn chung")
            </span>

            <h1 class="text-3xl md:text-5xl font-extrabold font-headline text-primary leading-tight">
                @Model.TieuDe
            </h1>
        </header>

        @if (!string.IsNullOrEmpty(embedUrl))
        {
            <div class="relative w-full aspect-video rounded-[2rem] overflow-hidden shadow-2xl shadow-slate-200/50 border border-outline-variant/20 mb-12 bg-black">
                <iframe class="absolute inset-0 w-full h-full"
                        src="@embedUrl"
                        title="@Model.TieuDe"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen>
                </iframe>
            </div>
        }
        else
        {
            <div class="w-full aspect-video rounded-[2rem] bg-surface-container-low flex flex-col items-center justify-center border border-dashed border-outline-variant/30 mb-12">
                <span class="material-symbols-outlined text-5xl text-outline-variant/50 mb-4">videocam_off</span>
                <p class="text-on-surface-variant font-medium">Video hướng dẫn đang được cập nhật</p>
            </div>
        }

        <article class="bg-white rounded-[2.5rem] p-8 md:p-14 shadow-sm border border-outline-variant/20 max-w-4xl mx-auto">
            <div class="flex items-center gap-3 mb-8 border-b border-outline-variant/10 pb-6">
                <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary">
                    <span class="material-symbols-outlined text-2xl">description</span>
                </div>
                <div>
                    <h3 class="text-xl font-bold font-headline text-primary">Các bước thực hiện</h3>
                    <p class="text-sm text-on-surface-variant">Làm theo hướng dẫn bên dưới hoặc xem video ở trên.</p>
                </div>
            </div>

            <div class="prose prose-slate prose-lg max-w-none text-on-surface-variant leading-relaxed">
                @if (!string.IsNullOrEmpty(Model.NoiDung))
                {
                    @Html.Raw(Model.NoiDung)
                }
                else
                {
                    <p class="italic text-center text-outline">Chưa có nội dung mô tả chi tiết.</p>
                }
            </div>
        </article>

    </div>
</div>