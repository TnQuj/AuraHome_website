@model AISmartHome.Models.HomeViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thiết bị Smart Home";
    var activeCatId = Context.Request.Query["category"].ToString();
    var activeCategory = Model.DanhMucs?.FirstOrDefault(d => d.MaDanhMuc.ToString() == activeCatId);
    bool isCategorySelected = !string.IsNullOrEmpty(activeCatId);
}
@using Microsoft.EntityFrameworkCore
@inject AISmartHome.Data.AISmartHomeDbContext _context

@{
    // Biến lưu tổng số lượng
    int cartCount = 0;
    int maKhachHangHienTai = 1; // Khách hàng số 1 (như đã thiết lập ở Controller)

    // Truy vấn nhanh vào DB để đếm số lượng
    var cart = _context.GioHangs
        .Include(g => g.ChiTietGioHangs)
        .FirstOrDefault(g => g.MaKhachHang == maKhachHangHienTai);

    if (cart != null && cart.ChiTietGioHangs != null)
    {
        cartCount = cart.ChiTietGioHangs.Sum(c => c.SoLuong ?? 0);
    }
}
<!DOCTYPE html>
<html class="light" lang="en">
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display">
    <main class="pt-4 relative px-4 md:px-8 lg:px-16 max-w-[1600px] mx-auto pb-20">
        <!--Dấu tích điều hướng-->
        <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-6">
            <a class="hover:text-cyan-500 transition-colors" asp-controller="Home" asp-action="Index">Trang chủ</a>

            <i class="fa-solid fa-chevron-right text-[10px]"></i>

            @if (activeCategory != null)
            {
                <a class="hover:text-cyan-500 transition-colors" asp-controller="Customers" asp-action="Index">Thiết bị thông minh</a>

                <i class="fa-solid fa-chevron-right text-[10px]"></i>

                <span class="text-cyan-600 dark:text-cyan-400 font-semibold">@activeCategory.TenDanhMuc</span>
            }
            else
            {
                <span class="text-cyan-600 dark:text-cyan-400 font-semibold">Thiết bị thông minh</span>
            }
        </nav>

        <div class="flex flex-col lg:flex-row gap-8 items-start">

            <aside class="w-full lg:w-[340px] xl:w-[400px] flex-shrink-0 space-y-8 lg:sticky lg:top-24 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-slate-200 dark:scrollbar-thumb-slate-700">
                <div class="relative bg-white dark:bg-slate-800/50 p-5 rounded-3xl border border-slate-100 dark:border-slate-700/50 shadow-sm">
                    <div class="absolute -top-10 -left-10 w-40 h-40 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none z-0"></div>

                    <h3 class="text-xs font-black uppercase tracking-[0.2em] flex items-center gap-3 mb-6 relative z-10">
                        <span class="w-2 h-2 rounded-full bg-cyan-500 shadow-[0_0_10px_rgba(6,182,212,0.8)] animate-pulse"></span>
                        <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-500 to-purple-600">Danh Mục</span>
                    </h3>

                    @{
                        var currentCategoryId = Context.Request.Query["category"].ToString();
                        bool isAllActive = string.IsNullOrEmpty(currentCategoryId);

                        var styles = new[] {
                    new { ActiveBg = "bg-gradient-to-r from-indigo-500/15 to-transparent border border-indigo-500/30", ActiveLine = "bg-indigo-500 shadow-[0_0_15px_rgba(99,102,241,0.8)]", ActiveText = "text-indigo-600 dark:text-indigo-400", ActiveIcon = "bg-indigo-500 text-white shadow-[0_0_20px_rgba(99,102,241,0.6)] scale-110", HoverIcon = "group-hover/link:bg-indigo-500/20 group-hover/link:text-indigo-500", Icon = "fa-lightbulb", Badge = "bg-indigo-100 text-indigo-600" },
                    new { ActiveBg = "bg-gradient-to-r from-emerald-500/15 to-transparent border border-emerald-500/30", ActiveLine = "bg-emerald-500 shadow-[0_0_15px_rgba(16,185,129,0.8)]", ActiveText = "text-emerald-600 dark:text-emerald-400", ActiveIcon = "bg-emerald-500 text-white shadow-[0_0_20px_rgba(16,185,129,0.6)] scale-110", HoverIcon = "group-hover/link:bg-emerald-500/20 group-hover/link:text-emerald-500", Icon = "fa-shield-halved", Badge = "bg-emerald-100 text-emerald-600" },
                    new { ActiveBg = "bg-gradient-to-r from-orange-500/15 to-transparent border border-orange-500/30", ActiveLine = "bg-orange-500 shadow-[0_0_15px_rgba(249,115,22,0.8)]", ActiveText = "text-orange-600 dark:text-orange-400", ActiveIcon = "bg-orange-500 text-white shadow-[0_0_20px_rgba(249,115,22,0.6)] scale-110", HoverIcon = "group-hover/link:bg-orange-500/20 group-hover/link:text-orange-500", Icon = "fa-temperature-half", Badge = "bg-orange-100 text-orange-600" },
                    new { ActiveBg = "bg-gradient-to-r from-cyan-500/15 to-transparent border border-cyan-500/30", ActiveLine = "bg-cyan-500 shadow-[0_0_15px_rgba(6,182,212,0.8)]", ActiveText = "text-cyan-600 dark:text-cyan-400", ActiveIcon = "bg-cyan-500 text-white shadow-[0_0_20px_rgba(6,182,212,0.6)] scale-110", HoverIcon = "group-hover/link:bg-cyan-500/20 group-hover/link:text-cyan-500", Icon = "fa-microchip", Badge = "bg-cyan-100 text-cyan-600" },
                    new { ActiveBg = "bg-gradient-to-r from-purple-500/15 to-transparent border border-purple-500/30", ActiveLine = "bg-purple-500 shadow-[0_0_15px_rgba(168,85,247,0.8)]", ActiveText = "text-purple-600 dark:text-purple-400", ActiveIcon = "bg-purple-500 text-white shadow-[0_0_20px_rgba(168,85,247,0.6)] scale-110", HoverIcon = "group-hover/link:bg-purple-500/20 group-hover/link:text-purple-500", Icon = "fa-battery-full", Badge = "bg-purple-100 text-purple-600" }
                    };
                    }

                    <div class="space-y-3 relative z-10">
                        @if (Model.DanhMucs != null && Model.DanhMucs.Any())
                        {
                            <a href="/Customers/Index" class="relative flex items-center px-3 py-3 rounded-2xl transition-all duration-300 group/link bg-white dark:bg-slate-800/80 border shadow-sm hover:shadow-md @(isAllActive ? "bg-gradient-to-r from-cyan-500/15 to-transparent border-cyan-400/50" : "border-slate-100 dark:border-slate-700/50 hover:border-cyan-300")">

                                @if (isAllActive)
                                {
                                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-cyan-500 shadow-[0_0_15px_rgba(6,182,212,0.8)] rounded-l-2xl"></div>
                                }

                                <div class="flex items-center gap-3 flex-1">
                                    <span class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-xl transition-all duration-300 @(isAllActive ? "bg-cyan-500 text-white shadow-[0_0_20px_rgba(6,182,212,0.6)] scale-105" : "bg-slate-100 dark:bg-slate-800 text-slate-500 group-hover/link:bg-cyan-500/20 group-hover/link:text-cyan-500 group-hover/link:shadow-[0_0_20px_rgba(6,182,212,0.4)]")">
                                        <i class="fa-solid fa-layer-group text-[15px]"></i>
                                    </span>

                                    <span class="font-bold text-[14px] whitespace-nowrap @(isAllActive ? "text-cyan-600 dark:text-cyan-400" : "text-slate-600 dark:text-slate-400 group-hover/link:text-cyan-600 dark:group-hover/link:text-white") transition-colors duration-300">
                                        Tất cả thiết bị
                                    </span>
                                </div>

                                <span class="ml-auto flex-shrink-0 px-2.5 py-1 min-w-[32px] text-center rounded-full text-[12px] font-bold transition-colors @(isAllActive ? "bg-cyan-500 text-white" : "bg-slate-100 dark:bg-slate-700 text-slate-500 group-hover/link:bg-cyan-100 group-hover/link:text-cyan-600")">
                                    24
                                </span>
                            </a>

                            int index = 0;
                            foreach (var danhmuc in Model.DanhMucs)
                            {
                                bool isActive = currentCategoryId == danhmuc.MaDanhMuc.ToString();
                                var style = styles[index % styles.Length];
                                index++;

                                <a href="/Customers/Index?category=@danhmuc.MaDanhMuc" class="relative flex items-center px-3 py-3 rounded-2xl transition-all duration-300 group/link bg-white dark:bg-slate-800/80 border shadow-sm hover:shadow-md @(isActive ? style.ActiveBg : "border-slate-100 dark:border-slate-700/50 hover:border-slate-300 dark:hover:border-slate-600")">

                                    @if (isActive)
                                    {
                                        <div class="absolute left-0 top-0 bottom-0 w-1 @style.ActiveLine rounded-l-2xl"></div>
                                    }

                                    <div class="flex items-center gap-3 flex-1">
                                        <span class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-xl transition-all duration-300 @(isActive ? style.ActiveIcon : $"bg-slate-100 dark:bg-slate-800 text-slate-500 {style.HoverIcon}")">
                                            <i class="fa-solid @style.Icon text-[15px]"></i>
                                        </span>

                                        <span class="font-bold text-[14px] whitespace-nowrap @(isActive ? style.ActiveText : "text-slate-600 dark:text-slate-400 group-hover/link:text-slate-900 dark:group-hover/link:text-white") transition-colors duration-300">
                                            @danhmuc.TenDanhMuc
                                        </span>
                                    </div>

                                    <span class="ml-auto flex-shrink-0 px-2.5 py-1 min-w-[32px] text-center rounded-full text-[12px] font-bold transition-colors @(isActive ? "bg-cyan-500 text-white" : "bg-slate-100 dark:bg-slate-700 text-slate-500 group-hover/link:bg-cyan-50 group-hover/link:text-cyan-600")">
                                        5
                                    </span>
                                </a>
                            }
                        }
                    </div>
                </div>


                <div class="relative overflow-hidden bg-gradient-to-br from-cyan-500 to-blue-600 p-6 rounded-3xl shadow-[0_15px_30px_-10px_rgba(6,182,212,0.4)] text-white">
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/10 rounded-full blur-2xl pointer-events-none"></div>
                    <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-white/10 rounded-full blur-xl pointer-events-none"></div>

                    <div class="relative z-10">
                        <h3 class="text-xs font-black uppercase tracking-[0.2em] text-cyan-100 mb-2">Cộng đồng AuraHome</h3>
                        <p class="text-[13px] text-cyan-50 mb-5 leading-relaxed">Theo dõi chúng tôi để nhận mẹo setup nhà thông minh mỗi ngày.</p>

                        <div class="grid grid-cols-2 gap-3">
                            <a href="#" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 rounded-xl py-3 transition-all duration-300 group">
                                <i class="fa-brands fa-facebook-f text-white group-hover:scale-110 transition-transform"></i>
                                <span class="text-[12px] font-bold">Facebook</span>
                            </a>
                            <a href="#" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 rounded-xl py-3 transition-all duration-300 group">
                                <i class="fa-brands fa-youtube text-white group-hover:scale-110 transition-transform"></i>
                                <span class="text-[12px] font-bold">YouTube</span>
                            </a>
                            <a href="#" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 rounded-xl py-3 transition-all duration-300 group">
                                <i class="fa-brands fa-tiktok text-white group-hover:scale-110 transition-transform"></i>
                                <span class="text-[12px] font-bold">TikTok</span>
                            </a>
                            <a href="#" class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 rounded-xl py-3 transition-all duration-300 group">
                                <i class="fa-solid fa-comment-dots text-white group-hover:scale-110 transition-transform"></i>
                                <span class="text-[12px] font-bold">Zalo OA</span>
                            </a>
                        </div>
                    </div>
                </div>
            </aside>
            <!--Banner main-->
            <div class="flex-1 min-w-0">

                <div class="relative w-full rounded-3xl bg-[#0a0f1c] shadow-2xl flex items-center px-8 md:px-16 group
        transition-all duration-1000 ease-in-out transform origin-top
        @(isCategorySelected ? "h-0 opacity-0 mb-0 scale-y-0 overflow-hidden" : "h-[280px] md:h-[320px] mb-5 opacity-100 scale-y-100 overflow-hidden")">

                    <div class="absolute inset-0 z-0 bg-[#0a0f1c]">
                        <img id="banner-img" src="https://images.unsplash.com/photo-1558002038-1055907df827?q=80&w=2070&auto=format&fit=crop"
                             class="w-full h-full object-cover opacity-40 group-hover:scale-105 transition-all duration-500 ease-in-out"
                             alt="Smart Home Banner" />
                        <div class="absolute inset-0 bg-gradient-to-r from-[#0a0f1c] via-[#0a0f1c]/80 to-transparent"></div>
                    </div>

                    <div class="relative z-10 w-full md:w-2/3">
                        <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-4 leading-tight">
                            Kiến tạo <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Không Gian Sống</span><br /> Tương Lai
                        </h2>
                        <p class="text-slate-300 mb-8 text-sm md:text-base font-medium">Giảm ngay 20% cho đơn hàng AuraHome đầu tiên của bạn.</p>

                        <div class="flex items-center w-full max-w-md bg-white/10 backdrop-blur-md p-1.5 rounded-full border border-white/20 focus-within:border-cyan-400 transition-colors shadow-[0_0_30px_rgba(6,182,212,0.15)]">
                            <input type="email" placeholder="Nhập email của bạn..." class="flex-1 bg-transparent border-none text-white placeholder-slate-400 text-sm px-4 focus:ring-0 outline-none" />
                            <button class="bg-cyan-500 hover:bg-cyan-400 text-white text-sm font-bold py-2.5 px-6 rounded-full transition-colors shadow-[0_0_15px_rgba(6,182,212,0.4)]">
                                Đăng ký
                            </button>
                        </div>
                    </div>

                    <button onclick="prevBanner()" class="absolute left-4 top-1/2 -translate-y-1/2 size-10 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white flex items-center justify-center hover:bg-cyan-500 transition-colors z-20">
                        <i class="fa-solid fa-chevron-left text-sm"></i>
                    </button>

                    <button onclick="nextBanner()" class="absolute right-4 top-1/2 -translate-y-1/2 size-10 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white flex items-center justify-center hover:bg-cyan-500 transition-colors z-20">
                        <i class="fa-solid fa-chevron-right text-sm"></i>
                    </button>

                    <div id="banner-dots" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20 items-center">
                    </div>
                </div>

                <div class="mb-6 flex flex-col sm:flex-row items-center justify-between bg-white dark:bg-slate-800 p-2 sm:p-3 rounded-xl shadow-sm border border-slate-100 dark:border-slate-700 gap-3">

                    <div class="flex items-center gap-4 w-full sm:w-auto justify-between sm:justify-start pl-1">

                        <div class="flex items-center bg-slate-100 dark:bg-slate-900 rounded-lg p-1">
                            <button onclick="changeViewMode('grid')" id="btn-grid" class="w-8 h-8 rounded-md bg-white dark:bg-slate-700 text-cyan-500 shadow-sm flex items-center justify-center transition-all" title="Dạng lưới">
                                <i class="fa-solid fa-border-all text-sm"></i>
                            </button>
                            <button onclick="changeViewMode('list')" id="btn-list" class="w-8 h-8 rounded-md text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 flex items-center justify-center transition-all" title="Dạng danh sách">
                                <i class="fa-solid fa-list-ul text-sm"></i>
                            </button>
                        </div>

                        <div class="text-[13px] font-medium text-slate-500 dark:text-slate-400">
                            Có <span class="font-bold text-slate-800 dark:text-white">@Model.SanPhams.Count()</span> sản phẩm
                        </div>
                    </div>

                    <form method="get" action="/Customers/Index" class="flex w-full sm:w-auto" id="sortForm">
                        @if (Context.Request.Query.ContainsKey("category"))
                        {
                            <input type="hidden" name="category" value="@Context.Request.Query["category"]" />
                        }
                        <div class="relative w-full sm:w-56 group h-10 flex items-center">
                            <select name="sortOrder" onchange="document.getElementById('sortForm').submit()" class="w-full h-full appearance-none bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 rounded-lg pl-4 pr-10 outline-none focus:border-cyan-500 transition-all text-[13px] font-semibold cursor-pointer m-0">
                                @{
                                    var currentSort = Context.Request.Query["sortOrder"].ToString();
                                }
                                <option value="" selected="@(string.IsNullOrEmpty(currentSort))">Sắp xếp: Mới nhất</option>
                                <option value="price_asc" selected="@(currentSort == "price_asc")">Giá: Thấp &rarr; Cao</option>
                                <option value="price_desc" selected="@(currentSort == "price_desc")">Giá: Cao &rarr; Thấp</option>
                                <option value="name_asc" selected="@(currentSort == "name_asc")">Tên: A &rarr; Z</option>
                                <option value="name_desc" selected="@(currentSort == "name_desc")">Tên: Z &rarr; A</option>
                            </select>
                            <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 text-[10px] pointer-events-none group-hover:text-cyan-500 transition-colors flex items-center h-full"></i>
                        </div>
                    </form>
                </div>

                <!--Sản Phẩm-->
                <div id="product-list-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

                    @if (Model.SanPhams != null && Model.SanPhams.Any())
                    {
                        foreach (var sp in Model.SanPhams)
                        {
                            // BƯỚC 1: Xử lý gộp ảnh chính và ảnh phụ của TỪNG SẢN PHẨM vào một List
                            var tatCaHinhAnh = new List<string>();
                            if (!string.IsNullOrEmpty(sp.HinhAnh))
                            {
                                tatCaHinhAnh.Add(sp.HinhAnh);
                            }
                            if (sp.HinhAnhSanPhams != null && sp.HinhAnhSanPhams.Any())
                            {
                                tatCaHinhAnh.AddRange(sp.HinhAnhSanPhams.Select(x => x.UrlHinhAnh));
                            }

                            <div class="bg-white dark:bg-slate-800/50 rounded-3xl border border-slate-100 dark:border-slate-700/50 overflow-hidden hover:shadow-[0_20px_40px_-15px_rgba(6,182,212,0.15)] hover:border-cyan-200 dark:hover:border-cyan-800 transition-all duration-500 group flex flex-col h-full">

                                <div class="relative aspect-square bg-slate-50 dark:bg-slate-900/50 overflow-hidden p-4 flex items-center justify-center">
                                    <img class="block w-full h-full object-cover origin-center group-hover:scale-110 transition-transform duration-500 will-change-transform"
                                         src="@(string.IsNullOrEmpty(sp.HinhAnh) ? "https://images.unsplash.com/photo-1558002038-1055907df827?q=80&w=500&auto=format&fit=crop" : $"/img/{sp.HinhAnh}")"
                                         alt="@sp.TenSanPham" />

                                    <span class="absolute top-3 left-3 bg-gradient-to-r from-cyan-500 to-blue-500 text-white text-[10px] font-black px-2.5 py-1 rounded-md uppercase tracking-wider shadow-md z-10">New</span>

                                    <div class="absolute top-3 right-3 translate-x-4 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 z-10">
                                        <button class="size-8 rounded-full bg-white text-slate-400 hover:text-rose-500 hover:shadow-md flex items-center justify-center transition-all">
                                            <i class="fa-solid fa-heart text-sm"></i>
                                        </button>
                                    </div>

                                    <button type="button" onclick="openQuickView('@sp.MaSanPham')"
                                            class="w-full absolute bottom-0 inset-x-0 bg-indigo-600/90 backdrop-blur-sm text-white text-[13px] font-black uppercase tracking-widest py-3 text-center translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-20 shadow-[0_-10px_20px_rgba(0,0,0,0.1)]">
                                        Xem nhanh
                                    </button>

                                    <div id="quickview-@sp.MaSanPham" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 sm:p-6">
                                        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" onclick="closeQuickView('@sp.MaSanPham')"></div>

                                        <div class="relative w-full max-w-4xl bg-white dark:bg-slate-900 rounded-3xl shadow-2xl flex flex-col md:flex-row overflow-hidden max-h-[90vh] z-10 transform transition-all">

                                            <button onclick="closeQuickView('@sp.MaSanPham')" class="absolute top-4 right-4 z-50 size-10 flex items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 hover:bg-rose-500 hover:text-white transition-colors shadow-sm">
                                                <i class="fa-solid fa-xmark text-lg"></i>
                                            </button>

                                            <div class="w-full md:w-1/2 bg-slate-50 dark:bg-slate-800/50 p-6 md:p-8 flex flex-col items-center justify-start relative">

                                                <div class="relative w-full h-[40vh] md:h-[50vh] flex items-center justify-center mb-6">
                                                    <img id="main-img-@sp.MaSanPham"
                                                         src="@(tatCaHinhAnh.Any() ? $"/img/{tatCaHinhAnh.First()}" : "https://images.unsplash.com/photo-1558002038-1055907df827?q=80&w=500&auto=format&fit=crop")"
                                                         alt="@sp.TenSanPham"
                                                         class="max-h-full max-w-full object-contain drop-shadow-xl transition-all duration-300" />
                                                </div>

                                                <div class="flex gap-3 overflow-x-auto w-full pb-2 hide-scrollbar justify-center">
                                                    @if (tatCaHinhAnh.Any())
                                                    {
                                                        for (int i = 0; i < tatCaHinhAnh.Count; i++)
                                                        {
                                                            // Ảnh đầu tiên (i==0) được đánh dấu viền đậm mặc định
                                                            string activeBorder = (i == 0) ? "border-[#2b3a82] dark:border-indigo-400" : "border-transparent hover:border-slate-300 dark:hover:border-slate-600";

                                                            <img onclick="changeMainImage('@sp.MaSanPham', '/img/@tatCaHinhAnh[i]', this)"
                                                                 src="/img/@tatCaHinhAnh[i]"
                                                                 class="size-16 md:size-20 rounded-xl border-2 @activeBorder cursor-pointer object-cover shadow-sm flex-shrink-0 transition-all qv-thumb-@sp.MaSanPham"
                                                                 onerror="this.style.display='none'" />
                                                        }
                                                    }
                                                </div>

                                            </div>

                                            <div class="w-full md:w-1/2 p-8 lg:p-12 flex flex-col overflow-y-auto">
                                                <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-2 leading-snug">@sp.TenSanPham</h2>

                                                <div class="w-12 h-1 bg-slate-200 dark:bg-slate-700 mb-6"></div>

                                                <div class="mb-6">
