@model AISmartHome.Models.BaiViet
@{
    ViewData["Title"] = Model.TieuDe + " | AuraMag";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var relatedNews = ViewBag.RelatedNews as IEnumerable<AISmartHome.Models.BaiViet>;
}

<script src="https://cdn.tailwindcss.com?plugins=typography,forms,aspect-ratio"></script>

<style>
    .editorial-bg {
        background: radial-gradient(circle at top right, rgba(0, 229, 255, 0.03), transparent), radial-gradient(circle at bottom left, rgba(0, 31, 63, 0.02), transparent);
        background-color: #f8fafc; /* slate-50 */
    }
    /* Tối ưu hiển thị ảnh trong nội dung bài viết */
    .prose img {
        border-radius: 1.5rem;
        box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
        margin-left: auto;
        margin-right: auto;
    }

    .prose blockquote {
        border-left-color: #00E5FF;
        font-style: italic;
        color: #1e293b;
    }
</style>

<div class="editorial-bg min-h-screen pb-24">
    <div class="fixed top-0 left-0 w-full h-1 z-[60]">
        <div id="readingProgress" class="h-full bg-gradient-to-r from-cyan-400 to-blue-600 w-0 transition-all duration-150"></div>
    </div>

    <header class="relative bg-[#001F3F] pt-32 pb-40 overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <pattern id="dotPattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                        <circle cx="2" cy="2" r="1" fill="#00E5FF"></circle>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#dotPattern)"></rect>
            </svg>
        </div>

        <div class="relative max-w-7xl mx-auto px-6 z-10 text-center flex flex-col items-center">
            <nav class="flex items-center gap-3 mb-8">
                <span class="px-4 py-1.5 bg-cyan-500 text-[#001F3F] font-black text-[10px] tracking-[0.2em] uppercase rounded-full shadow-lg shadow-cyan-500/20">
                    @Model.MaDanhMucBaiVietNavigation?.TenDanhMuc
                </span>
                <span class="text-white/40 text-xs font-bold uppercase tracking-widest">AuraMag Digital Atrium</span>
            </nav>

            <h1 class="max-w-5xl text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.1] tracking-tighter drop-shadow-lg mb-10">
                @Model.TieuDe
            </h1>

            <div class="flex items-center gap-4 bg-white/5 backdrop-blur-sm px-6 py-3 rounded-full border border-white/10 text-white/90 shadow-inner">
                <div class="flex items-center gap-2.5">
                    <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-cyan-400 to-blue-500 flex items-center justify-center font-black text-[#001F3F] text-xs">AH</div>
                    <span class="text-sm font-bold">AuraHome Team</span>
                </div>
                <div class="h-5 w-px bg-white/20"></div>
                <span class="text-sm">@Model.NgayDang?.ToString("dd/MM/yyyy")</span>
                <div class="h-5 w-px bg-white/20"></div>
                <span class="text-sm flex items-center gap-1.5"><i class="fa-regular fa-clock text-cyan-400"></i> 6 phút đọc</span>
            </div>
        </div>
    </header>

    <div class="relative z-20 max-w-7xl mx-auto px-6 -mt-24 mb-16">
        <div class="relative aspect-video max-h-[500px] w-full mx-auto rounded-[2.5rem] overflow-hidden shadow-2xl shadow-slate-900/30 border-4 border-white group">
            <div class="absolute inset-0 bg-cyan-400 blur-[120px] opacity-30 scale-75 rounded-full group-hover:opacity-40 transition-opacity"></div>

            <img alt="@Model.TieuDe"
                 class="relative w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                 src="/img/@Model.HinhAnh"
                 onerror="this.src='https://via.placeholder.com/1600x900?text=AuraMag+Exclusive'" />

            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-16 relative z-10">

        <main class="lg:col-span-8">
            <article class="bg-white p-8 md:p-14 rounded-[3rem] shadow-xl shadow-slate-100 border border-slate-100">

                <div class="text-xl md:text-2xl font-medium text-slate-500 leading-relaxed italic mb-12 border-l-4 border-cyan-400 pl-8">
                    Khám phá chiều sâu của công nghệ và kiến trúc thông minh qua góc nhìn của các chuyên gia AuraHome.
                </div>

                <div class="prose prose-slate prose-lg max-w-none
                            prose-headings:font-black prose-headings:text-[#001F3F] prose-headings:tracking-tight
                            prose-p:text-slate-600 prose-p:leading-relaxed prose-p:font-light
                            prose-a:text-cyan-500 prose-a:no-underline hover:prose-a:text-blue-700 prose-a:font-medium
                            prose-strong:text-slate-900 prose-strong:font-bold
                            prose-img:shadow-2xl prose-img:rounded-3xl">
                    @Html.Raw(Model.NoiDung)
                </div>

                @if (!string.IsNullOrEmpty(Model.NguonTin))
                {
                    <div class="mt-20 p-8 bg-slate-50 rounded-3xl border border-slate-100 flex flex-col sm:flex-row items-center justify-between group gap-4">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-cyan-500 group-hover:scale-110 transition-transform shink-0">
                                <i class="fa-solid fa-link text-xl"></i>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Nguồn tin gốc</p>
                                <p class="text-sm font-bold text-slate-700 truncate max-w-[200px] md:max-w-[350px]">@Model.NguonTin</p>
                            </div>
                        </div>
                        <a href="@Model.NguonTin" target="_blank" class="bg-[#001F3F] text-white px-7 py-3 rounded-xl text-xs font-black hover:bg-cyan-500 transition-colors whitespace-nowrap shadow-md">TRUY CẬP</a>
                    </div>
                }

                <div class="mt-16 pt-10 border-t border-slate-100 flex flex-wrap items-center justify-between gap-6">
                    <div class="flex items-center gap-4">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-wider">Tags:</span>
                        <div class="flex gap-2.5">
                            <span class="px-3 py-1 bg-slate-100 text-slate-500 text-[10px] font-bold rounded-lg uppercase">#AuraHome</span>
                            <span class="px-3 py-1 bg-slate-100 text-slate-500 text-[10px] font-bold rounded-lg uppercase">#Smart_Living</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="text-xs font-black text-slate-400 uppercase mr-1 tracking-wider">Chia sẻ:</span>
                        <button class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 hover:text-blue-600 hover:border-blue-600 hover:bg-blue-50 transition-all"><i class="fa-brands fa-facebook-f"></i></button>
                        <button class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center text-slate-400 hover:text-cyan-500 hover:border-cyan-500 hover:bg-cyan-50 transition-all"><i class="fa-solid fa-link"></i></button>
                    </div>
                </div>
            </article>

            <div class="mt-12 bg-[#001F3F] p-10 rounded-[3rem] text-white flex flex-col md:flex-row items-center gap-8 shadow-xl shadow-slate-200">
                <img src="https://ui-avatars.com/api/?name=Aura+Home&background=00E5FF&color=001F3F&size=120" class="w-24 h-24 rounded-full border-4 border-white/10 shadow-xl shrink-0">
                <div class="flex-1 text-center md:text-left">
                    <p class="text-xs font-black text-cyan-400 uppercase tracking-widest mb-1">Đội ngũ biên tập</p>
                    <h4 class="text-2xl font-black text-white mb-2">AuraHome Editorial</h4>
                    <p class="text-slate-300 leading-relaxed text-sm mb-5">Chúng tôi kết nối những ý tưởng công nghệ đột phá với cuộc sống thường nhật, giúp bạn làm chủ không gian sống tương lai.</p>
                    <div class="flex justify-center md:justify-start gap-5">
                        <a href="/Contact" class="text-xs font-black text-[#001F3F] bg-white px-5 py-2 rounded-lg hover:bg-cyan-400 transition-colors">LIÊN HỆ</a>
                        <a href="#" class="text-xs font-black tracking-widest hover:text-cyan-400 transition-colors pt-2">FACEBOOK</a>
                    </div>
                </div>
            </div>
        </main>

        <aside class="lg:col-span-4 space-y-10">

            <div class="sticky top-28 space-y-10">

                <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100">
                    <h3 class="text-lg font-black text-[#001F3F] mb-8 flex items-center justify-between">
                        <span>BÀI VIẾT TƯƠNG TỰ</span>
                        <span class="w-10 h-1 bg-cyan-500 rounded-full shrink-0"></span>
                    </h3>
                    <div class="space-y-7">
                        @if (relatedNews != null && relatedNews.Any())
                        {
                            foreach (var news in relatedNews)
                            {
                                <a asp-action="NewsDetail" asp-route-id="@news.MaBaiViet" class="group flex gap-4 items-center">
                                    <div class="w-16 h-16 rounded-2xl overflow-hidden shrink-0 shadow-sm bg-slate-100">
                                        <img src="/img/@news.HinhAnh" class="w-full h-full object-cover group-hover:scale-110 transition-all duration-500" onerror="this.src='/img/news-default.jpg'">
                                    </div>
                                    <div class="space-y-1">
                                        <h4 class="text-sm font-bold text-slate-800 line-clamp-2 leading-snug group-hover:text-cyan-600 transition-colors">@news.TieuDe</h4>
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-tighter">@news.NgayDang?.ToString("dd MMM yyyy")</span>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>

                <div class="bg-[#001F3F] p-8 rounded-[2.5rem] text-white overflow-hidden relative shadow-2xl shadow-slate-200">
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-cyan-500/20 rounded-full blur-3xl"></div>
                    <h3 class="text-xl font-black mb-3">Stay Digital.</h3>
                    <p class="text-sm text-slate-400 mb-6 leading-relaxed">Đăng ký nhận bản tin công nghệ AuraMag mới nhất.</p>
                    <div class="space-y-3">
                        <input type="email" placeholder="Email của bạn..." class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-3 text-sm focus:ring-2 focus:ring-cyan-500 outline-none placeholder:text-white/20">
                        <button class="w-full bg-cyan-500 text-[#001F3F] font-black py-3 rounded-xl hover:bg-white hover:scale-105 transition-all shadow-lg shadow-cyan-500/20 text-sm">ĐĂNG KÝ NGAY</button>
                    </div>
                </div>

                <a asp-action="News" class="flex items-center justify-center gap-3 w-full py-4 rounded-[2rem] border-2 border-slate-200 text-slate-500 font-black text-xs tracking-widest hover:bg-white hover:border-[#001F3F] hover:text-[#001F3F] transition-all group">
                    <i class="fa-solid fa-arrow-left-long group-hover:-translate-x-1 transition-transform"></i> QUAY LẠI KHO TIN TỨC
                </a>
            </div>

        </aside>
    </div>
</div>

<script>
    // Logic thanh tiến trình đọc bài
    window.onscroll = function() {
        let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        let scrolled = (winScroll / height) * 100;
        let progressElement = document.getElementById("readingProgress");
        if (progressElement) {
            progressElement.style.width = scrolled + "%";
        }
    };
</script>