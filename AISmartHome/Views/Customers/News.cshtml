@model IEnumerable<AISmartHome.Models.BaiViet>
@{
    ViewData["Title"] = "AuraBlog | Tin tức tương lai";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Hoặc Layout bạn đang dùng
    var categories = ViewBag.Categories as IEnumerable<AISmartHome.Models.DanhMucBaiViet>;
    var currentCat = ViewBag.CurrentCategory as int?;
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    /* Đốm sáng nền lung linh (Ambient Blurs) */
    .ambient-blob {
        position: absolute;
        filter: blur(80px);
        z-index: 0;
        opacity: 0.6;
        animation: float 10s infinite alternate ease-in-out;
    }
    @@keyframes float {
        0%

    {
        transform: translate(0, 0) scale(1);
    }

    100% {
        transform: translate(30px, -50px) scale(1.1);
    }

    }

    /* Hiệu ứng thẻ kính mờ (Glass Card) */
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);
    }
</style>

<div class="bg-[#FAFCFF] text-slate-800 font-body selection:bg-secondary selection:text-white min-h-screen relative overflow-hidden">

    <div class="ambient-blob bg-cyan-300/40 w-[30rem] h-[30rem] rounded-full top-[-5%] left-[-10%] pointer-events-none"></div>
    <div class="ambient-blob bg-indigo-300/30 w-[40rem] h-[40rem] rounded-full top-[20%] right-[-15%] pointer-events-none" style="animation-delay: -5s;"></div>

    <main class="pt-24 pb-20 relative z-10">

        <section class="max-w-screen-2xl mx-auto px-8 mb-10 pt-12 md:pt-16 text-center">
            <div class="max-w-4xl mx-auto flex flex-col items-center">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/80 backdrop-blur-sm text-secondary text-xs font-bold uppercase tracking-widest mb-6 rounded-full border border-secondary/20 shadow-sm">
                    <span class="material-symbols-outlined text-[16px]">campaign</span>
                    Blog độc quyền tại AuraBlog
                </span>

                <h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tighter text-slate-900 leading-tight mb-6">
                    Tin tức & <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#006875] to-[#00daf3]">Xu hướng</span>
                </h1>

                <p class="text-lg md:text-xl text-slate-500 font-medium leading-relaxed max-w-2xl">
                    Khai phá tiềm năng vô hạn của AI trong không gian sống hiện đại. Khám phá những giải pháp thông minh giúp cuộc sống trở nên tinh tế hơn.
                </p>
            </div>

            <div class="w-full h-px bg-slate-200/60 mt-12"></div>
        </section>

        <section class="max-w-screen-2xl mx-auto px-8 mb-12">
            <div class="flex flex-wrap items-center justify-center gap-4">

                <a asp-action="News" asp-route-danhMucId=""
                   class="px-8 py-3 rounded-full font-bold text-sm transition-all duration-300 active:scale-95 shadow-sm border
                  @(currentCat == null
                    ? "bg-[#006875] text-white border-[#006875] shadow-lg shadow-[#006875]/30 scale-105"
                    : "bg-white/80 backdrop-blur-md border-slate-200 text-slate-600 hover:bg-[#006875] hover:text-white hover:border-[#006875] hover:-translate-y-1")">
                    Tất cả
                </a>

                @if (categories != null)
                {
                    foreach (var cat in categories)
                    {
                        <a asp-action="News" asp-route-danhMucId="@cat.MaDanhMucBaiViet"
                           class="px-8 py-3 rounded-full font-bold text-sm transition-all duration-300 active:scale-95 shadow-sm border
                          @(currentCat == cat.MaDanhMucBaiViet
                            ? "bg-[#006875] text-white border-[#006875] shadow-lg shadow-[#006875]/30 scale-105"
                            : "bg-white/80 backdrop-blur-md border-slate-200 text-slate-600 hover:bg-[#006875] hover:text-white hover:border-[#006875] hover:-translate-y-1")">
                            @cat.TenDanhMuc
                        </a>
                    }
                }

            </div>
        </section>

        <section class="max-w-screen-2xl mx-auto px-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var item in Model)
                {
                    <article class="group relative rounded-[2rem] p-4 glass-card hover:-translate-y-2 transition-transform duration-500 cursor-pointer flex flex-col h-full" onclick="window.location.href='@Url.Action("NewDetail", "Customers", new { id = item.MaBaiViet })'">

                        <div class="aspect-[4/5] rounded-[1.5rem] overflow-hidden mb-5 relative shadow-inner">
                            <img alt="@item.TieuDe" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                 src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/default-thumbnail.jpg" : $"/img/{item.HinhAnh}")" />
                            <div class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/10 transition-colors duration-500"></div>
                        </div>

                        <div class="flex-1 flex flex-col justify-start px-2">
                            <span class="text-secondary text-xs font-black uppercase tracking-widest mb-2 block">
                                @(item.MaDanhMucBaiVietNavigation?.TenDanhMuc ?? "Tin Tức")
                            </span>
                            <h3 class="text-xl font-headline font-bold text-slate-900 leading-snug group-hover:text-cyan-600 transition-colors duration-300 line-clamp-3">
                                @item.TieuDe
                            </h3>
                            <time class="text-slate-400 text-xs mt-auto pt-4 font-bold flex items-center gap-1.5 uppercase tracking-wider">
                                <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                @(item.NgayDang?.ToString("dd/MM/yyyy") ?? "Mới cập nhật")
                            </time>
                        </div>
                    </article>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-24 glass-card rounded-[2rem] mt-8">
                    <span class="material-symbols-outlined text-6xl text-slate-300 mb-4 block">article</span>
                    <p class="text-lg text-slate-500 font-medium">Hiện chưa có bài viết nào trong danh mục này.</p>
                </div>
            }
        </section>

    </main>
</div>