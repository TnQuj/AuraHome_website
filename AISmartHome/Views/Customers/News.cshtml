@model IEnumerable<AISmartHome.Models.BaiViet>
@{
    ViewData["Title"] = "AuraBlog | Tin tức tương lai";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Hoặc Layout bạn đang dùng
    var categories = ViewBag.Categories as IEnumerable<AISmartHome.Models.DanhMucBaiViet>;
    var currentCat = ViewBag.CurrentCategory as int?;
}

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .glass-nav {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }

    .editorial-shadow {
        text-shadow: 0 10px 30px rgb(246, 244, 232);
    }
</style>

<div class="bg-[#25343F] text-white font-body selection:bg-secondary-container selection:text-primary">
    <main class="pt-24 pb-20">
        <section class="max-w-screen-2xl mx-auto px-8 mb-20">
            <div class="relative rounded-3xl overflow-hidden h-[716px] flex items-end p-12">
                <div class="absolute inset-0 bg-gradient-to-t from-[#000D1A] via-[#000D1A]/40 to-transparent z-10"></div>
                @{
                    var featured = Model.FirstOrDefault();
                }
                <img alt="Hero" class="absolute inset-0 w-full h-full object-cover"
                     src="~/img/044069d4fdd37c511dc3ae826f3dc46d.jpg" />

                <div class="relative z-20 max-w-4xl">
                    <span class="inline-block px-4 py-1 bg-secondary text-white text-xs font-bold uppercase tracking-widest mb-4 rounded-sm">Blog độc quyền tại AuraBlog</span>
                    <h1 class="text-7xl md:text-9xl font-headline font-extrabold tracking-tighter editorial-shadow leading-none mb-6">
                        AURAMAG
                    </h1>
                    <p class="text-xl md:text-2xl text-surface-variant font-light max-w-2xl leading-relaxed">
                        Khai phá tiềm năng vô hạn của AI trong không gian sống hiện đại. Khám phá những giải pháp thông minh giúp cuộc sống trở nên tinh tế hơn.
                    </p>
                </div>
            </div>
        </section>

        <section class="max-w-screen-2xl mx-auto px-8 mb-12">
            <div class="flex flex-wrap items-center gap-3">
                <a asp-action="News" asp-route-danhMucId=""
                   class="px-8 py-3 rounded-full font-medium text-sm transition-all hover:scale-105 active:scale-95 @(currentCat == null ? "bg-secondary text-white" : "bg-surface-container-low/10 border border-white/10 text-surface-variant")">
                    Tất cả
                </a>
                @if (categories != null)
                {
                    foreach (var cat in categories)
                    {
                        <a asp-action="News" asp-route-danhMucId="@cat.MaDanhMucBaiViet"
                           class="px-8 py-3 rounded-full font-medium text-sm transition-all hover:scale-105 active:scale-95 @(currentCat == cat.MaDanhMucBaiViet ? "bg-secondary text-white" : "bg-surface-container-low/10 border border-white/10 text-surface-variant hover:bg-white/10")">
                            @cat.TenDanhMuc
                        </a>
                    }
                }
            </div>
        </section>

        <section class="max-w-screen-2xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var item in Model)
                {
                    <article class="group cursor-pointer" onclick="window.location.href='@Url.Action("NewDetail", "Customers", new { id = item.MaBaiViet })'">
                        <div class="aspect-[4/5] rounded-2xl overflow-hidden mb-4 relative">
                            <img alt="@item.TieuDe" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                 src="/img/@item.HinhAnh" onerror="this.src='https://via.placeholder.com/400x500'" />
                            <div class="absolute inset-0 bg-gradient-to-t from-[#000D1A] to-transparent opacity-60"></div>
                        </div>
                        <span class="text-secondary-container text-xs font-bold uppercase tracking-widest mb-2 block">
                            @item.MaDanhMucBaiVietNavigation?.TenDanhMuc
                        </span>
                        <h3 class="text-xl font-headline font-bold leading-tight group-hover:text-secondary-container transition-colors duration-300">
                            @item.TieuDe
                        </h3>
                        <time class="text-surface-variant/50 text-xs mt-3 block">@item.NgayDang?.ToString("dd/MM/yyyy")</time>
                    </article>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-20 text-surface-variant/50">
                    <p>Hiện chưa có bài viết nào trong danh mục này.</p>
                </div>
            }
        </section>

        @* <section class="max-w-screen-2xl mx-auto px-8 mt-32"> *@
        @*     <div class="relative rounded-[3rem] bg-primary-container p-12 md:p-20 overflow-hidden group"> *@
        @*         <div class="absolute top-0 right-0 w-1/2 h-full bg-secondary-container/10 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2 group-hover:bg-secondary-container/20 transition-all duration-700"></div> *@
        @*         <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12"> *@
        @*             <div class="max-w-xl"> *@
        @*                 <h2 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tight mb-6"> *@
        @*                     Stay updated with AuraHome *@
        @*                 </h2> *@
        @*                 <p class="text-lg text-surface-variant/80 font-light leading-relaxed"> *@
        @*                     Đăng ký nhận bản tin định kỳ về các xu hướng công nghệ nhà thông minh và AI hàng đầu từ AuraMag. *@
        @*                 </p> *@
        @*             </div> *@
        @*             <div class="w-full md:w-auto min-w-[320px]"> *@
        @*                 <form class="flex flex-col gap-4"> *@
        @*                     <input class="bg-white/5 border border-white/10 rounded-2xl py-5 px-8 text-white focus:ring-2 focus:ring-secondary outline-none backdrop-blur-md" placeholder="Địa chỉ email của bạn" type="email" /> *@
        @*                     <button class="bg-gradient-to-r from-secondary to-secondary-container text-white font-bold py-5 px-10 rounded-2xl shadow-lg hover:shadow-cyan-500/20 active:scale-95 transition-all"> *@
        @*                         Đăng ký ngay *@
        @*                     </button> *@
        @*                 </form> *@
        @*             </div> *@
        @*         </div> *@
        @*     </div> *@
        @* </section> *@
    </main>
</div>