@model IEnumerable<AISmartHome.Models.SanPham>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@keyframes fade-in-up {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.6s ease-out forwards;
        opacity: 0;
    }
</style>
<main class="w-full min-h-[75vh] pb-20 bg-slate-50 overflow-hidden relative">
    <div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-brand-cyan/5 to-transparent pointer-events-none"></div>
    <div class="absolute -top-24 -right-24 w-[500px] h-[500px] rounded-full bg-blue-400/10 blur-[80px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-8">

        <div class="mb-10 bg-white/80 backdrop-blur-xl border border-brand-cyan/20 rounded-2xl p-5 md:p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] animate-fade-in-up relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-brand-cyan to-blue-600"></div>

            <div class="flex flex-col sm:flex-row items-start gap-4 md:gap-5 ml-2">
                <div class="w-12 h-12 rounded-full bg-cyan-50 flex items-center justify-center text-brand-cyan shrink-0 border border-cyan-100 shadow-inner">
                    <i class="fa-solid fa-lightbulb text-xl animate-pulse"></i>
                </div>
                <div>
                    <h4 class="text-brand-navy font-black text-base uppercase tracking-wider mb-2">Mẹo tìm kiếm thông minh từ AuraHome</h4>
                    <p class="text-slate-600 text-[14px] leading-relaxed text-justify sm:text-left">
                        Hệ thống AI của chúng tôi liên tục phân tích từ khóa để đưa ra gợi ý tốt nhất cho ngôi nhà của bạn. Để tìm đúng thiết bị cần thiết (ví dụ: <em>Công tắc cảm ứng, Cảm biến chuyển động, Camera AI</em>), hãy đảm bảo <strong>nhập đúng tên model hoặc một mô tả ngắn gọn</strong>. Nếu sản phẩm bạn cần không xuất hiện, rất có thể chúng đã được nâng cấp lên phiên bản mới hoặc đang tạm hết hàng. Đừng ngại liên hệ qua Hotline, các kỹ sư của chúng tôi luôn sẵn sàng hỗ trợ bạn tìm thiết bị thay thế hoàn hảo nhất!
                    </p>
                </div>
            </div>
        </div>

        <div class="mb-12 text-center md:text-left animate-fade-in-up" style="animation-delay: 100ms;">
            <h1 class="text-3xl md:text-4xl font-black text-brand-navy mb-3 tracking-tight">
                Kết quả cho:
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-blue-600 inline-block transform hover:scale-105 transition-transform cursor-default">
                    "@ViewBag.Keyword"
                </span>
            </h1>
            <div class="flex items-center justify-center md:justify-start gap-2 text-slate-500 font-medium">
                <i class="fa-solid fa-layer-group text-slate-400"></i>
                <span>Hệ thống quét được <strong class="text-brand-cyan text-lg">@Model.Count()</strong> sản phẩm cực chất.</span>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-8">
                @{
                    int delayIndex = 200;
                }
                @foreach (var item in Model)
                {
                    string delayClass = $"animation-delay: {delayIndex}ms;";
                    delayIndex += 50; // Tăng dần thời gian trễ để tạo hiệu ứng lượn sóng

                    <div class="group relative bg-white rounded-[2rem] p-4 md:p-5 transition-all duration-500 hover:-translate-y-3 hover:shadow-[0_20px_40px_-15px_rgba(0,182,212,0.3)] border border-slate-100/80 hover:border-brand-cyan/30 flex flex-col animate-fade-in-up" style="@delayClass">

                        <a href="/SanPhams/Details/@item.MaSanPham" class="relative w-full aspect-[4/5] rounded-2xl bg-slate-50/50 flex items-center justify-center overflow-hidden mb-5">
                            <div class="absolute inset-0 bg-gradient-to-tr from-brand-cyan/0 via-brand-cyan/0 to-brand-cyan/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                            <img src="/img/@item.HinhAnh" alt="@item.TenSanPham" class="w-3/4 h-3/4 object-contain group-hover:scale-110 group-hover:rotate-3 transition-all duration-700 ease-out z-10 drop-shadow-sm group-hover:drop-shadow-xl" onerror="this.src='https://via.placeholder.com/300?text=No+Image'" />

                            @if (item.SoLuong <= 0)
                            {
                                <div class="absolute top-3 left-3 bg-rose-500/90 backdrop-blur-sm text-white text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-widest z-20 shadow-lg shadow-rose-500/30 border border-rose-400">Hết hàng</div>
                            }
                            else
                            {
                                <div class="absolute top-3 left-3 flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-emerald-600 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider z-20 shadow-sm border border-emerald-100">
                                    <span class="relative flex h-2 w-2">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                                    </span>
                                    Sẵn sàng
                                </div>
                            }
                        </a>

                        <div class="flex flex-col flex-1">
                            <a href="/SanPhams/Details/@item.MaSanPham" class="font-extrabold text-brand-navy group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-brand-cyan group-hover:to-blue-600 transition-all text-[14px] md:text-base line-clamp-2 mb-2 leading-snug">
                                @item.TenSanPham
                            </a>

                            <div class="mt-auto pt-4 flex items-end justify-between gap-2">
                                <div>
                                    <p class="text-xs text-slate-400 line-through font-medium mb-0.5">@((item.GiaBan * 1.2m).ToString("N0")) ₫</p>
                                    <p class="text-rose-600 font-black text-lg md:text-xl drop-shadow-sm">@item.GiaBan.ToString("N0") ₫</p>
                                </div>

                                @if (item.SoLuong > 0)
                                {
                                    <a href="/Customers/BuyNow?id=@item.MaSanPham&quantity=1" class="w-10 h-10 md:w-11 md:h-11 rounded-2xl bg-slate-50 text-slate-600 flex items-center justify-center transition-all duration-300 group-hover:bg-gradient-to-r group-hover:from-brand-cyan group-hover:to-blue-500 group-hover:text-white group-hover:shadow-lg group-hover:shadow-cyan-500/40 shrink-0" title="Mua ngay">
                                        <i class="fa-solid fa-cart-plus transform group-hover:scale-110 transition-transform"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="relative max-w-3xl mx-auto mt-12 animate-fade-in-up" style="animation-delay: 200ms;">

                <div class="absolute -inset-1 bg-gradient-to-r from-rose-500 via-purple-500 to-amber-500 rounded-[3rem] blur-xl opacity-15 animate-pulse pointer-events-none"></div>

                <div class="relative bg-white/90 backdrop-blur-xl rounded-[2.5rem] p-8 md:p-16 text-center border border-white shadow-2xl">

                    <div class="relative w-32 h-32 mx-auto mb-10 flex items-center justify-center">
                        <div class="absolute inset-0 border-2 border-slate-200 rounded-full animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite]"></div>
                        <div class="absolute inset-4 border-2 border-slate-100 rounded-full animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite_0.5s]"></div>
                        <div class="relative w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center shadow-inner border border-slate-100">
                            <i class="fa-solid fa-satellite-dish text-4xl text-slate-400"></i>
                        </div>
                    </div>

                    <h2 class="text-2xl font-black text-brand-navy mb-4">Mất tín hiệu! Không tìm thấy sản phẩm.</h2>

                    <div class="text-slate-500 mb-10 space-y-3 text-sm md:text-base leading-relaxed max-w-xl mx-auto">
                        <p>
                            Radar của chúng tôi không bắt được bất kỳ tín hiệu nào khớp với từ khóa <strong class="text-rose-500 px-2 py-0.5 bg-rose-50 rounded-md border border-rose-100">"@ViewBag.Keyword"</strong> trong toàn bộ kho dữ liệu.
                        </p>

                        <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 text-left mt-8 shadow-inner">
                            <h4 class="font-bold text-slate-700 mb-3 uppercase text-[11px] tracking-widest flex items-center gap-2">
                                <i class="fa-solid fa-clipboard-list text-brand-cyan text-sm"></i> Chẩn đoán & Khắc phục:
                            </h4>
                            <ul class="list-disc list-inside space-y-2 text-slate-600 text-sm">
                                <li><strong>Lỗi đánh máy:</strong> Vui lòng kiểm tra lại xem có sai chính tả không.</li>
                                <li><strong>Từ khóa quá hẹp:</strong> Thử sử dụng các từ khóa chung chung hơn (VD: "Khóa thông minh", "Rèm cửa").</li>
                                <li><strong>Cập nhật hệ thống:</strong> Sản phẩm có thể đang được hãng đổi mã phân phối hoặc ngừng kinh doanh.</li>
                            </ul>
                        </div>
                    </div>

                    <a href="/SanPhams" class="inline-flex items-center gap-3 px-10 py-4 bg-slate-900 hover:bg-brand-cyan text-white font-bold rounded-2xl transition-all duration-300 shadow-xl shadow-slate-900/20 hover:shadow-cyan-500/40 hover:-translate-y-1 group">
                        <i class="fa-solid fa-rotate-left group-hover:-rotate-180 transition-transform duration-500"></i>
                        Khởi động lại radar (Xem tất cả)
                    </a>
                </div>
            </div>
        }
    </div>
</main>