@model IEnumerable<AISmartHome.Models.SanPham>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@keyframes fade-in-up {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.6s ease-out forwards;
        opacity: 0;
    }
</style>

<main class="w-full min-h-[75vh] pb-20 bg-slate-50 overflow-hidden relative">
    <div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-brand-cyan/5 to-transparent pointer-events-none"></div>
    <div class="absolute -top-24 -right-24 w-[500px] h-[500px] rounded-full bg-blue-400/10 blur-[80px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-8">

        <div class="mb-10 bg-white/80 backdrop-blur-xl border border-brand-cyan/20 rounded-2xl p-5 md:p-6 shadow-sm animate-fade-in-up relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-brand-cyan to-blue-600"></div>
            <div class="flex flex-col sm:flex-row items-start gap-4 md:gap-5 ml-2">
                <div class="w-12 h-12 rounded-full bg-cyan-50 flex items-center justify-center text-brand-cyan shrink-0 border border-cyan-100 shadow-inner">
                    <i class="fa-solid fa-lightbulb text-xl animate-pulse"></i>
                </div>
                <div>
                    <h4 class="text-brand-navy font-black text-base uppercase tracking-wider mb-2">Mẹo tìm kiếm thông minh từ AuraHome</h4>
                    <p class="text-slate-600 text-[14px] leading-relaxed text-justify sm:text-left">
                        Hệ thống AI của chúng tôi liên tục phân tích từ khóa để đưa ra gợi ý tốt nhất cho ngôi nhà của bạn. Hãy đảm bảo <strong>nhập đúng tên model hoặc một mô tả ngắn gọn</strong>. Đừng ngại liên hệ qua Hotline, các kỹ sư của chúng tôi luôn sẵn sàng hỗ trợ bạn tìm thiết bị thay thế hoàn hảo nhất!
                    </p>
                </div>
            </div>
        </div>

        <div class="mb-12 text-center md:text-left animate-fade-in-up" style="animation-delay: 100ms;">
            <h1 class="text-3xl md:text-4xl font-black text-brand-navy mb-3 tracking-tight">
                Kết quả cho:
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-blue-600 inline-block transform hover:scale-105 transition-transform cursor-default">
                    "@ViewBag.Keyword"
                </span>
            </h1>
            <div class="flex items-center justify-center md:justify-start gap-2 text-slate-500 font-medium">
                <i class="fa-solid fa-layer-group text-slate-400"></i>
                <span>Tìm thấy <strong class="text-brand-cyan text-lg">@Model.Count()</strong> sản phẩm phù hợp.</span>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
                @{
                    int delayIndex = 200;
                }
                @foreach (var item in Model)
                {
                    string delayClass = $"animation-delay: {delayIndex}ms;";
                    delayIndex += 50;

                    <div class="group relative bg-white rounded-2xl p-4 transition-all duration-500 hover:-translate-y-2 hover:shadow-xl border border-slate-100 hover:border-cyan-200 flex flex-col h-full animate-fade-in-up" style="@delayClass">

                        <a href="/Customers/Details?id=@item.MaSanPham" class="relative w-full aspect-square rounded-xl bg-slate-50 flex items-center justify-center overflow-hidden mb-4">
                            <img src="/img/@item.HinhAnh" alt="@item.TenSanPham" class="w-3/4 h-3/4 object-contain group-hover:scale-110 transition-transform duration-500 z-10" onerror="this.src='https://via.placeholder.com/300?text=No+Image'" />

                            @if (item.SoLuong <= 0)
                            {
                                <div class="absolute top-2 left-2 bg-rose-500/90 text-white text-[10px] font-black px-2 py-1 rounded-md uppercase z-20">Hết hàng</div>
                            }
                        </a>

                        <div class="flex flex-col flex-1">
                            <a href="/Customers/Details?id=@item.MaSanPham" class="font-bold text-brand-navy group-hover:text-brand-cyan transition-colors text-[14px] line-clamp-2 mb-2">
                                @item.TenSanPham
                            </a>

                            <div class="mt-auto flex flex-col gap-3">
                                <div>
                                    <p class="text-xs text-slate-400 line-through font-medium mb-0.5">@((item.GiaBan * 1.2m).ToString("N0")) ₫</p>
                                    <p class="text-rose-600 font-black text-lg">@item.GiaBan.ToString("N0") ₫</p>
                                </div>

                                @if (item.SoLuong > 0)
                                {
                                    <div class="grid grid-cols-2 gap-2 mt-1">
                                        <form onsubmit="addToCartAjax(event)" class="m-0 p-0 w-full">
                                            <input type="hidden" name="id" value="@item.MaSanPham" />
                                            <input type="hidden" name="quantity" value="1" />

                                            <button type="submit" class="w-full flex items-center justify-center gap-1.5 bg-slate-800 hover:bg-brand-cyan text-white text-[12px] font-bold py-2.5 rounded-lg transition-colors shadow-sm">
                                                <i class="fa-solid fa-cart-plus"></i>
                                                <span class="hidden sm:inline">Thêm giỏ</span>
                                                <span class="sm:hidden">Giỏ</span>
                                            </button>
                                        </form>

                                        <a asp-controller="Customers" asp-action="BuyNow" asp-route-id="@item.MaSanPham" asp-route-quantity="1" class="w-full flex items-center justify-center gap-1.5 bg-rose-600 hover:bg-rose-500 text-white text-[12px] font-bold py-2.5 rounded-lg transition-colors shadow-sm">
                                            <i class="fa-solid fa-bolt text-yellow-300"></i> Mua ngay
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <div class="w-full bg-slate-100 text-slate-400 text-[12px] font-bold py-2.5 rounded-lg text-center cursor-not-allowed">
                                        Tạm thời hết hàng
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="relative max-w-3xl mx-auto mt-12 animate-fade-in-up" style="animation-delay: 200ms;">
                <div class="relative bg-white/90 backdrop-blur-xl rounded-3xl p-8 md:p-16 text-center border border-slate-100 shadow-xl">

                    <div class="relative w-32 h-32 mx-auto mb-10 flex items-center justify-center">
                        <div class="absolute inset-0 border-2 border-slate-200 rounded-full animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite]"></div>
                        <div class="absolute inset-4 border-2 border-slate-100 rounded-full animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite_0.5s]"></div>
                        <div class="relative w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center shadow-inner border border-slate-100">
                            <i class="fa-solid fa-satellite-dish text-4xl text-slate-400"></i>
                        </div>
                    </div>

                    <h2 class="text-2xl font-black text-brand-navy mb-4">Mất tín hiệu! Không tìm thấy sản phẩm.</h2>
                    <p class="text-slate-500 mb-8">Radar của chúng tôi không bắt được bất kỳ tín hiệu nào khớp với từ khóa <strong class="text-rose-500">"@ViewBag.Keyword"</strong>.</p>

                    <a href="/Customers/Index" class="inline-flex items-center gap-3 px-8 py-3.5 bg-brand-cyan hover:bg-cyan-600 text-white font-bold rounded-xl transition-colors shadow-lg shadow-cyan-500/30">
                        <i class="fa-solid fa-rotate-left"></i> Trở về Cửa hàng
                    </a>
                </div>
            </div>
        }
    </div>
</main>