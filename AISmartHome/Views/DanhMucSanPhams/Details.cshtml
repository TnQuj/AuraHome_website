@model AISmartHome.Models.DanhMucSanPham

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Danh mục";
}

<style>
    /* Hiệu ứng viền sáng (Glow) cho nút Cyan */
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6 flex flex-col md:flex-row items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
                    Thông tin chi tiết Danh mục
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Mã định danh: #@Model?.MaDanhMuc</p>
            </div>

            <div class="flex items-center gap-3">
                <a asp-action="Index" class="flex items-center gap-2 text-[#001F3F] bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.MaDanhMuc" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-6 py-2.5 rounded-xl font-bold transition-all duration-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Chỉnh sửa ngay
                </a>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden flex flex-col md:flex-row">

            <div class="w-full md:w-1/3 bg-gradient-to-br from-[#001F3F] to-[#003366] p-8 flex flex-col items-center justify-center border-b md:border-b-0 md:border-r border-gray-100 relative overflow-hidden">
                <div class="absolute w-40 h-40 bg-[#00E5FF]/20 rounded-full blur-3xl"></div>

                <div class="relative z-10 w-32 h-32 bg-white/10 backdrop-blur-sm rounded-3xl border border-white/20 shadow-lg flex items-center justify-center p-6 transform hover:scale-105 transition-transform duration-500">
                    <svg class="w-full h-full text-[#00E5FF] drop-shadow-[0_0_15px_rgba(0,229,255,0.4)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
                <p class="text-[#00E5FF] mt-6 font-bold tracking-[0.2em] uppercase text-xs text-center">Category Data</p>
            </div>

            <div class="w-full md:w-2/3 p-8">
                <h2 class="text-3xl font-bold text-[#001F3F] mb-6">@Model?.TenDanhMuc</h2>

                <hr class="border-gray-100 mb-6" />

                <div>
                    <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-3 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
                        Mô tả nhóm thiết bị
                    </h3>

                    <div class="bg-slate-50 p-6 rounded-xl border border-gray-100 text-slate-700 leading-relaxed whitespace-pre-line text-base">
                        @(string.IsNullOrEmpty(Model?.MoTa) ? "Chưa có thông tin mô tả chi tiết cho nhóm danh mục này." : Model?.MoTa)
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>