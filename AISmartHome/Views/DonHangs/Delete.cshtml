@model AISmartHome.Models.DonHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xác nhận xóa Đơn hàng";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-3xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    Xác nhận xóa đơn hàng
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Hành động này không thể hoàn tác. Vui lòng kiểm tra kỹ.</p>
            </div>
            <a asp-action="Index" class="text-gray-500 hover:text-gray-700 font-medium transition-colors">
                Hủy và Quay lại
            </a>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border-2 border-red-50 overflow-hidden">

            <div class="bg-red-50 border-b border-red-100 px-6 py-4 flex items-center gap-3">
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-red-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                <div>
                    <h3 class="font-bold text-red-800">Bạn có chắc chắn muốn xóa đơn hàng này?</h3>
                    <p class="text-xs text-red-600/70">Mọi dữ liệu liên quan đến đơn hàng #@Model.MaDonHang sẽ bị loại bỏ khỏi hệ thống.</p>
                </div>
            </div>

            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                    <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase">Khách hàng</span>
                        <p class="text-[#001F3F] font-bold">@Model.TenKhachHang</p>
                        <p class="text-sm text-slate-500">@Model.SoDienThoai</p>
                    </div>
                    <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase">Giá trị đơn hàng</span>
                        <p class="text-red-600 font-black text-lg">@Model.TongTien?.ToString("N0") đ</p>
                        <p class="text-xs text-slate-500 italic">Trạng thái: @Model.TrangThaiDonHang</p>
                    </div>
                    <div class="md:col-span-2 p-4 rounded-xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase">Địa chỉ nhận hàng</span>
                        <p class="text-sm text-[#001F3F]">@Model.DiaChiGiaoHang</p>
                    </div>
                </div>

                <form asp-action="Delete" class="flex items-center justify-center gap-4">
                    <input type="hidden" asp-for="MaDonHang" />

                    <a asp-action="Index" class="flex-1 text-center py-3 rounded-xl font-bold text-gray-500 bg-gray-100 hover:bg-gray-200 transition-all">
                        Quay lại
                    </a>

                    <button type="submit" class="flex-[2] py-3 rounded-xl font-bold text-white bg-red-600 hover:bg-red-700 shadow-lg shadow-red-200 transition-all flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        Xác nhận xóa vĩnh viễn
                    </button>
                </form>
            </div>

            <div class="bg-slate-50 px-6 py-3 border-t border-slate-100">
                <p class="text-[10px] text-center text-slate-400 uppercase tracking-widest font-bold">Security Check Required</p>
            </div>
        </div>
    </div>
</div>