@model AISmartHome.Models.DonHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Đơn hàng";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Thông tin Đơn hàng chi tiết
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Xem lại lịch sử và thông tin vận chuyển</p>
            </div>
            <div class="flex gap-3">
                <a asp-action="Index" class="flex items-center gap-2 text-gray-600 bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
                    Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model.MaDonHang" class="flex items-center gap-2 text-white bg-[#001F3F] px-4 py-2 rounded-xl font-medium hover:bg-[#002b5a] transition-colors shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    Chỉnh sửa
                </a>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-[#001F3F] px-6 py-4 flex justify-between items-center">
                <h3 class="text-white font-semibold flex items-center gap-2">
                    <svg class="w-5 h-5 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                    Mã đơn hàng: #@Model.MaDonHang
                </h3>
                <span class="px-3 py-1 rounded-full text-xs font-bold bg-[#00E5FF]/20 text-[#00E5FF] border border-[#00E5FF]/30">
                    @Model.TrangThaiDonHang
                </span>
            </div>

            <div class="p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <div class="space-y-6">
                        <div>
                            <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Thông tin khách hàng</h4>
                            <div class="bg-slate-50 p-4 rounded-xl border border-gray-100">
                                <p class="text-sm text-gray-500">Họ tên người nhận</p>
                                @* Ưu tiên hiển thị TenKhachHang nếu có, nếu không thì hiển thị từ Tài khoản *@
                                <p class="text-base font-bold text-[#001F3F]">
                                    @(string.IsNullOrEmpty(Model.TenKhachHang) ? Model.MaKhachHangNavigation?.TenKhachHang : Model.TenKhachHang)
                                </p>

                                <div class="mt-4">
                                    <p class="text-sm text-gray-500">Số điện thoại</p>
                                    <p class="text-base font-semibold text-[#001F3F]">
                                        @(string.IsNullOrEmpty(Model.SoDienThoai) ? "Chưa cập nhật" : Model.SoDienThoai)
                                    </p>
                                </div>

                                <div class="mt-4">
                                    <p class="text-sm text-gray-500">ID Tài khoản hệ thống</p>
                                    <p class="text-sm font-mono text-blue-600">
                                        #@(Model.MaKhachHangNavigation?.MaKhachHang ?? 0)
                                    </p>
                                </div>
                                <div class="mt-4">
                                    <p class="text-sm text-gray-500">Địa chỉ Email</p>
                                    @if (!string.IsNullOrEmpty(Model.Email))
                                    {
                                        <a href="mailto:@Model.Email" class="text-sm font-medium text-blue-600 hover:text-blue-800 hover:underline transition-colors">
                                            @Model.Email
                                        </a>
                                    }
                                    else
                                    {
                                        <p class="text-sm font-medium text-gray-400 italic">Chưa cập nhật</p>
                                    }
                                </div>
                            </div>
                        </div>

                        <div>
                            <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Ngày thực hiện</h4>
                            <div class="flex items-center gap-3 text-[#001F3F]">
                                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <span class="font-medium">@Model.NgayDatHang?.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div>
                            <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Địa chỉ giao hàng</h4>
                            <div class="flex gap-3 bg-red-50/50 p-4 rounded-xl border border-red-100">
                                <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                <p class="text-[#001F3F] leading-relaxed font-medium">
                                    @(string.IsNullOrEmpty(Model.DiaChiGiaoHang) ? "Nhận tại cửa hàng" : Model.DiaChiGiaoHang)
                                </p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.GhiChu))
                        {
                            <div>
                                <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Ghi chú từ Checkout</h4>
                                <div class="p-4 bg-amber-50 rounded-xl border border-amber-100 text-sm text-amber-800 italic leading-relaxed">
                                    <i class="fa-solid fa-quote-left mr-2 opacity-50"></i>
                                    @Model.GhiChu
                                </div>
                            </div>
                        }

                        <div class="bg-blue-50 p-6 rounded-2xl border border-blue-100">
                            <h4 class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-1">Tổng cộng đơn hàng</h4>
                            <p class="text-3xl font-black text-blue-700">
                                @Model.TongTien?.ToString("N0") <span class="text-lg font-bold">VNĐ</span>
                            </p>
                            <p class="text-xs text-blue-500 mt-2 font-medium italic">* Đã bao gồm thuế và phí vận chuyển (nếu có)</p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="bg-slate-50 px-8 py-4 border-t border-gray-100 text-center">
                <p class="text-xs text-gray-400 italic">Đơn hàng được khởi tạo tự động bởi hệ thống AI Smart Home</p>
            </div>
        </div>
    </div>
    <div class="mt-8 bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="bg-slate-800 px-6 py-3">
            <h3 class="text-white font-bold text-sm uppercase tracking-widest flex items-center gap-2">
                <svg class="w-5 h-5 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
                Danh sách thiết bị trong đơn hàng
            </h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 text-[#001F3F] text-xs uppercase font-black border-b border-gray-100">
                        <th class="p-4">Sản phẩm</th>
                        <th class="p-4 text-center">Số lượng</th>
                        <th class="p-4 text-right">Đơn giá</th>
                        <th class="p-4 text-right">Thành tiền</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
                    {
                        foreach (var ct in Model.ChiTietDonHangs)
                        {
                            var thanhTien = (ct.Gia ?? 0) * (ct.SoLuong ?? 0);
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="p-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-12 h-12 bg-gray-100 rounded-lg p-1 shrink-0">
                                            <img src="/img/@ct.MaSanPhamNavigation?.HinhAnh" class="w-full h-full object-contain" alt="">
                                        </div>
                                        <div>
                                            <p class="font-bold text-[#001F3F] text-sm">@ct.MaSanPhamNavigation?.TenSanPham</p>
                                            <p class="text-xs text-gray-400">Mã SP: #@ct.MaSanPham</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 text-center font-semibold text-gray-600">
                                    @ct.SoLuong
                                </td>
                                <td class="p-4 text-right font-medium text-gray-600">
                                    @(ct.Gia?.ToString("N0")) đ
                                </td>
                                <td class="p-4 text-right font-bold text-blue-600">
                                    @thanhTien.ToString("N0") đ
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-400 italic">
                                Không tìm thấy chi tiết sản phẩm cho đơn hàng này.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.GhiChu))
    {
        <div class="mt-6 p-4 bg-amber-50 border-l-4 border-amber-400 rounded-r-xl">
            <h4 class="text-xs font-bold text-amber-700 uppercase mb-1">Ghi chú từ hệ thống/Khách hàng:</h4>
            <p class="text-sm text-amber-800 leading-relaxed">@Model.GhiChu</p>
        </div>
    }
</div>