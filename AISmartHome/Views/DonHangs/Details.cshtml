@model AISmartHome.Models.DonHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xử lý Đơn hàng";

    // Lấy thông tin lắp đặt (nếu có)
    var yeuCau = Model.YeuCauLapDats?.FirstOrDefault();
    bool coLapDat = yeuCau != null;

    // --- LOGIC TÍNH TOÁN TIỀN CỌC ---
    decimal tienHang = Model.TongTien ?? 0;
    decimal tienLapDat = yeuCau?.PhiLapDat ?? 0;

    // Giả định theo logic checkout: Có lắp đặt thì cọc 30%, Không lắp đặt thì trả 100%
    decimal tienDaThanhToan = coLapDat ? (tienHang * 0.3m) : tienHang;
    decimal soTienCanThu = (tienHang + tienLapDat) - tienDaThanhToan;
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
            <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
            Xem chi tiết đơn hàng
        </h1>
        <p class="text-sm text-gray-500 mt-1 pl-10">Cập nhật thông tin vận chuyển và trạng thái thanh toán</p>
    </div>
    <a asp-action="Index" class="flex items-center gap-2 text-[#001F3F] bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại danh sách
    </a>
</div>

<div class="max-w-6xl mx-auto">
    <div class="mb-6 flex justify-between items-center bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-brand-navy text-white rounded-xl flex items-center justify-center text-2xl font-black shadow-inner">
                #@Model.MaDonHang
            </div>
            <div>
                <h1 class="text-xl font-black text-brand-navy uppercase tracking-wide">
                    Đơn hàng @(coLapDat ? "Kèm Lắp Đặt" : "Tiêu chuẩn")
                </h1>
                <p class="text-slate-500 text-sm mt-1">Đặt lúc: @(Model.NgayDatHang?.ToString("dd/MM/yyyy HH:mm"))</p>
            </div>
        </div>
        <div class="text-right">
            <p class="text-sm font-bold text-slate-500 uppercase">Cần thu khách (Còn lại)</p>
            <p class="text-3xl font-black text-rose-600">@soTienCanThu.ToString("N0") VNĐ</p>
            @if (coLapDat)
            {
                <div class="mt-1 inline-flex items-center gap-1 bg-emerald-50 text-emerald-600 text-xs font-bold px-2.5 py-1 rounded-md border border-emerald-100">
                    <i class="fa-solid fa-check-circle"></i> Đã cọc 30%: @tienDaThanhToan.ToString("N0") đ
                </div>
            }
            else
            {
                <div class="mt-1 inline-flex items-center gap-1 bg-emerald-50 text-emerald-600 text-xs font-bold px-2.5 py-1 rounded-md border border-emerald-100">
                    <i class="fa-solid fa-check-circle"></i> Đã thanh toán 100%
                </div>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="space-y-6 lg:col-span-1">

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                <h3 class="font-bold text-slate-800 border-b pb-2 mb-4 uppercase text-sm"><i class="fa-solid fa-user text-brand-cyan mr-2"></i> Khách hàng</h3>
                <div class="space-y-3 text-sm">
                    <p><span class="text-slate-500">Tên:</span> <strong class="text-brand-navy float-right">@(Model.TenKhachHang ?? Model.MaKhachHangNavigation?.TenKhachHang)</strong></p>
                    <p><span class="text-slate-500">SĐT:</span> <strong class="text-brand-cyan float-right">@Model.SoDienThoai</strong></p>
                    <div class="pt-2 border-t border-slate-50">
                        <span class="text-slate-500 block mb-1">Địa chỉ giao/lắp:</span>
                        <strong class="text-slate-800 leading-relaxed block bg-slate-50 p-2 rounded-lg">@Model.DiaChiGiaoHang</strong>
                    </div>
                </div>
            </div>

            @if (coLapDat)
            {
                <div class="bg-cyan-50/50 p-6 rounded-2xl shadow-sm border border-cyan-200 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-brand-cyan"></div>
                    <h3 class="font-bold text-brand-navy border-b border-cyan-200 pb-2 mb-4 uppercase text-sm flex justify-between items-center">
                        <span><i class="fa-solid fa-screwdriver-wrench text-brand-cyan mr-2"></i> Yêu cầu lắp đặt</span>
                        <span class="text-[10px] bg-brand-cyan text-white px-2 py-0.5 rounded">#@yeuCau.MaYeuCauLapDat</span>
                    </h3>

                    <div class="space-y-3 text-sm">
                        <p><span class="text-slate-500">Trạng thái:</span> <strong class="text-rose-600 float-right">@yeuCau.TrangThaiLapDat</strong></p>
                        <p>
                            <span class="text-slate-500">Kỹ thuật viên:</span>
                            <strong class="text-brand-navy float-right">@(yeuCau.MaNhanVienNavigation?.TenNhanVien ?? "Chưa phân công")</strong>
                        </p>
                        <p><span class="text-slate-500">Hẹn ngày:</span> <strong class="text-slate-800 float-right">@(yeuCau.NgayLap?.ToString("dd/MM HH:mm") ?? "Chưa chốt")</strong></p>
                        <p><span class="text-slate-500">Phí kỹ thuật:</span> <strong class="text-rose-600 float-right">@tienLapDat.ToString("N0") đ</strong></p>
                    </div>

                    <a asp-controller="YeuCauLapDats" asp-action="Edit" asp-route-id="@yeuCau.MaYeuCauLapDat"
                       class="mt-4 block w-full text-center py-2 bg-white border border-cyan-300 text-brand-cyan font-bold rounded-lg hover:bg-brand-cyan hover:text-white transition-colors text-sm shadow-sm">
                        Cập nhật / Báo giá lắp đặt
                    </a>
                </div>
            }

        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 lg:col-span-2 flex flex-col">
            <div class="flex justify-between items-center border-b pb-4 mb-4">
                <h3 class="font-bold text-slate-800 uppercase text-sm"><i class="fa-solid fa-box-open text-brand-cyan mr-2"></i> Sản phẩm khách đặt</h3>
                <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full text-xs font-bold">@Model.ChiTietDonHangs.Count() món</span>
            </div>

            <div class="flex-1 overflow-y-auto pr-2 custom-scrollbar space-y-4">
                @foreach (var chitiet in Model.ChiTietDonHangs)
                {
                    decimal thanhTien = (chitiet.Gia ?? 0) * (chitiet.SoLuong ?? 0);
                    <div class="flex items-center gap-4 p-4 border border-slate-100 rounded-xl hover:bg-slate-50 transition-colors">
                        <div class="w-16 h-16 bg-white border border-slate-200 rounded-lg p-1 shrink-0">
                            <img src="/img/@chitiet.MaSanPhamNavigation?.HinhAnh" class="w-full h-full object-contain" alt="Hình ảnh">
                        </div>
                        <div class="flex-1">
                            <p class="font-bold text-brand-navy line-clamp-1">@chitiet.MaSanPhamNavigation?.TenSanPham</p>
                            <p class="text-xs text-slate-500 mt-1">Đơn giá: @(chitiet.Gia?.ToString("N0")) đ</p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold text-slate-500">x @chitiet.SoLuong</p>
                            <p class="font-black text-brand-cyan mt-1">@thanhTien.ToString("N0") đ</p>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-6 pt-4 border-t border-slate-100">
                <div class="flex justify-between items-center text-sm mb-2">
                    <span class="text-slate-500 font-bold">Tổng tiền hàng:</span>
                    <span class="font-bold text-slate-800">@tienHang.ToString("N0") đ</span>
                </div>

                @if (coLapDat)
                {
                    <div class="flex justify-between items-center text-sm mb-2 text-emerald-600">
                        <span class="font-bold bg-emerald-50 px-2 py-0.5 rounded">Đã thanh toán (Cọc 30%):</span>
                        <span class="font-bold">- @tienDaThanhToan.ToString("N0") đ</span>
                    </div>
                    <div class="flex justify-between items-center text-sm mb-2 text-slate-600">
                        <span class="font-bold">Phí lắp đặt thợ thu:</span>
                        <span class="font-bold">+ @tienLapDat.ToString("N0") đ</span>
                    </div>
                }
                else
                {
                    <div class="flex justify-between items-center text-sm mb-2 text-emerald-600">
                        <span class="font-bold bg-emerald-50 px-2 py-0.5 rounded">Đã thanh toán (100%):</span>
                        <span class="font-bold">- @tienDaThanhToan.ToString("N0") đ</span>
                    </div>
                }

                <div class="flex justify-between items-center text-base mt-4 pt-4 border-t border-dashed border-slate-300">
                    <span class="font-black text-brand-navy uppercase">Cần thu khách (Còn lại):</span>
                    <span class="text-2xl font-black text-rose-600">@soTienCanThu.ToString("N0") VNĐ</span>
                </div>
            </div>

        </div>

    </div>
</div>