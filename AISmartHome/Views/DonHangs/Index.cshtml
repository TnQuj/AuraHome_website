@model IEnumerable<AISmartHome.Models.DonHang>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<style>
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }
    /* Hiệu ứng focus cho phần ghi chú */
    .note-box {
        border-left: 3px solid #00E5FF;
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
        <div class="mb-4 md:mb-0">
            <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Quản Lý Đơn Hàng
            </h1>
            <p class="text-sm text-gray-500 mt-1 pl-10">Theo dõi giao dịch, ghi chú và vận chuyển thiết bị AI</p>
        </div>

        <div class="flex items-center gap-3">
            <a asp-action="Create" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-6 py-2.5 rounded-xl font-bold transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Tạo Đơn Thủ Công
            </a>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-slate-50 text-slate-500 font-bold uppercase text-[11px] tracking-wider border-b border-slate-100">
                    <tr>
                        <th class="px-6 py-4">Mã ĐH</th>
                        <th class="px-6 py-4">Khách hàng</th>
                        <th class="px-6 py-4">Loại đơn hàng</th>
                        <th class="px-6 py-4">Tổng tiền</th>
                        <th class="px-6 py-4">Trạng thái</th>
                        <th class="px-6 py-4 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model)
                    {
                        // Lấy ra Yêu cầu lắp đặt của đơn này (nếu có)
                        var yeuCau = item.YeuCauLapDats?.FirstOrDefault();
                        bool coLapDat = yeuCau != null;

                        // Tính tổng tiền thực tế
                        decimal tienHang = item.TongTien ?? 0;
                        decimal tienLapDat = yeuCau?.PhiLapDat ?? 0;
                        decimal tongPhaiThu = tienHang + tienLapDat;

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 font-black text-brand-navy">#@item.MaDonHang</td>
                            <td class="px-6 py-4 font-bold text-slate-700">
                                @(item.TenKhachHang ?? item.MaKhachHangNavigation?.TenKhachHang)
                            </td>
                            <td class="px-6 py-4">
                                @if (coLapDat)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[11px] font-bold bg-cyan-100 text-cyan-700 border border-cyan-200">
                                        <i class="fa-solid fa-screwdriver-wrench"></i> Có lắp đặt
                                    </span>
                                    <div class="text-[10px] text-slate-500 mt-1 font-semibold">
                                        TT: <span class="text-brand-navy">@yeuCau.TrangThaiLapDat</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[11px] font-bold bg-slate-100 text-slate-600 border border-slate-200">
                                        <i class="fa-solid fa-box"></i> Giao chuẩn
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-bold text-rose-600">@tongPhaiThu.ToString("N0") đ</div>
                                @if (tienLapDat > 0)
                                {
                                    <div class="text-[10px] text-slate-400 mt-0.5">(Đã gồm @tienLapDat.ToString("N0")đ lắp)</div>
                                }
                            </td>
                            <td class="px-6 py-4">
                                @{
                                    var statusClass = item.TrangThaiDonHang switch
                                    {
                                        "Chờ xử lý" => "bg-amber-100 text-amber-700 border border-amber-200",
                                        "Đã giao cho kỹ thuật" => "bg-blue-100 text-blue-700 border border-blue-200",
                                        "Đang giao" => "bg-indigo-100 text-indigo-700 border border-indigo-200",
                                        "Hoàn thành" => "bg-emerald-100 text-emerald-700 border border-emerald-200",
                                        "Đã hủy" => "bg-rose-100 text-rose-700 border border-rose-200",
                                        _ => "bg-slate-100 text-slate-600 border border-slate-200" // Trạng thái mặc định
                                    };
                                }
                                <span class="px-3 py-1 @statusClass text-xs font-bold rounded-full whitespace-nowrap shadow-sm">
                                    @item.TrangThaiDonHang
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.MaDonHang"
                                       class="w-8 h-8 flex items-center justify-center bg-cyan-50 text-brand-cyan hover:bg-brand-cyan hover:text-white rounded-lg transition-all shadow-sm group"
                                       title="Xem chi tiết">
                                        <i class="fa-solid fa-eye group-hover:scale-110 transition-transform"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.MaDonHang"
                                       class="w-8 h-8 flex items-center justify-center bg-indigo-50 text-indigo-500 hover:bg-indigo-500 hover:text-white rounded-lg transition-all shadow-sm group"
                                       title="Chỉnh sửa">
                                        <i class="fa-solid fa-pen-to-square group-hover:scale-110 transition-transform"></i>
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.MaDonHang"
                                       class="w-8 h-8 flex items-center justify-center bg-rose-50 text-rose-500 hover:bg-rose-500 hover:text-white rounded-lg transition-all shadow-sm group"
                                       title="Xóa">
                                        <i class="fa-solid fa-trash-can group-hover:scale-110 transition-transform"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>