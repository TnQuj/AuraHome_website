@model IEnumerable<AISmartHome.Models.DonHang>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<style>
    /* Hiệu ứng viền sáng (Glow) cho nút Cyan */
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
        <div class="mb-4 md:mb-0">
            <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Quản Lý Đơn Hàng
            </h1>
            <p class="text-sm text-gray-500 mt-1 pl-10">Theo dõi giao dịch và vận chuyển thiết bị AI</p>
        </div>

        <div class="flex items-center gap-3">
            <a asp-action="Create" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-6 py-2.5 rounded-xl font-bold transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Tạo Đơn Thủ Công
            </a>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-[#001F3F] text-white text-sm uppercase tracking-wider">
                        <th class="p-4 font-semibold">Khách hàng</th>
                        <th class="p-4 font-semibold w-1/3">Liên hệ & Địa chỉ</th>
                        <th class="p-4 font-semibold text-center">Ngày đặt</th>
                        <th class="p-4 font-semibold text-right">Tổng tiền</th>
                        <th class="p-4 font-semibold text-center">Trạng thái</th>
                        <th class="p-4 font-semibold text-center w-36">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-blue-50/50 transition-colors group">

                            <td class="p-4">
                                <div class="font-bold text-[#001F3F] text-base">@item.TenKhachHang</div>
                                @if (item.MaKhachHangNavigation != null)
                                {
                                    <div class="text-xs text-gray-400 mt-0.5">Tài khoản ID: #@item.MaKhachHangNavigation.MaKhachHang</div>
                                }
                            </td>

                            <td class="p-4">
                                <div class="font-semibold text-gray-700 flex items-center gap-1.5 mb-1">
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                    @item.SoDienThoai
                                </div>
                                <div class="text-xs text-gray-500 line-clamp-2" title="@item.DiaChiGiaoHang">
                                    <span class="font-medium">Đ/C:</span> @item.DiaChiGiaoHang
                                </div>
                            </td>

                            <td class="p-4 text-center">
                                <span class="text-sm font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full whitespace-nowrap">
                                    @(item.NgayDatHang.HasValue ? item.NgayDatHang.Value.ToString("dd/MM/yyyy") : "N/A")
                                </span>
                            </td>

                            <td class="p-4 text-right">
                                <span class="inline-flex items-center font-bold text-[#00E5FF] bg-[#001F3F] px-3 py-1.5 rounded-lg shadow-sm whitespace-nowrap">
                                    @(item.TongTien.HasValue ? item.TongTien.Value.ToString("#,##0") : "0") đ
                                </span>
                            </td>

                            <td class="p-4 text-center">
                                <span class="inline-flex px-3 py-1 rounded-full text-xs font-bold border border-blue-200 bg-blue-100 text-blue-700 whitespace-nowrap">
                                    @(string.IsNullOrEmpty(item.TrangThaiDonHang) ? "Chờ xử lý" : item.TrangThaiDonHang)
                                </span>
                            </td>

                            <td class="p-4">
                                <div class="flex items-center justify-center gap-2 opacity-30 group-hover:opacity-100 transition-opacity duration-300">
                                    <a asp-action="Edit" asp-route-id="@item.MaDonHang" class="p-2 text-blue-600 hover:bg-blue-100 hover:text-blue-800 rounded-lg transition-colors" title="Cập nhật trạng thái">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaDonHang" class="p-2 text-[#001F3F] hover:bg-gray-200 rounded-lg transition-colors" title="Xem chi tiết đơn">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaDonHang" class="p-2 text-red-500 hover:bg-red-100 hover:text-red-700 rounded-lg transition-colors" title="Hủy / Xóa đơn">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>