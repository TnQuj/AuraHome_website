
@model AISmartHome.Models.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ - Thiết bị Smart Home";
}
<!DOCTYPE html>

<html class="scroll-smooth" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;400;700;800&amp;family=Inter:wght@300;400;500;600&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "surface-variant": "#e0e3e5",
                "surface-container-low": "#f2f4f6",
                "surface-tint": "#476083",
                "error-container": "#ffdad6",
                "surface-container-highest": "#e0e3e5",
                "outline-variant": "#c4c6cf",
                "tertiary": "#00070a",
                "on-surface": "#191c1e",
                "on-secondary-fixed-variant": "#004f58",
                "on-primary": "#ffffff",
                "on-primary-fixed": "#001c3a",
                "surface-bright": "#f7f9fb",
                "on-secondary": "#ffffff",
                "inverse-on-surface": "#eff1f3",
                "surface-container": "#eceef0",
                "on-tertiary-fixed": "#001f24",
                "on-secondary-fixed": "#001f24",
                "tertiary-fixed": "#9cf0ff",
                "inverse-primary": "#afc8f0",
                "tertiary-fixed-dim": "#00daf3",
                "tertiary-container": "#002328",
                "error": "#ba1a1a",
                "on-secondary-container": "#00616d",
                "on-background": "#191c1e",
                "secondary": "#006875",
                "on-tertiary": "#ffffff",
                "on-error": "#ffffff",
                "surface-dim": "#d8dadc",
                "on-tertiary-fixed-variant": "#004f58",
                "surface-container-high": "#e6e8ea",
                "surface": "#f7f9fb",
                "secondary-container": "#00e3fd",
                "primary-container": "#001f3f",
                "secondary-fixed-dim": "#00daf3",
                "on-surface-variant": "#43474e",
                "on-primary-container": "#6f88ad",
                "primary-fixed-dim": "#afc8f0",
                "secondary-fixed": "#9cf0ff",
                "surface-container-lowest": "#ffffff",
                "primary-fixed": "#d4e3ff",
                "outline": "#74777f",
                "inverse-surface": "#2d3133",
                "background": "#f7f9fb",
                "on-tertiary-container": "#0094a6",
                "primary": "#000613",
                "on-error-container": "#93000a",
                "on-primary-fixed-variant": "#2f486a"
              },
              fontFamily: {
                "headline": ["Manrope"],
                "body": ["Inter"],
                "label": ["Inter"]
              },
              borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
            },
          },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, rgba(0, 31, 63, 0.95) 0%, rgba(0, 104, 117, 0.4) 100%);
        }

        .text-glow {
            text-shadow: 0 0 20px rgba(0, 229, 255, 0.3);
        }

        header {
            position: sticky !important;
            z-index: 9999 !important;
        }

        .group:hover .group-hover\:visible {
            visibility: visible !important;
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface">
    <!-- Menu điều hướng các trang-->
    <header class="sticky top-0 z-[9999] bg-white border-b border-gray-100 shadow-sm">
        <div class="container mx-auto px-4 h-20 flex items-center justify-between relative">

            <div class="flex-1 flex justify-start items-center gap-2">
                <div class="w-10 h-10 bg-brand-navy rounded-xl flex items-center justify-center">
                    <svg class="h-6 w-6 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </div>
                <span class="text-xl font-bold tracking-tight text-brand-navy">AuraHome</span>
            </div>

            <nav class="hidden lg:flex items-center justify-center space-x-8 text-sm font-medium h-full">
                <div class="relative group h-full flex items-center">
                    <button class="flex items-center gap-1 hover:text-brand-cyan transition-colors py-8 outline-none font-bold">
                        Thiết Bị Thông Minh
                        <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>

                    <div class="absolute left-0 top-full w-72 bg-white rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.2)] border border-gray-100 invisible opacity-0 translate-y-4 group-hover:!visible group-hover:!opacity-100 group-hover:!translate-y-0 transition-all duration-300 z-[10000] overflow-hidden">

                        <div class="p-3">
                            <ul class="space-y-1">
                                <li>
                                    <a href="/SanPhams?category=1" class="flex items-center justify-between px-3 py-3 text-gray-600 hover:bg-slate-50 hover:text-brand-cyan rounded-xl transition-all group/link">
                                        <span class="flex items-center gap-3 font-semibold">
                                            <i class="fa-solid fa-lightbulb text-indigo-500 w-5 text-center text-lg"></i>
                                            Chiếu sáng thông minh
                                        </span>
                                        <i class="fa-solid fa-chevron-right text-[10px] opacity-0 group-hover/link:opacity-100 transition-opacity"></i>
                                    </a>
                                </li>
                                <li>
                                    <a href="/SanPhams?category=2" class="flex items-center justify-between px-3 py-3 text-gray-600 hover:bg-slate-50 hover:text-brand-cyan rounded-xl transition-all group/link">
                                        <span class="flex items-center gap-3 font-semibold">
                                            <i class="fa-solid fa-shield-halved text-emerald-500 w-5 text-center text-lg"></i>
                                            An ninh & Camera
                                        </span>
                                        <i class="fa-solid fa-chevron-right text-[10px] opacity-0 group-hover/link:opacity-100 transition-opacity"></i>
                                    </a>
                                </li>
                                <li>
                                    <a href="/SanPhams?category=3" class="flex items-center justify-between px-3 py-3 text-gray-600 hover:bg-slate-50 hover:text-brand-cyan rounded-xl transition-all group/link">
                                        <span class="flex items-center gap-3 font-semibold">
                                            <i class="fa-solid fa-temperature-half text-orange-500 w-5 text-center text-lg"></i>
                                            Khí hậu & Nhiệt độ
                                        </span>
                                        <i class="fa-solid fa-chevron-right text-[10px] opacity-0 group-hover/link:opacity-100 transition-opacity"></i>
                                    </a>
                                </li>
                                <li>
                                    <a href="/SanPhams?category=4" class="flex items-center justify-between px-3 py-3 text-gray-600 hover:bg-slate-50 hover:text-brand-cyan rounded-xl transition-all group/link">
                                        <span class="flex items-center gap-3 font-semibold">
                                            <i class="fa-solid fa-plug text-rose-500 w-5 text-center text-lg"></i>
                                            Phụ kiện Smart
                                        </span>
                                        <i class="fa-solid fa-chevron-right text-[10px] opacity-0 group-hover/link:opacity-100 transition-opacity"></i>
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <div class="bg-gray-50/80 p-3.5 text-center border-t border-gray-100">
                            <a href="/SanPhams" class="text-[11px] font-bold text-gray-400 hover:text-brand-cyan uppercase tracking-[0.2em] transition-colors flex items-center justify-center gap-2">
                                Xem tất cả thiết bị
                                <i class="fa-solid fa-arrow-right text-[10px]"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <a class="hover:text-brand-cyan transition-colors font-bold text-gray-600" href="/TinTucs">Tin Tức</a>
                <a class="hover:text-brand-cyan transition-colors font-bold text-gray-600" href="/HuongDanSuDungs">Hướng Dẫn Sử Dụng</a>
            </nav>
            <div class="flex-1 flex items-center justify-end gap-6">

                <a class="hidden xl:flex items-center gap-1.5 text-sm font-medium text-brand-navy hover:text-brand-cyan transition-colors whitespace-nowrap ml-2 pl-6" href="#">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        <path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1h2m4-1v-4a1 1 0 00-1-1h-3m-1 0v6m4-1h1a1 1 0 001-1v-2l-2-3h-3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                    Tra cứu đơn hàng
                </a>

                <div class="hidden xl:flex items-center relative ml-4">
                    <input class="pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all w-48 focus:w-64 outline-none text-gray-700" placeholder="Tìm kiếm sản phẩm..." type="text" />
                    <svg class="h-5 w-5 text-gray-400 absolute left-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </div>

                <div class="flex items-center gap-4 pl-4 ml-2">
                    <button class="text-brand-navy hover:text-brand-cyan transition-colors" title="Account">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                    </button>
                    <button class="text-brand-navy hover:text-brand-cyan transition-colors relative" title="Cart">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                        <span class="absolute -top-1 -right-1 bg-brand-cyan text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full">0</span>
                    </button>
                </div>

            </div>
        </div>
    </header>
    <main class="pt-0 relative">
        <!-- Banner -->
        <section class="relative h-[921px] flex items-center shadow-inner">
            <div class="absolute inset-0 z-0">
                <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?q=80&w=2075&auto=format&fit=crop" alt="AuraHome Smart Villa" />
                <div class="absolute inset-0 hero-gradient"></div>
            </div>
            <div class="relative z-10 max-w-7xl mx-auto px-8 w-full">
                <div class="max-w-3xl">
                    <h1 class="text-6xl md:text-8xl font-headline font-extrabold text-white leading-tight tracking-tighter mb-6">Kỷ Nguyên<br /><span class="text-secondary-container text-glow" style="font-size: 6rem; letter-spacing: -0.05em;">Kết Nối</span></h1>
                    <p class="text-xl text-primary-fixed-dim font-light mb-10 max-w-xl leading-relaxed text-justify">
                        Nâng tầm không gian sống với hệ điều hành tàng hình đầu tiên cho ngôi nhà của bạn. AuraHome tự động điều chỉnh môi trường để hòa nhịp cùng cuộc sống nhờ hệ thống AI vượt trội.
                    </p>
                    <div class="flex gap-4">
                        <button class="bg-gradient-to-r from-secondary to-secondary-container text-on-primary font-bold px-10 py-5 rounded-md hover:scale-105 transition-transform">Khám phá hệ thống</button>
                        <button class="backdrop-blur-md bg-white/10 border border-white/20 text-white font-bold px-10 py-5 rounded-md hover:bg-white/20 transition-all">Trãi nghiệm thực tế</button>
                    </div>
                </div>
            </div>
        </section>
        <!-- Thông tin -->
        <section class="py-20 bg-surface-container-low">
            <div class="max-w-7xl mx-auto px-8">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-8">

                    <div class="group p-8 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-2xl hover:shadow-[#00E5FF]/15 hover:border-[#00E5FF]/40 transition-all duration-500 relative overflow-hidden cursor-pointer">

                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#00E5FF]/10 rounded-full blur-3xl group-hover:bg-[#00E5FF]/20 transition-all duration-500"></div>

                        <div class="relative z-10">
                            <div class="w-14 h-14 bg-[#001F3F] rounded-2xl flex items-center justify-center mb-6 shadow-md group-hover:-translate-y-1 group-hover:shadow-lg group-hover:shadow-[#001F3F]/30 transition-all duration-300">
                                <span class="material-symbols-outlined text-[#00E5FF] text-3xl" data-icon="security">security</span>
                            </div>

                            <h3 class="font-bold text-[#001F3F] text-xl mb-3 group-hover:text-[#00E5FF] transition-colors duration-300">
                                An ninh Thông minh
                            </h3>

                            <p class="text-gray-500 text-sm leading-relaxed text-justify group-hover:text-gray-600 transition-colors duration-300">
                                Tiên đoán rủi ro và bảo vệ tuyệt đối với hệ thống nhận diện khuôn mặt được mã hóa nhiều lớp.
                            </p>
                        </div>

                        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#00E5FF] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>

                    <div class="group p-8 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-2xl hover:shadow-[#00E5FF]/15 hover:border-[#00E5FF]/40 transition-all duration-500 relative overflow-hidden cursor-pointer">
                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#00E5FF]/10 rounded-full blur-3xl group-hover:bg-[#00E5FF]/20 transition-all duration-500"></div>

                        <div class="relative z-10">
                            <div class="w-14 h-14 bg-[#001F3F] rounded-2xl flex items-center justify-center mb-6 shadow-md group-hover:-translate-y-1 group-hover:shadow-lg group-hover:shadow-[#001F3F]/30 transition-all duration-300">
                                <span class="material-symbols-outlined text-[#00E5FF] text-3xl" data-icon="energy_savings_leaf">energy_savings_leaf</span>
                            </div>

                            <h3 class="font-bold text-[#001F3F] text-xl mb-3 group-hover:text-[#00E5FF] transition-colors duration-300">
                                Tối ưu Năng lượng
                            </h3>

                            <p class="text-gray-500 text-sm leading-relaxed text-justify group-hover:text-gray-600 transition-colors duration-300">
                                Quản lý điện năng qua mạng lưới nơ-ron, giúp cắt giảm đến 45% lượng điện hao phí mỗi ngày.
                            </p>
                        </div>

                        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#00E5FF] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>

                    <div class="group p-8 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-2xl hover:shadow-[#00E5FF]/15 hover:border-[#00E5FF]/40 transition-all duration-500 relative overflow-hidden cursor-pointer">
                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#00E5FF]/10 rounded-full blur-3xl group-hover:bg-[#00E5FF]/20 transition-all duration-500"></div>

                        <div class="relative z-10">
                            <div class="w-14 h-14 bg-[#001F3F] rounded-2xl flex items-center justify-center mb-6 shadow-md group-hover:-translate-y-1 group-hover:shadow-lg group-hover:shadow-[#001F3F]/30 transition-all duration-300">
                                <span class="material-symbols-outlined text-[#00E5FF] text-3xl" data-icon="psychology">psychology</span>
                            </div>

                            <h3 class="font-bold text-[#001F3F] text-xl mb-3 group-hover:text-[#00E5FF] transition-colors duration-300">
                                Tích hợp AI
                            </h3>

                            <p class="text-gray-500 text-sm leading-relaxed text-justify group-hover:text-gray-600 transition-colors duration-300">
                                Trí tuệ nhân tạo xuyên suốt các thiết bị, thấu hiểu và đáp ứng nhu cầu của bạn một cách liền mạch.
                            </p>
                        </div>

                        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#00E5FF] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>

                    <div class="group p-8 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-2xl hover:shadow-[#00E5FF]/15 hover:border-[#00E5FF]/40 transition-all duration-500 relative overflow-hidden cursor-pointer">
                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-[#00E5FF]/10 rounded-full blur-3xl group-hover:bg-[#00E5FF]/20 transition-all duration-500"></div>

                        <div class="relative z-10">
                            <div class="w-14 h-14 bg-[#001F3F] rounded-2xl flex items-center justify-center mb-6 shadow-md group-hover:-translate-y-1 group-hover:shadow-lg group-hover:shadow-[#001F3F]/30 transition-all duration-300">
                                <span class="material-symbols-outlined text-[#00E5FF] text-3xl" data-icon="settings_input_component">settings_input_component</span>
                            </div>

                            <h3 class="font-bold text-[#001F3F] text-xl mb-3 group-hover:text-[#00E5FF] transition-colors duration-300">
                                Tự động hóa Nhà ở
                            </h3>

                            <p class="text-gray-500 text-sm leading-relaxed text-justify group-hover:text-gray-600 transition-colors duration-300">
                                Thiết lập các kịch bản kích hoạt thông minh dựa trên sự hiện diện và dữ liệu môi trường.
                            </p>
                        </div>

                        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#00E5FF] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    
                </div>
            </div>
        </section>
        <!-- Giới thiệu sản phẩm -->
       <section class="py-16 bg-surface">
    <div class="max-w-7xl mx-auto px-8">
                <div class="mb-10">
                    <span class="flex items-center gap-2 text-[#00E5FF] font-bold tracking-[0.2em] text-sm uppercase mb-2">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
                        Hệ sinh thái thiết bị AI tiên tiến nhất
                    </span>

                    <h2 class="text-5xl font-extrabold tracking-tighter mt-2 text-[#001F3F]">
                        Sản Phẩm Hot Sale
                    </h2>
                </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            @if (Model.SanPhams != null && Model.SanPhams.Any())
            {
                // Dùng .Take(3) để giới hạn vòng lặp chỉ chạy qua 3 sản phẩm đầu tiên
                foreach (var product in Model.SanPhams.Take(3))
                {
                    <div class="group cursor-pointer">
                        <div class="aspect-[4/5] overflow-hidden rounded-xl mb-6 bg-surface-container">
                            <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                 alt="@product.TenSanPham"
                                         src="~/img/@product.HinhAnh" />
                        </div>
                        <div class="flex justify-between items-start">
                            <div>
                                <h4 class="font-headline font-bold text-2xl">@product.TenSanPham</h4>
                                <p class="text-on-surface-variant text-sm mt-1">@product.MoTa</p>
                            </div>
                            <span class="text-xl font-bold font-headline">@product.GiaBan.ToString("C0", new System.Globalization.CultureInfo("en-US"))</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-3 text-center text-gray-500 py-10">
                    Chưa có sản phẩm nào được hiển thị.
                </div>
            }
        </div>

        @if (Model.SanPhams != null && Model.SanPhams.Count() > 3)
        {
            <div class="mt-14 flex justify-center">
                        <a asp-controller="Customers" asp-action="Index" class="px-8 py-3 rounded-full border-2 border-secondary text-secondary font-bold hover:bg-secondary hover:text-white transition-colors flex items-center gap-2">
                    Xem thêm sản phẩm
                    <span class="material-symbols-outlined">expand_more</span>
                </a>
            </div>
        }
    </div>
</section>
        <!-- Thông tin 2 -->
        <section class="mt-0 bg-primary-container text-white overflow-hidden">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center">
                <div class="w-full md:w-1/2 p-12 md:p-24 order-2 md:order-1">
                    <h2 class="text-5xl font-headline font-bold mb-8 leading-tight">Cơ sở Hạ tầng Thông minh</h2>
                    <ul class="space-y-8">
                        <li class="flex gap-4">
                            <span class="material-symbols-outlined text-secondary-container" data-icon="bolt">bolt</span>
                            <div>
                                <h5 class="font-bold text-lg">Phản hồi không độ trễ</h5>
                                <p class="text-on-primary-container text-sm">Công nghệ Edge computing giúp ngôi nhà phản ứng trong chưa đầy 15ms trước mọi biến đổi môi trường.</p>
                            </div>
                        </li>
                        <li class="flex gap-4">
