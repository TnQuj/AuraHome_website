@model IEnumerable<AISmartHome.Models.HuongDanSuDung>

@{
    // Đảm bảo dòng này khớp với tên file Layout Admin của bạn
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Hướng dẫn sử dụng";
}

<div class="p-4 sm:p-6 bg-slate-50 min-h-screen">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Hướng dẫn sử dụng</h2>
            <p class="text-sm text-slate-500">Danh sách tài liệu hướng dẫn vận hành thiết bị SmartHome</p>
        </div>
        <a asp-action="Create" class="inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg shadow-sm transition-all">
            <i class="fa-solid fa-plus mr-2"></i> Thêm hướng dẫn
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse whitespace-nowrap">
                <thead>
                    <tr class="bg-slate-800 text-white text-[11px] uppercase tracking-wider">
                        <th class="px-6 py-4 font-bold">Tiêu đề & Nội dung</th>
                        <th class="px-6 py-4 font-bold">Sản phẩm</th>
                        <th class="px-6 py-4 font-bold text-center">Video</th>
                        <th class="px-6 py-4 font-bold text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0">
                                        <i class="fa-solid fa-file-lines text-xs"></i>
                                    </div>
                                    <div class="max-w-xs md:max-w-sm overflow-hidden">
                                        <div class="text-sm font-bold text-slate-700 truncate">@item.TieuDe</div>
                                        <div class="text-xs text-slate-400 truncate">@item.NoiDung</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600 font-medium">
                                <span class="px-2 py-1 bg-blue-50 text-blue-700 rounded text-[10px] font-bold border border-blue-100">
                                    @(item.MaSanPhamNavigation?.TenSanPham ?? "Chưa gắn SP")
                                </span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                @if (!string.IsNullOrEmpty(item.VideoUrl))
                                {
                                    <a href="@item.VideoUrl" target="_blank" class="text-rose-500 hover:scale-110 inline-block transition-transform" title="Xem trên Youtube">
                                        <i class="fa-brands fa-youtube text-xl"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-slate-300"><i class="fa-solid fa-video-slash"></i></span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end items-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.MaHuongDan" class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:text-indigo-600 hover:border-indigo-600 transition-all">
                                        <i class="fa-solid fa-pen-to-square text-xs"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaHuongDan" class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:text-emerald-600 hover:border-emerald-600 transition-all">
                                        <i class="fa-solid fa-eye text-xs"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaHuongDan" class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:text-rose-600 hover:border-rose-600 transition-all">
                                        <i class="fa-solid fa-trash text-xs"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="p-12 text-center text-slate-400">
                <i class="fa-solid fa-folder-open text-4xl mb-3 block"></i>
                <p class="text-sm">Chưa có bài hướng dẫn nào trong hệ thống.</p>
            </div>
        }
    </div>
</div>