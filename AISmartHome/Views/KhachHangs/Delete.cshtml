@model AISmartHome.Models.KhachHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xác nhận xóa Khách hàng";
}

<div class="p-6 bg-slate-50 min-h-screen text-slate-700">
    <div class="max-w-3xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"></path></svg>
                    Gỡ bỏ Khách hàng
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Cảnh báo: Hành động này sẽ xóa vĩnh viễn hồ sơ người dùng.</p>
            </div>
            <a asp-action="Index" class="text-gray-400 hover:text-gray-600 font-medium transition-colors">
                Hủy và Quay lại
            </a>
        </div>

        <div class="bg-white rounded-3xl shadow-xl border-2 border-red-50 overflow-hidden">

            <div class="bg-red-50 border-b border-red-100 px-6 py-5 flex items-center gap-4">
                <div class="w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-red-500">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                <div>
                    <h3 class="font-black text-red-900 text-lg uppercase">Xác nhận xóa dữ liệu?</h3>
                    <p class="text-sm text-red-600/80">Hồ sơ của <strong>@Model.TenKhachHang</strong> sẽ không thể khôi phục sau khi xác nhận.</p>
                </div>
            </div>

            <div class="p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                    <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Họ tên khách hàng</span>
                        <p class="text-[#001F3F] font-bold text-lg">@Model.TenKhachHang</p>
                    </div>

                    <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Số điện thoại</span>
                        <p class="text-[#001F3F] font-bold">@Model.SoDienThoai</p>
                    </div>

                    <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Email đăng ký</span>
                        <p class="text-[#001F3F] font-medium italic">@Model.Email</p>
                    </div>

                    <div class="p-4 rounded-2xl bg-slate-50 border border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Địa chỉ</span>
                        <p class="text-sm text-slate-600 truncate">@Model.DiaChi</p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row items-center gap-4">
                    <form asp-action="Delete" class="w-full sm:w-auto flex-1">
                        <input type="hidden" asp-for="MaKhachHang" />
                        <button type="submit" class="w-full py-3.5 rounded-2xl font-black text-white bg-red-600 hover:bg-red-700 shadow-lg shadow-red-200 transition-all flex items-center justify-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            XÓA KHÁCH HÀNG NÀY
                        </button>
                    </form>

                    <a asp-action="Index" class="w-full sm:w-auto px-8 py-3.5 rounded-2xl font-bold text-gray-500 bg-gray-100 hover:bg-gray-200 transition-all text-center">
                        Quay lại trang chủ
                    </a>
                </div>
            </div>

            <div class="bg-slate-50 px-8 py-4 border-t border-slate-100 text-center">
                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest flex items-center justify-center gap-2">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                    Thao tác yêu cầu quyền quản trị viên cao cấp
                </p>
            </div>
        </div>
    </div>
</div>