@model AISmartHome.Models.KhachHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa Khách hàng";
}

<div class="p-6 bg-slate-50 min-h-screen flex items-center justify-center">
    <div class="max-w-xl w-full bg-white rounded-3xl shadow-xl border border-rose-100 overflow-hidden text-center">

        <div class="bg-rose-50 p-8 flex flex-col items-center">
            <div class="w-20 h-20 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center text-4xl mb-4">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <h2 class="text-2xl font-black text-slate-800">Xác nhận xóa khách hàng?</h2>
            <p class="text-rose-500 mt-2 font-medium">Hành động này không thể hoàn tác. Dữ liệu giỏ hàng và voucher của khách cũng sẽ bị xóa bỏ.</p>
        </div>

        <div class="p-8 text-left bg-white border-y border-slate-100">
            <div class="bg-slate-50 p-4 rounded-xl border border-slate-200">
                <h3 class="text-lg font-bold text-[#001F3F] mb-1">@Model.TenKhachHang</h3>
                <p class="text-sm text-slate-500 mb-3">@Model.Email | @Model.SoDienThoai</p>
                <div class="flex gap-3">
                    <span class="px-3 py-1 bg-amber-100 text-amber-700 font-bold text-xs rounded-lg uppercase">
                        Hạng: @Model.HangThanhVien
                    </span>
                    <span class="px-3 py-1 bg-blue-100 text-blue-700 font-bold text-xs rounded-lg uppercase">
                        @Model.DiemTichLuy Điểm
                    </span>
                </div>
            </div>
        </div>

        <div class="px-8 py-6 bg-slate-50 flex gap-4 justify-center">
            <form asp-action="Delete" class="flex gap-4 w-full">
                <input type="hidden" asp-for="MaKhachHang" />
                <button type="submit" class="flex-1 bg-rose-500 hover:bg-rose-600 text-white py-3 rounded-xl font-bold transition-all shadow-lg shadow-rose-500/30">
                    Có, Xóa vĩnh viễn
                </button>
                <a asp-action="Index" class="flex-1 bg-slate-200 hover:bg-slate-300 text-slate-700 py-3 rounded-xl font-bold transition-all text-center">
                    Hủy bỏ
                </a>
            </form>
        </div>
    </div>
</div>