@model AISmartHome.Models.KhachHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Khách hàng";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">

        <div class="bg-[#001F3F] p-8 text-white flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 bg-[#00E5FF] text-[#001F3F] text-2xl font-black rounded-full flex items-center justify-center shadow-lg">
                    @(string.IsNullOrEmpty(Model.TenKhachHang) ? "?" : Model.TenKhachHang.Substring(0, 1).ToUpper())
                </div>
                <div>
                    <h2 class="text-2xl font-bold">@Model.TenKhachHang</h2>
                    <p class="text-[#00E5FF] flex items-center gap-2 mt-1">
                        <i class="fa-solid fa-crown"></i> Hạng: @Model.HangThanhVien
                        <span class="text-white/60 ml-2">|</span>
                        <i class="fa-solid fa-star text-yellow-400 ml-2"></i> @Model.DiemTichLuy điểm
                    </p>
                </div>
            </div>
        </div>

        <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
                <div>
                    <label class="text-sm text-slate-400 font-semibold uppercase tracking-wider">Số điện thoại</label>
                    <p class="text-lg text-slate-800 font-medium">@(string.IsNullOrEmpty(Model.SoDienThoai) ? "Chưa cập nhật" : Model.SoDienThoai)</p>
                </div>
                <div>
                    <label class="text-sm text-slate-400 font-semibold uppercase tracking-wider">Email</label>
                    <p class="text-lg text-slate-800 font-medium">@(string.IsNullOrEmpty(Model.Email) ? "Chưa cập nhật" : Model.Email)</p>
                </div>
            </div>

            <div class="space-y-4">
                <div>
                    <label class="text-sm text-slate-400 font-semibold uppercase tracking-wider">Địa chỉ liên hệ</label>
                    <p class="text-lg text-slate-800 font-medium leading-relaxed">
                        @(string.IsNullOrEmpty(Model.DiaChi) ? "Chưa cập nhật" : Model.DiaChi)
                    </p>
                </div>
            </div>
        </div>

        <div class="px-8 py-5 bg-slate-50 border-t border-slate-100 flex gap-3">
            <a asp-action="Edit" asp-route-id="@Model?.MaKhachHang" class="bg-emerald-500 hover:bg-emerald-600 text-white px-6 py-2.5 rounded-xl font-bold transition-all">
                Chỉnh sửa
            </a>
            <a asp-action="Index" class="bg-slate-200 hover:bg-slate-300 text-slate-700 px-6 py-2.5 rounded-xl font-bold transition-all">
                Quay lại
            </a>
        </div>
    </div>
</div>