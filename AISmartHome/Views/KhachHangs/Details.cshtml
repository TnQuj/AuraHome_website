@model AISmartHome.Models.KhachHang

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Khách hàng";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
                    Hồ sơ chi tiết Khách hàng
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Xem toàn bộ thông tin cá nhân và lịch sử liên hệ</p>
            </div>
            <div class="flex gap-3">
                <a asp-action="Index" class="flex items-center gap-2 text-gray-600 bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
                    Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model.MaKhachHang" class="flex items-center gap-2 text-white bg-[#001F3F] px-4 py-2 rounded-xl font-medium hover:bg-[#002b5a] transition-colors shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    Chỉnh sửa hồ sơ
                </a>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">

            <div class="h-32 bg-gradient-to-r from-[#001F3F] to-[#003366] relative">
                <div class="absolute -bottom-12 left-8">
                    <div class="w-24 h-24 rounded-2xl bg-[#00E5FF] border-4 border-white shadow-md flex items-center justify-center text-[#001F3F] text-3xl font-black">
                        @Model.TenKhachHang.Substring(0, 1).ToUpper()
                    </div>
                </div>
            </div>

            <div class="pt-16 p-8">
                <div class="mb-8">
                    <h2 class="text-2xl font-bold text-[#001F3F]">@Model.TenKhachHang</h2>
                    <p class="text-gray-400 text-sm">Mã định danh: <span class="font-mono">#KH-@Model.MaKhachHang</span></p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="p-3 bg-blue-50 rounded-xl text-blue-600">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase">Số điện thoại</p>
                                <p class="text-lg font-semibold text-[#001F3F]">@Model.SoDienThoai</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="p-3 bg-indigo-50 rounded-xl text-indigo-600">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase">Email</p>
                                <p class="text-lg font-semibold text-[#001F3F]">@Model.Email</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="p-3 bg-rose-50 rounded-xl text-rose-600">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase">Địa chỉ thường trú</p>
                                <p class="text-base text-[#001F3F] leading-relaxed">@Model.DiaChi</p>
                            </div>
                        </div>

                        <div class="p-4 bg-slate-50 rounded-2xl border border-dashed border-slate-200">
                            <p class="text-xs text-gray-400 italic">Lưu ý: Thông tin khách hàng được bảo mật theo tiêu chuẩn AI Smart Home.</p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="bg-slate-50 px-8 py-4 border-t border-gray-100 flex justify-between items-center text-xs text-gray-400">
                <span>Hệ thống quản lý dữ liệu tập trung</span>
                <span>Ngày cập nhật: @DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    </div>
</div>