@model AISmartHome.Models.NhanVienViewModel

@{
    ViewData["Title"] = "Thêm mới Nhân viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Thay bằng _LayoutAdmin nếu bạn đang dùng layout riêng
}

<main class="w-full min-h-[75vh] py-12 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-black text-brand-navy uppercase tracking-wide">Thêm Mới Nhân Viên</h1>
                <p class="text-slate-500 text-sm mt-1">Cập nhật thông tin cá nhân và cấp tài khoản hệ thống</p>
            </div>
            <a asp-action="Index" class="text-slate-500 hover:text-brand-cyan transition-colors font-medium flex items-center gap-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
            </a>
        </div>

        <form asp-action="Create" method="post" class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">

            <div asp-validation-summary="ModelOnly" class="bg-rose-50 text-rose-500 px-8 py-4 text-sm font-medium border-b border-rose-100"></div>

            <div class="p-8 grid grid-cols-1 lg:grid-cols-2 gap-12">

                <div class="space-y-6">
                    <div class="flex items-center gap-3 border-b border-slate-100 pb-3">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-500 flex items-center justify-center">
                            <i class="fa-solid fa-address-card"></i>
                        </div>
                        <h3 class="font-bold text-slate-800 uppercase tracking-wide">1. Thông tin cá nhân</h3>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="TenNhanVien" class="block text-sm font-bold text-slate-700">Họ và tên *</label>
                        <input asp-for="TenNhanVien" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all bg-slate-50 focus:bg-white" placeholder="Nhập họ tên đầy đủ" />
                        <span asp-validation-for="TenNhanVien" class="text-rose-500 text-xs font-medium"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="SoDienThoai" class="block text-sm font-bold text-slate-700">Số điện thoại *</label>
                        <input asp-for="SoDienThoai" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all bg-slate-50 focus:bg-white" placeholder="VD: 0987654321" />
                        <span asp-validation-for="SoDienThoai" class="text-rose-500 text-xs font-medium"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="DiaChi" class="block text-sm font-bold text-slate-700">Địa chỉ liên hệ</label>
                        <textarea asp-for="DiaChi" rows="2" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/20 outline-none transition-all bg-slate-50 focus:bg-white" placeholder="Nhập địa chỉ cư trú..."></textarea>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="flex items-center gap-3 border-b border-slate-100 pb-3">
                        <div class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                        <h3 class="font-bold text-slate-800 uppercase tracking-wide">2. Tài khoản hệ thống</h3>
                    </div>

                    <div class="p-6 bg-cyan-50/50 border border-cyan-100 rounded-2xl space-y-6">
                        <div class="space-y-2">
                            <label asp-for="TenDangNhap" class="block text-sm font-bold text-slate-700">Tên đăng nhập *</label>
                            <div class="relative">
                                <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                <input asp-for="TenDangNhap" autocomplete="off" class="w-full pl-10 pr-4 py-3 rounded-xl border border-white focus:border-brand-cyan shadow-sm outline-none transition-all" placeholder="Tên dùng để đăng nhập" />
                            </div>
                            <span asp-validation-for="TenDangNhap" class="text-rose-500 text-xs font-medium"></span>
                        </div>

                        <div class="space-y-2">
                            <label asp-for="MatKhau" class="block text-sm font-bold text-slate-700">Mật khẩu cấp phát *</label>
                            <div class="relative">
                                <i class="fa-solid fa-key absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                <input asp-for="MatKhau" type="password" autocomplete="new-password" class="w-full pl-10 pr-4 py-3 rounded-xl border border-white focus:border-brand-cyan shadow-sm outline-none transition-all" placeholder="Tối thiểu 6 ký tự" />
                            </div>
                            <span asp-validation-for="MatKhau" class="text-rose-500 text-xs font-medium"></span>
                        </div>

                        <p class="text-xs text-slate-500 italic">
                            <i class="fa-solid fa-circle-info text-brand-cyan mr-1"></i>
                            Tài khoản sẽ được tự động gắn quyền "Nhân viên" và kích hoạt ngay sau khi lưu.
                        </p>
                    </div>
                </div>

            </div>

            <div class="p-6 bg-slate-50 border-t border-slate-100 flex justify-end gap-4">
                <a asp-action="Index" class="px-8 py-3 bg-white border border-slate-200 text-slate-600 font-bold rounded-xl hover:bg-slate-100 transition-colors">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-8 py-3 bg-brand-cyan text-white font-bold rounded-xl hover:bg-cyan-600 transition-all shadow-lg shadow-cyan-600/30 flex items-center gap-2">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu Nhân Viên
                </button>
            </div>
        </form>

    </div>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}