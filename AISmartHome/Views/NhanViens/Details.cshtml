@model AISmartHome.Models.NhanVien

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Hồ sơ Nhân viên";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
                    Hồ sơ chi tiết Nhân sự
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Xem thông tin định danh và tài khoản hệ thống</p>
            </div>
            <div class="flex gap-3">
                <a asp-action="Index" class="flex items-center gap-2 text-gray-600 bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
                    Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model.MaNhanVien" class="flex items-center gap-2 text-white bg-[#001F3F] px-4 py-2 rounded-xl font-medium hover:bg-[#002b5a] transition-colors shadow-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                    Sửa hồ sơ
                </a>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">

            <div class="h-32 bg-gradient-to-r from-[#001F3F] to-[#004d99] relative">
                <div class="absolute -bottom-12 left-8 flex items-end gap-6">
                    <div class="w-24 h-24 rounded-2xl bg-white border-4 border-white shadow-xl flex items-center justify-center text-[#001F3F] text-3xl font-black overflow-hidden bg-gradient-to-br from-[#00E5FF] to-blue-500">
                        @Model.TenNhanVien.Substring(0, 1).ToUpper()
                    </div>
                </div>
            </div>

            <div class="pt-16 p-8">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-[#001F3F]">@Model.TenNhanVien</h2>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-[#00E5FF]/10 text-[#001F3F] border border-[#00E5FF]/20 mt-1">
                            Nhân viên chính thức
                        </span>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Mã nhân sự</p>
                        <p class="text-lg font-mono font-bold text-blue-600">#NV-@Model.MaNhanVien</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <div class="space-y-6">
                        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-tighter">Thông tin cơ bản</h4>

                        <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
                            <div class="w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center text-blue-500">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400">Số điện thoại</p>
                                <p class="font-bold text-[#001F3F]">@Model.SoDienThoai</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
                            <div class="w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center text-purple-500">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400">Tài khoản hệ thống</p>
                                <p class="font-mono font-bold text-purple-700">@Model.MaTaiKhoanNavigation?.MaTaiKhoan</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-tighter">Địa chỉ làm việc & Cư trú</h4>

                        <div class="flex items-start gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
                            <div class="w-10 h-10 rounded-xl bg-white shadow-sm flex items-center justify-center text-rose-500 shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400">Địa chỉ hiện tại</p>
                                <p class="text-sm font-medium text-[#001F3F] leading-relaxed">@Model.DiaChi</p>
                            </div>
                        </div>

                        <div class="p-4 rounded-2xl border-2 border-dashed border-slate-100 flex flex-col justify-center items-center text-center">
                            <p class="text-[10px] text-gray-400 font-bold uppercase mb-1">Xác minh nhân sự</p>
                            <div class="flex items-center text-emerald-500 gap-1 font-bold text-sm">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                Hồ sơ đã được duyệt
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="bg-slate-50 px-8 py-4 border-t border-gray-100 flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest">
                <span>Dữ liệu nội bộ - Bảo mật tuyệt đối</span>
                <span>Ngày truy xuất: @DateTime.Now.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    </div>
</div>