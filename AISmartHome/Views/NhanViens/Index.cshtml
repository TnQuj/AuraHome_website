@model IEnumerable<AISmartHome.Models.NhanVien>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Nhân viên";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-6xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    Đội ngũ Nhân viên
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Quản lý thông tin và tài khoản truy cập hệ thống</p>
            </div>

            <a asp-action="Create" class="flex items-center gap-2 bg-[#001F3F] text-white px-5 py-2.5 rounded-xl font-bold hover:bg-[#002b5a] transition-all shadow-lg shadow-blue-900/10">
                <svg class="w-5 h-5 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
                Thêm nhân viên
            </a>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-[#001F3F] text-white">
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Nhân viên</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Số điện thoại</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Địa chỉ</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider">Tài khoản</th>
                            <th class="px-6 py-4 text-sm font-semibold uppercase tracking-wider text-right">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#00E5FF] to-blue-500 flex items-center justify-center text-[#001F3F] font-black shadow-sm">
                                            @item.TenNhanVien.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="font-bold text-[#001F3F]">@item.TenNhanVien</div>
                                            <div class="text-[10px] text-gray-400 uppercase font-bold tracking-tighter">Mã NV: #@item.MaNhanVien</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2 text-sm text-slate-700 font-medium">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                        @item.SoDienThoai
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    <span class="line-clamp-1" title="@item.DiaChi">@item.DiaChi</span>
                                </td>
                                <td class="px-6 py-4 text-sm font-mono font-bold text-blue-600">
                                    @Html.DisplayFor(modelItem => item.MaTaiKhoanNavigation.MaTaiKhoan)
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex justify-end gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.MaNhanVien" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.MaNhanVien" class="p-2 text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaNhanVien" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="py-20 text-center">
                    <p class="text-gray-400 italic">Hiện tại chưa có nhân viên nào trong danh sách.</p>
                </div>
            }
        </div>

        <div class="mt-4 flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest">
            <p>TỔNG SỐ NHÂN SỰ: @Model.Count()</p>
            <p>Hệ thống AI Smart Home Admin</p>
        </div>
    </div>
</div>