@model AISmartHome.Models.SanPham

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Sản phẩm mới";
}

<style>
    /* Hiệu ứng viền sáng (Glow) cho nút Cyan */
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }

    /* Màu tùy chỉnh cho input khi focus */
    .input-focus-cyan:focus {
        outline: none;
        border-color: #00E5FF;
        box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.2);
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.5v15m7.5-7.5h-15"></path></svg>
                    Nhập Kho Thiết Bị Mới
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Thêm thiết bị AI Smart Home vào cơ sở dữ liệu</p>
            </div>
            <a asp-action="Index" class="flex items-center gap-2 text-[#001F3F] bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Quay lại danh sách
            </a>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-[#001F3F] px-6 py-4 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#00E5FF]/20 flex items-center justify-center">
                    <svg class="w-4 h-4 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h3 class="text-white font-semibold">Nhập thông tin sản phẩm</h3>
            </div>

            <form asp-action="Create" enctype="multipart/form-data" class="p-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium bg-red-50 p-3 rounded-lg"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="md:col-span-2">
                        <label asp-for="TenSanPham" class="block text-sm font-bold text-[#001F3F] mb-2">Tên sản phẩm <span class="text-red-500">*</span></label>
                        <input asp-for="TenSanPham" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white" placeholder="VD: Khóa cửa thông minh AI Smart Lock" required />
                        <span asp-validation-for="TenSanPham" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="MaDanhMuc" class="block text-sm font-bold text-[#001F3F] mb-2">Phân loại danh mục</label>
                        <select asp-for="MaDanhMuc" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white cursor-pointer" asp-items="ViewBag.MaDanhMuc"></select>
                    </div>

                    <div>
                        <label asp-for="SoLuong" class="block text-sm font-bold text-[#001F3F] mb-2">Số lượng nhập kho ban đầu</label>
                        <input asp-for="SoLuong" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white" type="number" min="0" value="0" />
                        <span asp-validation-for="SoLuong" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="GiaBan" class="block text-sm font-bold text-[#001F3F] mb-2">Giá bán (VNĐ)</label>
                        <div class="relative">
                            <input asp-for="GiaBan" class="w-full pl-4 pr-12 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 font-semibold text-blue-600 bg-slate-50 focus:bg-white" type="number" min="0" value="0" />
                            <span class="absolute inset-y-0 right-0 flex items-center pr-4 text-gray-500 font-bold">đ</span>
                        </div>
                        <span asp-validation-for="GiaBan" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="md:col-span-2 mt-2">
                        <div class="bg-[#00E5FF]/5 border border-[#00E5FF]/20 rounded-xl p-5">
                            <h4 class="text-[15px] font-bold text-[#001F3F] mb-4 flex items-center gap-2">
                                <i class="fa-solid fa-images text-[#00E5FF]"></i> Quản lý hình ảnh thiết bị
                            </h4>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Ảnh đại diện (Ảnh bìa) <span class="text-red-500">*</span></label>
                                    <input type="file" name="HinhAnhUpload" accept="image/*" required
                                           class="w-full text-sm text-slate-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-[#001F3F] file:text-white hover:file:bg-[#001F3F]/90 cursor-pointer transition-colors border border-gray-200 rounded-xl bg-white shadow-sm" />
                                </div>

                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Hình ảnh chi tiết (Nhiều góc độ)</label>
                                    <input type="file" name="HinhAnhChiTiet" multiple accept="image/*"
                                           class="w-full text-sm text-slate-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-[#00E5FF]/20 file:text-[#001F3F] hover:file:bg-[#00E5FF]/30 cursor-pointer transition-colors border border-gray-200 rounded-xl bg-white shadow-sm" />
                                    <p class="text-xs text-gray-500 mt-2 font-medium">
                                        <i class="fa-solid fa-circle-info mr-1 text-[#00E5FF]"></i> Nhấn giữ phím <strong>Ctrl</strong> (hoặc Cmd) để chọn nhiều ảnh cùng lúc.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="MoTa" class="block text-sm font-bold text-[#001F3F] mb-2">Mô tả thông số kỹ thuật</label>
                        <textarea asp-for="MoTa" rows="4" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white" placeholder="Nhập mô tả tính năng..."></textarea>
                        <span asp-validation-for="MoTa" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                </div>

                <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-end gap-4">
                    <a asp-action="Index" class="px-6 py-2.5 rounded-xl font-bold text-gray-600 hover:bg-gray-100 transition-colors">
                        Hủy bỏ
                    </a>
                    <button type="submit" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-8 py-2.5 rounded-xl font-bold transition-all duration-300">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4.5v15m7.5-7.5h-15"></path></svg>
                        Tạo Sản Phẩm Mới
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}