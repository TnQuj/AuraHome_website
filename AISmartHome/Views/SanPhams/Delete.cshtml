@model AISmartHome.Models.SanPham

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Xóa Thiết bị";
}

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6">
            <h1 class="text-2xl font-bold text-red-600 flex items-center gap-2">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                Xác nhận Xóa Thiết bị
            </h1>
            <p class="text-sm text-gray-500 mt-1 pl-10">Thao tác này không thể hoàn tác. Vui lòng kiểm tra kỹ thông tin trước khi xóa.</p>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-red-100 overflow-hidden">

            <div class="bg-red-50 border-b border-red-100 p-5 flex items-start gap-3">
                <svg class="w-6 h-6 text-red-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <div>
                    <h3 class="text-red-800 font-bold text-base">Cảnh báo hệ thống!</h3>
                    <p class="text-red-600 text-sm mt-1">Bạn đang chuẩn bị xóa thiết bị <strong class="text-red-800">@Model.TenSanPham</strong> khỏi cơ sở dữ liệu. Toàn bộ dữ liệu liên quan đến thiết bị này có thể bị mất vĩnh viễn.</p>
                </div>
            </div>

            <div class="p-6 flex flex-col md:flex-row gap-8 items-center md:items-start">

                <div class="w-48 h-48 flex-shrink-0 bg-gray-50 rounded-2xl border border-gray-200 p-3 flex items-center justify-center relative shadow-inner">
                    <img src="~/img/@Model.HinhAnh" alt="@Model.TenSanPham" class="max-w-full max-h-full object-contain mix-blend-multiply" onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />
                </div>

                <div class="flex-1 w-full">
                    <h2 class="text-2xl font-bold text-[#001F3F] mb-5">@Model.TenSanPham</h2>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="bg-slate-50 p-4 rounded-xl border border-gray-100">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider mb-1">Mã Sản Phẩm</p>
                            <p class="text-[#001F3F] font-bold text-lg">#@Model.MaSanPham</p>
                        </div>

                        <div class="bg-slate-50 p-4 rounded-xl border border-gray-100">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider mb-1">Danh mục</p>
                            <p class="text-[#001F3F] font-bold text-lg">@(Model.MaDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")</p>
                        </div>

                        <div class="bg-slate-50 p-4 rounded-xl border border-gray-100">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider mb-1">Giá bán</p>
                            <p class="inline-flex items-center text-[#00E5FF] font-bold bg-[#001F3F] px-3 py-1 rounded-lg text-lg">
                                @Model.GiaBan.ToString("#,##0") đ
                            </p>
                        </div>

                        <div class="bg-slate-50 p-4 rounded-xl border border-gray-100">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider mb-1">Số lượng tồn kho</p>
                            <p class="text-[#001F3F] font-bold text-lg">@Model.SoLuong thiết bị</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-gray-50 p-6 border-t border-gray-200">
                <form asp-action="Delete" class="flex flex-col sm:flex-row items-center justify-end gap-4">
                    <input type="hidden" asp-for="MaSanPham" />

                    <a asp-action="Index" class="w-full sm:w-auto text-center px-6 py-2.5 rounded-xl font-bold text-[#001F3F] bg-white border border-gray-300 hover:bg-gray-100 transition-colors">
                        Hủy & Quay lại
                    </a>

                    <button type="submit" class="w-full sm:w-auto flex items-center justify-center gap-2 bg-red-600 text-white px-8 py-2.5 rounded-xl font-bold hover:bg-red-700 transition-all shadow-lg shadow-red-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        Xác nhận Xóa
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>