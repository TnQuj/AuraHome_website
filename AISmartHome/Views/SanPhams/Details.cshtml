@model AISmartHome.Models.SanPham

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Thiết bị";

    // Xử lý gộp tất cả ảnh lại an toàn
    var tatCaHinhAnh = new List<string>();
    if (!string.IsNullOrEmpty(Model?.HinhAnh))
    {
        tatCaHinhAnh.Add(Model.HinhAnh);
    }
    if (Model?.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any())
    {
        tatCaHinhAnh.AddRange(Model.HinhAnhSanPhams.Select(x => x.UrlHinhAnh));
    }
}

<style>
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }

    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-5xl mx-auto">

        <div class="mb-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded shadow-sm" role="alert">
            <p class="font-bold">DEBUG DỮ LIỆU TỪ DATABASE:</p>
            <p>1. Ảnh chính: <strong>@Model?.HinhAnh</strong></p>
            <p>2. Số lượng ảnh phụ (HinhAnhSanPhams): <strong>@(Model?.HinhAnhSanPhams?.Count ?? 0) tấm</strong></p>
            <p>3. Tổng số ảnh gom được vào List: <strong>@tatCaHinhAnh.Count tấm</strong></p>
        </div>

        <div class="mb-6 flex flex-col md:flex-row items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Thông tin Thiết bị AI
                </h1>
            </div>
            <div class="flex items-center gap-3">
                <a asp-action="Index" class="flex items-center gap-2 text-[#001F3F] bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 shadow-sm">
                    Quay lại
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.MaSanPham" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-6 py-2 rounded-xl font-bold transition-all duration-300">
                    Chỉnh sửa
                </a>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden flex flex-col md:flex-row">
            <div class="w-full md:w-2/5 bg-gray-50 p-8 flex flex-col items-center justify-start border-b md:border-b-0 md:border-r border-gray-100 relative">

                <div class="w-full aspect-square bg-white rounded-2xl shadow-sm border border-gray-100 flex items-center justify-center p-4 mb-6 relative group overflow-hidden">
                    <button onclick="changeSlide(-1)" class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/80 shadow text-slate-700 flex items-center justify-center hover:bg-[#00E5FF] hover:text-[#001F3F] transition-all opacity-0 group-hover:opacity-100 z-10 cursor-pointer">
                        <i class="fa-solid fa-chevron-left text-sm"></i>
                    </button>

                    <img id="main-img-detail" src="~/img/@Model?.HinhAnh" alt="@Model?.TenSanPham" class="max-w-full max-h-full object-contain transition-opacity duration-300" onerror="this.src='https://via.placeholder.com/300?text=No+Image'" />

                    <button onclick="changeSlide(1)" class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-white/80 shadow text-slate-700 flex items-center justify-center hover:bg-[#00E5FF] hover:text-[#001F3F] transition-all opacity-0 group-hover:opacity-100 z-10 cursor-pointer">
                        <i class="fa-solid fa-chevron-right text-sm"></i>
                    </button>
                </div>

                @if (tatCaHinhAnh.Count > 1)
                {
                    <div class="w-full">
                        <h4 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3 flex items-center gap-2">
                            <i class="fa-solid fa-images text-sm"></i> Thư viện ảnh (@tatCaHinhAnh.Count)
                        </h4>

                        <div class="flex gap-2 overflow-x-auto pb-2 hide-scrollbar w-full" id="thumbnail-container">
                            @for (int i = 0; i < tatCaHinhAnh.Count; i++)
                            {
                                string borderClass = (i == 0) ? "border-[#00E5FF]" : "border-transparent";
                                <div class="w-16 h-16 shrink-0 rounded-xl border-2 @borderClass overflow-hidden bg-white p-1 cursor-pointer transition-all hover:border-gray-300 detail-thumb"
                                     onclick="goToSlide(@i)">
                                    <img src="~/img/@tatCaHinhAnh[i]" class="w-full h-full object-contain" onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="w-full md:w-3/5 p-8">
                <h2 class="text-3xl font-bold text-[#001F3F] mb-4">@Model?.TenSanPham</h2>
                <div class="mb-8">
                    <p class="text-sm font-semibold text-gray-500 mb-1">Giá bán hiện tại</p>
                    <div class="inline-flex items-center gap-2 bg-[#001F3F] text-[#00E5FF] px-5 py-2.5 rounded-xl shadow-md">
                        <span class="text-2xl font-bold">@Model?.GiaBan.ToString("#,##0")</span> VNĐ
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Cách tạo mảng JS cực kỳ an toàn bằng vòng lặp Razor (Tránh lỗi Json Serialize)
        var imageArray = [];
        @foreach (var img in tatCaHinhAnh)
        {
            @:imageArray.push('@img');
        }

        var currentIndex = 0;

        function changeSlide(direction) {
            if (imageArray.length <= 1) return;
            currentIndex += direction;

            if (currentIndex >= imageArray.length) currentIndex = 0;
            if (currentIndex < 0) currentIndex = imageArray.length - 1;

            updateGallery();
        }

        function goToSlide(index) {
            currentIndex = index;
            updateGallery();
        }

        function updateGallery() {
            var mainImg = document.getElementById('main-img-detail');
            var thumbs = document.querySelectorAll('.detail-thumb');

            mainImg.style.opacity = '0.5';

            setTimeout(function() {
                mainImg.src = '/img/' + imageArray[currentIndex];
                mainImg.style.opacity = '1';
            }, 150);

            thumbs.forEach(function(thumb, idx) {
                if (idx === currentIndex) {
                    thumb.classList.remove('border-transparent');
                    thumb.classList.add('border-[#00E5FF]');
                    thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                } else {
                    thumb.classList.remove('border-[#00E5FF]');
                    thumb.classList.add('border-transparent');
                }
            });
        }
    </script>
}