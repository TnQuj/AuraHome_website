@model AISmartHome.Models.SanPham

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chỉnh sửa Thiết bị";
}

<style>
    /* Hiệu ứng viền sáng (Glow) cho nút Cyan */
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }

    /* Màu tùy chỉnh cho input khi focus */
    .input-focus-cyan:focus {
        outline: none;
        border-color: #00E5FF;
        box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.2);
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                    <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Chỉnh sửa Thiết bị AI
                </h1>
                <p class="text-sm text-gray-500 mt-1 pl-10">Cập nhật thông số kỹ thuật và giá bán</p>
            </div>
            <a asp-action="Index" class="flex items-center gap-2 text-[#001F3F] bg-white border border-gray-200 px-4 py-2 rounded-xl font-medium hover:bg-gray-50 transition-colors shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Quay lại
            </a>
        </div>

        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-[#001F3F] px-6 py-4">
                <h3 class="text-white font-semibold flex items-center gap-2">
                    <svg class="w-5 h-5 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Thông tin cơ bản (ID: #@Model.MaSanPham)
                </h3>
            </div>

            <form asp-action="Edit" enctype="multipart/form-data" class="p-6">
                <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm font-medium bg-red-50 p-3 rounded-lg"></div>
                <input type="hidden" asp-for="MaSanPham" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="md:col-span-2">
                        <label asp-for="TenSanPham" class="block text-sm font-bold text-[#001F3F] mb-2">Tên sản phẩm <span class="text-red-500">*</span></label>
                        <input asp-for="TenSanPham" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white" placeholder="VD: Camera AI Smart Vision Pro" />
                        <span asp-validation-for="TenSanPham" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="MaDanhMuc" class="block text-sm font-bold text-[#001F3F] mb-2">Phân loại danh mục</label>
                        <select asp-for="MaDanhMuc" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white appearance-none cursor-pointer" asp-items="ViewBag.MaDanhMuc"></select>
                        <span asp-validation-for="MaDanhMuc" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="SoLuong" class="block text-sm font-bold text-[#001F3F] mb-2">Tồn kho hiện tại</label>
                        <input asp-for="SoLuong" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white" type="number" min="0" />
                        <span asp-validation-for="SoLuong" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="GiaBan" class="block text-sm font-bold text-[#001F3F] mb-2">Giá bán (VNĐ)</label>
                        <div class="relative">
                            <input asp-for="GiaBan" class="w-full pl-4 pr-12 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 font-semibold text-blue-600 bg-slate-50 focus:bg-white" type="number" min="0" />
                            <span class="absolute inset-y-0 right-0 flex items-center pr-4 text-gray-500 font-bold">đ</span>
                        </div>
                        <span asp-validation-for="GiaBan" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <div class="md:col-span-2 mt-2">
                        <div class="bg-blue-50/50 border border-blue-100 rounded-xl p-5">
                            <h4 class="text-[15px] font-bold text-[#001F3F] mb-4 flex items-center gap-2">
                                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                Quản lý Hình ảnh Sản phẩm
                            </h4>

                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-3">Ảnh đại diện (Ảnh bìa chính)</label>
                                    <div class="flex items-center gap-4">
                                        <div class="w-20 h-20 rounded-xl border border-gray-200 overflow-hidden flex-shrink-0 bg-white shadow-sm flex items-center justify-center p-1">
                                            <img src="~/img/@Model.HinhAnh" alt="Current Image" class="max-w-full max-h-full object-contain" onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />
                                        </div>
                                        <div class="flex-1">
                                            <input type="hidden" asp-for="HinhAnh" />
                                            <input type="file" name="HinhAnhUpload" accept="image/*"
                                                   class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-[#00E5FF]/10 file:text-[#001F3F] hover:file:bg-[#00E5FF]/20 cursor-pointer transition-colors border border-gray-200 rounded-xl bg-white" />
                                            <p class="text-[11px] text-gray-500 mt-1 italic">Bỏ trống nếu không muốn thay đổi ảnh này.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="border-t lg:border-t-0 lg:border-l border-blue-100 pt-6 lg:pt-0 lg:pl-8">
                                    <label class="block text-sm font-bold text-slate-700 mb-3">Hình ảnh chi tiết (Nhiều ảnh)</label>

                                    <input type="hidden" name="IdsToXoa" id="IdsToXoa" value="" />

                                    @if (Model.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any())
                                    {
                                        <div class="flex flex-wrap gap-2 mb-4" id="container-anh-chi-tiet">
                                            @foreach (var anh in Model.HinhAnhSanPhams)
                                            {
                                                <div class="relative group item-anh" data-id="@anh.MaHinhAnh">
                                                    <div class="w-14 h-14 rounded-lg border border-gray-200 overflow-hidden bg-white flex items-center justify-center p-0.5">
                                                        <img src="~/img/@anh.UrlHinhAnh" class="max-w-full max-h-full object-contain" />
                                                    </div>
                                                    <button type="button"
                                                            onclick="markAsDeleted(this, @anh.MaHinhAnh)"
                                                            class="absolute -top-1.5 -right-1.5 size-5 bg-red-500 text-white rounded-full flex items-center justify-center text-[10px] opacity-0 group-hover:opacity-100 transition-opacity shadow-sm hover:bg-red-600">
                                                        <i class="fa-solid fa-xmark"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <label class="block text-[13px] font-semibold text-blue-600 mb-1">Thêm ảnh chi tiết mới:</label>
                                    <input type="file" name="HinhAnhChiTiet" multiple accept="image/*"
                                           class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-blue-100 file:text-blue-700 hover:file:bg-blue-200 cursor-pointer transition-colors border border-gray-200 rounded-xl bg-white" />
                                    <p class="text-[11px] text-gray-500 mt-1 italic">Nhấn giữ <strong>Ctrl</strong> để chọn nhiều file.</p>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="MoTa" class="block text-sm font-bold text-[#001F3F] mb-2">Mô tả thông số kỹ thuật</label>
                        <textarea asp-for="MoTa" rows="4" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 input-focus-cyan transition-all text-slate-700 bg-slate-50 focus:bg-white" placeholder="Nhập mô tả tính năng, thông số kỹ thuật của thiết bị..."></textarea>
                        <span asp-validation-for="MoTa" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                </div>

                <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-end gap-4">
                    <a asp-action="Index" class="px-6 py-2.5 rounded-xl font-bold text-gray-600 hover:bg-gray-100 transition-colors">
                        Hủy bỏ
                    </a>
                    <button type="submit" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-8 py-2.5 rounded-xl font-bold transition-all duration-300">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                        Lưu Thay Đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Mảng lưu trữ các ID ảnh cần xóa
        let deletedIds = [];

        function markAsDeleted(btn, id) {
            // 1. Thêm ID vào danh sách xóa
            deletedIds.push(id);

            // 2. Cập nhật giá trị vào input ẩn (nối nhau bằng dấu phẩy)
            document.getElementById('IdsToXoa').value = deletedIds.join(',');

            // 3. Ẩn phần tử trên giao diện với hiệu ứng nhẹ
            const item = btn.closest('.item-anh');
            item.style.transition = 'all 0.3s';
            item.style.opacity = '0';
            item.style.transform = 'scale(0.8)';

            setTimeout(() => {
                item.style.display = 'none';
            }, 300);

            console.log("Danh sách ID sẽ xóa:", document.getElementById('IdsToXoa').value);
        }
    </script>
}