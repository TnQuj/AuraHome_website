@model IEnumerable<AISmartHome.Models.SanPham>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<style>
    /* Hiệu ứng viền sáng (Glow) cho nút Cyan */
    .btn-cyan-glow:hover {
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
    }
</style>

<div class="p-6 bg-slate-50 min-h-screen">
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
        <div class="mb-4 md:mb-0">
            <h1 class="text-2xl font-bold text-[#001F3F] flex items-center gap-2">
                <svg class="w-8 h-8 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                Quản lý Kho Hàng AI
            </h1>
            <p class="text-sm text-gray-500 mt-1 pl-10">Hệ thống kiểm soát thiết bị Smart Home</p>
        </div>

        <div class="flex items-center gap-3">

            <form asp-action="ImportExcel" enctype="multipart/form-data" method="post" class="m-0">
                <input type="file" name="fileExcel" id="fileExcel" accept=".xlsx, .xls" class="hidden" onchange="this.form.submit()" />

                <label for="fileExcel" class="flex items-center gap-2 bg-white text-[#001F3F] border-2 border-[#001F3F]/10 px-5 py-2.5 rounded-xl font-bold cursor-pointer hover:border-[#00E5FF] hover:text-[#00E5FF] transition-all shadow-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Nhập Excel
                </label>
            </form>

            <a asp-action="Create" class="btn-cyan-glow flex items-center gap-2 bg-[#00E5FF] text-[#001F3F] px-6 py-2.5 rounded-xl font-bold transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Thêm Thủ Công
            </a>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-[#001F3F] text-white text-sm uppercase tracking-wider">
                        <th class="p-4 font-semibold w-24 text-center">Hình ảnh</th>
                        <th class="p-4 font-semibold">Thông tin thiết bị</th>
                        <th class="p-4 font-semibold">Giá bán</th>
                        <th class="p-4 font-semibold text-center">Tồn kho</th>
                        <th class="p-4 font-semibold">Danh mục</th>
                        <th class="p-4 font-semibold text-center w-36">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-blue-50/50 transition-colors group">

                            <td class="p-4">
                                <div class="w-16 h-16 mx-auto rounded-xl bg-gray-50 border border-gray-200 flex items-center justify-center overflow-hidden p-1 shadow-sm">
                                    <img src="~/img/@item.HinhAnh" alt="@item.TenSanPham" class="w-full h-full object-contain" onerror="this.src='https://via.placeholder.com/150?text=No+Image'" />
                                </div>
                            </td>

                            <td class="p-4">
                                <div class="font-bold text-[#001F3F] text-base mb-1">@item.TenSanPham</div>
                                <div class="text-xs text-gray-500 line-clamp-1 max-w-xs" title="@item.MoTa">@item.MoTa</div>
                            </td>

                            <td class="p-4">
                                <span class="inline-flex items-center font-bold text-[#00E5FF] bg-[#001F3F] px-3 py-1.5 rounded-lg shadow-sm">
                                    @item.GiaBan.ToString("#,##0") đ
                                </span>
                            </td>

                            <td class="p-4 text-center">
                                @if (item.SoLuong > 10)
                                {
                                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-100 text-green-700 font-bold border border-green-200" title="Còn nhiều hàng">
                                        @item.SoLuong
                                    </span>
                                }
                                else if (item.SoLuong > 0)
                                {
                                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-orange-100 text-orange-700 font-bold border border-orange-200" title="Sắp hết hàng">
                                        @item.SoLuong
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex px-2 py-1 rounded-md bg-red-100 text-red-700 text-xs font-bold border border-red-200">
                                        Hết
                                    </span>
                                }
                            </td>

                            <td class="p-4">
                                <span class="text-sm font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">
                                    @(item.MaDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")
                                </span>
                            </td>

                            <td class="p-4">
                                <div class="flex items-center justify-center gap-2 opacity-30 group-hover:opacity-100 transition-opacity duration-300">
                                    <a asp-action="Edit" asp-route-id="@item.MaSanPham" class="p-2 text-blue-600 hover:bg-blue-100 hover:text-blue-800 rounded-lg transition-colors" title="Chỉnh sửa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.MaSanPham" class="p-2 text-[#001F3F] hover:bg-gray-200 rounded-lg transition-colors" title="Xem chi tiết">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaSanPham" class="p-2 text-red-500 hover:bg-red-100 hover:text-red-700 rounded-lg transition-colors" title="Xóa">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>