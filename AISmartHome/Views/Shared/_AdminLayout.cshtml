@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AuraHome Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { brand: { navy: '#0f172a', cyan: '#06b6d4', cyan_glow: '#00e5ff' } }
                }
            }
        }
    </script>
    <style>
        /* Tùy chỉnh thanh cuộn siêu mượt */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-slate-100 font-sans text-slate-800 overflow-hidden selection:bg-brand-cyan selection:text-white">

    <div class="flex h-screen w-full relative">

        <aside class="w-72 bg-brand-navy text-white flex-shrink-0 flex flex-col relative z-20 shadow-[4px_0_24px_rgba(0,0,0,0.15)]">
            <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-brand-cyan/20 to-transparent blur-[50px] pointer-events-none"></div>

            <div class="p-6 h-20 flex items-center justify-between border-b border-white/10 relative z-10">
                <div class="text-2xl font-black tracking-widest uppercase flex items-center gap-2">
                    <i class="fa-brands fa-hubspot text-brand-cyan"></i>
                    Aura<span class="text-brand-cyan">Admin</span>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto py-6 px-4 space-y-1 relative z-10 custom-scrollbar">
                <p class="px-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2 mt-4">Quản lý cốt lõi</p>
                <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan hover:shadow-[0_0_15px_rgba(6,182,212,0.3)] transition-all group">
                    <i class="fa-solid fa-chart-pie w-5 text-slate-400 group-hover:text-brand-cyan"></i> Bảng điều khiển
                </a>
                <a asp-controller="DonHangs" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan hover:shadow-[0_0_15px_rgba(6,182,212,0.3)] transition-all group">
                    <i class="fa-solid fa-cart-shopping w-5 text-slate-400 group-hover:text-brand-cyan"></i> Đơn hàng
                    <span class="ml-auto bg-rose-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">Mới</span>
                </a>
                <a asp-controller="YeuCauLapDats" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan hover:shadow-[0_0_15px_rgba(6,182,212,0.3)] transition-all group">
                    <i class="fa-solid fa-screwdriver-wrench w-5 text-slate-400 group-hover:text-brand-cyan"></i> Yêu cầu lắp đặt
                </a>

                <p class="px-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2 mt-8">Sản phẩm & Nội dung</p>
                <a asp-controller="SanPhams" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group">
                    <i class="fa-solid fa-box-open w-5 text-slate-400 group-hover:text-brand-cyan"></i> Sản phẩm
                </a>
                <a asp-controller="DanhMucSanPhams" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group">
                    <i class="fa-solid fa-tags w-5 text-slate-400 group-hover:text-brand-cyan"></i> Danh mục
                </a>
                <a asp-controller="BaiViets" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group">
                    <i class="fa-regular fa-newspaper w-5 text-slate-400 group-hover:text-brand-cyan"></i> Bài viết / Blog
                </a>
                <a asp-controller="HuongDanSuDungs" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group">
                    <i class="fa-solid fa-book w-5 text-slate-400 group-hover:text-brand-cyan"></i> Hướng dẫn SD
                </a>

                <p class="px-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2 mt-8">Tài khoản</p>
                <a asp-controller="KhachHangs" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group">
                    <i class="fa-solid fa-users w-5 text-slate-400 group-hover:text-brand-cyan"></i> Khách hàng
                </a>
                <a asp-controller="NhanViens" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group">
                    <i class="fa-solid fa-user-tie w-5 text-slate-400 group-hover:text-brand-cyan"></i> Nhân viên
                </a>
            </div>
            <div class="p-4 border-t border-white/10 relative z-10">
                <a asp-controller="Admin" asp-action="ExitToWebsite" class="flex items-center justify-center gap-2 w-full py-3 bg-white/5 hover:bg-brand-cyan hover:text-white rounded-xl transition-all font-bold text-sm border border-white/10">
                    <i class="fa-solid fa-globe"></i> Về trang Website
                </a>
            </div>
        </aside>

        <div class="flex-1 flex flex-col overflow-hidden relative bg-slate-50">

            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-brand-cyan/5 blur-[100px] rounded-full pointer-events-none"></div>

            <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 flex flex-col xl:flex-row items-center px-6 lg:px-8 py-4 justify-between relative z-30 min-h-[80px] gap-4">

                <div class="w-full xl:w-auto flex-1">
                    <h1 class="text-2xl font-black text-[#001F3F] flex items-center gap-2 tracking-wide">
                        @* Icon mặc định nếu trang không truyền icon lên *@
                        @if (ViewData["HeaderIcon"] != null)
                        {
                            @Html.Raw(ViewData["HeaderIcon"])
                        }
                        @ViewData["Title"]
                    </h1>

                    @if (ViewData["Subtitle"] != null)
                    {
                        <p class="text-sm text-slate-500 mt-1 pl-10">@ViewData["Subtitle"]</p>
                    }
                </div>

                <div class="flex items-center justify-end gap-4 lg:gap-6 w-full xl:w-auto">

                    @if (IsSectionDefined("HeaderActions"))
                    {
                        <div class="flex items-center gap-2">
                            @RenderSection("HeaderActions", required: false)
                        </div>

                        <div class="h-8 w-px bg-slate-200 hidden md:block"></div>
                    }

                    <div class="relative">
                        <button id="btnNotification" class="relative p-2 w-10 h-10 rounded-full bg-slate-100 text-slate-500 hover:bg-cyan-50 hover:text-brand-cyan transition-all outline-none">
                            <i class="fa-solid fa-bell text-lg"></i>
                            <span class="absolute top-0 right-0 flex h-3 w-3">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-rose-500 border-2 border-white"></span>
                            </span>
                        </button>
                        @await Component.InvokeAsync("Notification")
                    </div>

                    <div class="h-8 w-px bg-slate-200"></div>

                    <div class="relative group cursor-pointer">
                        <div class="flex items-center gap-3">
                            <div class="text-right hidden md:block">
                                <p class="text-sm font-bold text-slate-800 leading-tight">Admin Quản Trị</p>
                                <p class="text-xs text-brand-cyan font-medium">System Manager</p>
                            </div>
                            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-[#001F3F] to-[#00E5FF] text-white flex items-center justify-center font-bold shadow-md group-hover:ring-2 ring-offset-2 ring-[#00E5FF] transition-all">
                                A
                            </div>
                        </div>

                        <div class="absolute right-0 top-full mt-3 w-48 bg-white rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 transform origin-top-right scale-95 group-hover:scale-100 overflow-hidden">
                            <div class="p-1.5">
                                <div class="h-px bg-slate-100 my-1 hidden"></div>
                                <button type="button" onclick="confirmLogout()" class="w-full flex items-center gap-3 px-4 py-2.5 text-[14px] font-bold text-rose-500 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-colors text-left">
                                    <i class="fa-solid fa-right-from-bracket mt-0.5"></i> Đăng xuất
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </header>

            <div class="flex-1 overflow-y-auto px-6 pb-6 pt-3 relative z-10">

                <div class="relative group h-full">
                    <div class="absolute -inset-[2px] bg-gradient-to-r from-brand-cyan via-blue-400 to-emerald-400 rounded-3xl blur-[8px] opacity-20 group-hover:opacity-40 transition duration-1000"></div>

                    <div class="relative bg-white rounded-2xl h-full shadow-xl border border-white/50 p-6 overflow-y-auto custom-scrollbar">
                        @RenderBody()
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btnNotification = document.getElementById('btnNotification');
            const panelNotification = document.getElementById('panelNotification');

            // Bật/tắt hộp thông báo khi bấm vào chuông
            btnNotification.addEventListener('click', function (e) {
                e.stopPropagation(); // Ngăn sự kiện click lan ra ngoài
                panelNotification.classList.toggle('hidden');
            });

            // Tắt hộp thông báo khi click ra chỗ khác trên màn hình
            document.addEventListener('click', function (e) {
                if (!panelNotification.contains(e.target) && !btnNotification.contains(e.target)) {
                    panelNotification.classList.add('hidden');
                }
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmLogout() {
            Swal.fire({
                title: 'Xác nhận đăng xuất?',
                text: "Bạn có chắc chắn muốn thoát khỏi hệ thống quản trị AuraHome?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="fa-solid fa-right-from-bracket"></i> Đăng xuất ngay',
                cancelButtonText: 'Hủy bỏ',
                customClass: { backdrop: 'swal-glass-backdrop' }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Đang đăng xuất...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                    window.location.href = '/Admin/Logout';
                }
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>