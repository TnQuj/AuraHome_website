@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị BADO</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: { brand: { navy: '#001f3d', cyan: '#00e5ff' } } } }
        }
    </script>
</head>
<body class="bg-gray-100 font-sans">
    <div class="flex h-screen overflow-hidden">
        <aside class="w-64 bg-brand-navy text-white flex-shrink-0">
            <div class="p-6 text-xl font-bold border-b border-white/10">
                Admin <span class="text-brand-cyan">BADO</span>
            </div>
            <nav class="mt-6">
                <a asp-controller="Admin" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Bảng điều khiển</a>
                <a asp-controller="SanPhams" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quản lý sản phẩm</a>
                <a asp-controller="DanhMucSanPhams" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quản lý danh mục sản phẩm</a>
                <a asp-controller="DonHangs" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quản lý đơn hàng</a>
                <a asp-controller="KhachHangs" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quản lý khách hàng</a>
                <a asp-controller="NhanViens" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quản lý nhân viên</a>
                <a asp-controller="BaiViets" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quản lý bài viết</a>

                <hr class="border-white/10 my-4" />
                <a asp-controller="Home" asp-action="Index" class="block py-3 px-6 hover:bg-white/10 transition">Quay lại Website</a>
            </nav>
        </aside>

        <div class="flex-1 flex flex-col overflow-hidden">
            <header class="h-16 bg-white shadow-sm flex items-center px-8 justify-between">
                <h2 class="font-semibold text-lg text-brand-navy">@ViewData["Title"]</h2>
                <div class="text-sm text-gray-500">Xin chào, Admin</div>
            </header>
            <main class="flex-1 overflow-y-auto p-8">
                @RenderBody()
            </main>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>