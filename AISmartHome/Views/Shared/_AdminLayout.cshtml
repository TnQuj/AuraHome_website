@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AuraHome Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: { brand: { navy: '#0f172a', cyan: '#06b6d4', cyan_glow: '#00e5ff' } }
                }
            }
        }
    </script>
    <style>
        /* Tùy chỉnh thanh cuộn siêu mượt */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<style>
    /* Trạng thái khi sidebar thu nhỏ */
    .sidebar-collapsed {
        width: 88px !important;
    }

        /* Ẩn chữ và badge khi thu nhỏ */
        .sidebar-collapsed .sidebar-text {
            opacity: 0;
            visibility: hidden;
            width: 0;
        }

        /* Căn giữa các icon khi thu nhỏ */
        .sidebar-collapsed a {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }

        .sidebar-collapsed p {
            opacity: 0;
        }
</style>
<body class="bg-slate-100 font-sans text-slate-800 overflow-hidden selection:bg-brand-cyan selection:text-white">

    <div class="flex h-screen w-full relative">

        <aside id="adminSidebar" class="w-72 bg-brand-navy text-white flex-shrink-0 flex flex-col relative z-20 shadow-[4px_0_24px_rgba(0,0,0,0.15)] transition-all duration-300 ease-in-out">
            <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-brand-cyan/20 to-transparent blur-[50px] pointer-events-none"></div>

            <div class="p-6 h-20 flex items-center justify-between border-b border-white/10 relative z-10 overflow-hidden">
                <div class="text-2xl font-black tracking-widest uppercase flex items-center gap-2">
                    <i class="fa-brands fa-hubspot text-brand-cyan flex-shrink-0"></i>
                    <span class="sidebar-text transition-all duration-300">Aura<span class="text-brand-cyan">Admin</span></span>
                </div>
                <button onclick="toggleSidebar()" class="text-slate-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
                    <i id="toggleIcon" class="fa-solid fa-bars-staggered"></i>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto py-6 px-4 space-y-1 relative z-10 custom-scrollbar overflow-x-hidden">

                <p class="sidebar-text px-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2 mt-4 whitespace-nowrap">Quản lý cốt lõi</p>

                <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan hover:shadow-[0_0_15px_rgba(6,182,212,0.3)] transition-all group overflow-hidden">
                    <i class="fa-solid fa-chart-pie w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Bảng điều khiển</span>
                </a>

                <a asp-controller="DonHangs" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan hover:shadow-[0_0_15px_rgba(6,182,212,0.3)] transition-all group overflow-hidden">
                    <i class="fa-solid fa-cart-shopping w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Đơn hàng</span>
                </a>

                <a asp-controller="YeuCauLapDats" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan hover:shadow-[0_0_15px_rgba(6,182,212,0.3)] transition-all group overflow-hidden">
                    <i class="fa-solid fa-screwdriver-wrench w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Yêu cầu lắp đặt</span>
                </a>

                <p class="sidebar-text px-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2 mt-8 whitespace-nowrap">Sản phẩm & Nội dung</p>

                <a asp-controller="SanPhams" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group overflow-hidden">
                    <i class="fa-solid fa-box-open w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Sản phẩm</span>
                </a>

                <a asp-controller="DanhMucSanPhams" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group overflow-hidden">
                    <i class="fa-solid fa-tags w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Danh mục</span>
                </a>

                <a asp-controller="BaiViets" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group overflow-hidden">
                    <i class="fa-regular fa-newspaper w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Bài viết / Blog</span>
                </a>

                <a asp-controller="HuongDanSuDungs" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group overflow-hidden">
                    <i class="fa-solid fa-book w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Hướng dẫn SD</span>
                </a>

                <p class="sidebar-text px-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2 mt-8 whitespace-nowrap">Tài khoản</p>

                <a asp-controller="KhachHangs" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group overflow-hidden">
                    <i class="fa-solid fa-users w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Khách hàng</span>
                </a>

                <a asp-controller="NhanViens" asp-action="Index" class="flex items-center gap-3 py-3 px-4 rounded-xl hover:bg-white/10 hover:text-brand-cyan transition-all group overflow-hidden">
                    <i class="fa-solid fa-user-tie w-5 flex-shrink-0 text-slate-400 group-hover:text-brand-cyan text-center"></i>
                    <span class="sidebar-text whitespace-nowrap">Nhân viên</span>
                </a>
            </div>

            <div class="p-4 border-t border-white/10 relative z-10">
                <a asp-controller="Admin" asp-action="ExitToWebsite" class="flex items-center justify-center gap-2 w-full py-3 bg-white/5 hover:bg-brand-cyan hover:text-white rounded-xl transition-all font-bold text-sm border border-white/10 overflow-hidden">
                    <i class="fa-solid fa-globe flex-shrink-0"></i>
                    <span class="sidebar-text whitespace-nowrap">Về Website</span>
                </a>
            </div>
        </aside>

        <div class="flex-1 flex flex-col overflow-hidden relative bg-slate-50">

            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-brand-cyan/5 blur-[100px] rounded-full pointer-events-none"></div>

            <header class="bg-white/80 backdrop-blur-md border-b border-slate-200 flex flex-col xl:flex-row items-center px-6 lg:px-8 py-4 justify-between relative z-30 min-h-[80px] gap-4">

                <div class="w-full xl:w-auto flex-1">
                    <h1 class="text-2xl font-black text-[#001F3F] flex items-center gap-2 tracking-wide">
                        @* Icon mặc định nếu trang không truyền icon lên *@
                        @if (ViewData["HeaderIcon"] != null)
                        {
                            @Html.Raw(ViewData["HeaderIcon"])
                        }
                        @ViewData["Title"]
                    </h1>

                    @if (ViewData["Subtitle"] != null)
                    {
                        <p class="text-sm text-slate-500 mt-1 pl-10">@ViewData["Subtitle"]</p>
                    }
                </div>

                <div class="flex items-center justify-end gap-4 lg:gap-6 w-full xl:w-auto">

                    @if (IsSectionDefined("HeaderActions"))
                    {
                        <div class="flex items-center gap-2">
                            @RenderSection("HeaderActions", required: false)
                        </div>

                        <div class="h-8 w-px bg-slate-200 hidden md:block"></div>
                    }

                    <div class="relative">
                        <button id="btnNotification" class="relative p-2 w-10 h-10 rounded-full bg-slate-100 text-slate-500 hover:bg-cyan-50 hover:text-brand-cyan transition-all outline-none">
                            <i class="fa-solid fa-bell text-lg"></i>
                            <span class="absolute top-0 right-0 flex h-3 w-3">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-rose-500 border-2 border-white"></span>
                            </span>
                        </button>
                        @await Component.InvokeAsync("Notification", new { isForAdmin = true })
                    </div>

                    <div class="h-8 w-px bg-slate-200"></div>

                    <div class="relative group cursor-pointer">
                        <div class="flex items-center gap-3">
                            <div class="text-right hidden md:block">
                                <p class="text-sm font-bold text-slate-800 leading-tight">Admin Quản Trị</p>
                                <p class="text-xs text-brand-cyan font-medium">System Manager</p>
                            </div>
                            <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-[#001F3F] to-[#00E5FF] text-white flex items-center justify-center font-bold shadow-md group-hover:ring-2 ring-offset-2 ring-[#00E5FF] transition-all">
                                A
                            </div>
                        </div>

                        <div class="absolute right-0 top-full mt-3 w-48 bg-white rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 transform origin-top-right scale-95 group-hover:scale-100 overflow-hidden">
                            <div class="p-1.5">
                                <div class="h-px bg-slate-100 my-1 hidden"></div>
                                <button type="button" onclick="confirmLogout()" class="w-full flex items-center gap-3 px-4 py-2.5 text-[14px] font-bold text-rose-500 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-colors text-left">
                                    <i class="fa-solid fa-right-from-bracket mt-0.5"></i> Đăng xuất
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </header>

            <div class="flex-1 overflow-y-auto px-6 pb-6 pt-3 relative z-10">

                <div class="relative group h-full">
                    <div class="absolute -inset-[2px] bg-gradient-to-r from-brand-cyan via-blue-400 to-emerald-400 rounded-3xl blur-[8px] opacity-20 group-hover:opacity-40 transition duration-1000"></div>

                    <div class="relative bg-white rounded-2xl h-full shadow-xl border border-white/50 p-6 overflow-y-auto custom-scrollbar">
                        @RenderBody()
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ID nút chuông ngoài layout của bạn (hãy kiểm tra xem nút chuông có class/id gì)
            const btnNoti = document.querySelector('.fa-bell').closest('button, a'); // Hoặc id nút chuông của bạn
            const panelNoti = document.getElementById('panelNotification');

            if (btnNoti && panelNoti) {
                btnNoti.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    panelNoti.classList.toggle('hidden');
                });

                document.addEventListener('click', function (e) {
                    if (!panelNoti.contains(e.target) && !btnNoti.contains(e.target)) {
                        panelNoti.classList.add('hidden');
                    }
                });
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmLogout() {
            Swal.fire({
                title: 'Xác nhận đăng xuất?',
                text: "Bạn có chắc chắn muốn thoát khỏi hệ thống quản trị AuraHome?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="fa-solid fa-right-from-bracket"></i> Đăng xuất ngay',
                cancelButtonText: 'Hủy bỏ',
                customClass: { backdrop: 'swal-glass-backdrop' }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Đang đăng xuất...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                    window.location.href = '/Admin/Logout';
                }
            });
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        // Bật chế độ ghi log chi tiết (Information) để dễ tìm lỗi
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .configureLogging(signalR.LogLevel.Information)
            .build();

        // Lắng nghe tín hiệu
        connection.on("NhanDonHangMoi", function (maDon, tenKhach, tongTien) {
            console.log("🔥 ĐÃ NHẬN ĐƯỢC TÍN HIỆU TỪ C#! Mã đơn:", maDon); // Báo ra F12

            let audio = new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3');
            audio.play().catch(e => console.log("Trình duyệt chặn tự động phát âm thanh:", e));

            Swal.fire({
                title: '🎉 CÓ ĐƠN HÀNG MỚI!',
                html: `Khách hàng <b>${tenKhach}</b> vừa đặt đơn hàng #${maDon}<br>Trị giá: <b class="text-rose-600">${tongTien.toLocaleString('vi-VN')} đ</b>`,
                icon: 'info',
                position: 'top-end',
                toast: true,
                showConfirmButton: false,
                timer: 5000
            });
        });

        // Bắt đầu kết nối
        connection.start().then(function () {
            console.log("🟢 SignalR ĐÃ KẾT NỐI THÀNH CÔNG TỚI TRẠM PHÁT!");
        }).catch(function (err) {
            console.error("🔴 LỖI KẾT NỐI SIGNALR: ", err.toString());
        });
    </script>
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('adminSidebar');
            const icon = document.getElementById('toggleIcon');

            sidebar.classList.toggle('sidebar-collapsed');

            // Đổi icon khi đóng mở
            if (sidebar.classList.contains('sidebar-collapsed')) {
                icon.classList.replace('fa-bars-staggered', 'fa-align-left');
            } else {
                icon.classList.replace('fa-align-left', 'fa-bars-staggered');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>