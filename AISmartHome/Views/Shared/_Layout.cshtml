                    <button type="button" class="bg-cyan-500 text-white font-bold px-8 py-4 rounded-xl hover:bg-cyan-400 hover:-translate-y-1 transition-all duration-300 shadow-[0_0_20px_rgba(6,182,212,0.4)] whitespace-nowrap flex items-center justify-center gap-2">
