@using Microsoft.EntityFrameworkCore
@inject AISmartHome.Data.AISmartHomeDbContext _context
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // 1. Lấy Số điện thoại từ Session (đã lưu lúc khách đặt hàng hoặc tra cứu)
    string currentPhone = HttpContextAccessor.HttpContext?.Session.GetString("CustomerPhone");
    string guestIdStr = HttpContextAccessor.HttpContext?.Session.GetString("GuestCustomerId");
    int cartCount = 0;
    int notifCount = 0;
    var recentOrders = new List<AISmartHome.Models.DonHang>();

    // ========================================================
    // PHẦN 1: LOGIC GIỎ HÀNG (Dành cho khách vãng lai)
    // ========================================================
    // Tạm thời giữ MaKhachHang = 1 cho giỏ hàng nếu bạn chưa làm hệ thống giỏ hàng theo Session.
    // Nếu muốn giỏ hàng không bị dùng chung, bạn nên thay số 1 bằng một ID lưu trong Session.
    int maKhachHangChoGioHang = 1;

    var cart = _context.GioHangs
        .Include(g => g.ChiTietGioHangs)
        .FirstOrDefault(g => g.MaKhachHang == maKhachHangChoGioHang);

    if (cart != null && cart.ChiTietGioHangs != null)
    {
        cartCount = cart.ChiTietGioHangs.Sum(c => c.SoLuong ?? 0);
    }

    // ========================================================
    // PHẦN 2: LOGIC THÔNG BÁO (ĐÃ SỬA: CHỈ HIỆN ĐƠN CỦA SĐT ĐANG DÙNG)
    // ========================================================
    if (!string.IsNullOrEmpty(currentPhone))
    {
        // Chỉ lấy đơn hàng khớp với Số điện thoại đang lưu trong Session của trình duyệt này
        recentOrders = _context.DonHangs
            .Where(d => d.SoDienThoai == currentPhone || d.MaKhachHangNavigation.SoDienThoai == currentPhone)
            .OrderByDescending(d => d.NgayDatHang)
            .Take(5) // Lấy 5 đơn mới nhất cho gọn
            .ToList();

        // Đếm số đơn đang chạy (Chờ xử lý/Đang giao) của riêng số điện thoại này
        notifCount = recentOrders.Count(d => d.TrangThaiDonHang == "Chờ xử lý" || d.TrangThaiDonHang == "Đang giao");
    }
}
