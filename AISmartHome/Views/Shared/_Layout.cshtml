    <div id="mini-cart-overlay" class="fixed inset-0 bg-brand-navy/60 z-[10000] hidden opacity-0 transition-opacity duration-300 backdrop-blur-sm" onclick="closeMiniCart()"></div>

    <div id="mini-cart-panel" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[10001] transform translate-x-full transition-transform duration-300 flex flex-col shadow-2xl">
        <div class="flex items-center justify-center p-5 border-b border-slate-100 relative">
            <h3 class="text-lg font-display font-medium text-brand-navy uppercase tracking-wider">Giỏ Hàng</h3>
            <button type="button" onclick="closeMiniCart()" class="absolute right-4 top-1/2 -translate-y-1/2 w-8 h-8 flex items-center justify-center text-slate-500 hover:text-brand-red transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        <div id="mini-cart-items" class="flex-1 overflow-y-auto p-5 flex flex-col gap-5 cart-scroll"></div>

        <div class="p-6 border-t border-slate-100 bg-white mt-auto">
            <div class="flex justify-between items-center mb-5">
                <span class="text-brand-navy font-bold text-[16px]">Tổng số phụ:</span>
                <span id="mini-cart-total" class="text-xl font-black text-brand-navy">0 VNĐ</span>
            </div>
            <div class="flex flex-col gap-3">
                <a asp-controller="Customers" asp-action="Cart"
                   class="w-full bg-[#2b3a82] hover:bg-brand-navy text-white text-center py-3.5 rounded-sm font-medium transition-colors">
                    Xem giỏ hàng
                </a>

                <a asp-controller="Customers" asp-action="Checkout"
                   class="w-full bg-brand-red hover:bg-red-700 text-white text-center py-3.5 rounded-sm font-medium transition-colors">
                    Thanh toán
                </a>
            </div>
        </div>
    </div>

    <div id="adminLoginModal" class="fixed inset-0 z-[10005] hidden items-center justify-center bg-brand-navy/80 backdrop-blur-sm transition-all">
        <div class="bg-white p-8 rounded-3xl shadow-2xl w-[90%] max-w-sm transform scale-100 transition-transform relative">

            <button type="button" onclick="closeLoginModal()" class="absolute top-4 right-5 text-slate-400 hover:text-rose-500 transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>

            <div class="text-center mb-6 mt-2">
                <div class="mx-auto w-14 h-14 bg-brand-navy rounded-2xl flex items-center justify-center mb-4 shadow-lg shadow-brand-navy/20">
                    <i class="fa-solid fa-shield-halved text-brand-cyan text-2xl"></i>
                </div>
                <h3 class="text-xl font-black text-brand-navy uppercase tracking-wider">Đăng nhập</h3>
            </div>

            <form asp-controller="Admin" asp-action="Login" method="POST" class="space-y-5">
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-user text-slate-400 text-sm"></i>
                    </div>
                    <input name="Username" type="text" required
                           class="block w-full pl-11 pr-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all"
                           placeholder="Tài khoản">
                </div>

                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-lock text-slate-400 text-sm"></i>
                    </div>
                    <input name="Password" type="password" required
                           class="block w-full pl-11 pr-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all"
                           placeholder="Mật khẩu">
                </div>

                <div class="flex items-center justify-between text-xs">
                    <label class="flex items-center text-slate-600 cursor-pointer">
                        <input type="checkbox" class="mr-2 text-brand-cyan rounded border-slate-300 focus:ring-brand-cyan"> Ghi nhớ
                    </label>
                    <a href="#" class="text-brand-cyan font-semibold hover:underline">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="w-full py-3.5 bg-brand-navy text-white text-sm font-black uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all shadow-lg shadow-brand-navy/20">
                    Đăng nhập
                </button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/login.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["LoginError"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                // Gọi hàm mở Modal đăng nhập
                if (typeof openLoginModal === 'function') {
                    openLoginModal();
                }

                // Hiện thông báo lỗi
                Swal.fire({
                    icon: 'error',
                    title: 'Đăng nhập thất bại',
                    text: '@Html.Raw(TempData["LoginError"])',
                    confirmButtonColor: '#0f172a',
                    customClass: {
                        backdrop: 'swal-glass-backdrop' // Dùng luôn hiệu ứng kính mờ cho báo lỗi
                    }
                });
            });
        </script>
    }
</body>
</html>
