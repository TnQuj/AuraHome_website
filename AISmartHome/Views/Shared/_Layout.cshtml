    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        /* 1. CÀI ĐẶT FONT CHỮ CHUNG */
        body {
            font-family: 'Public Sans', sans-serif;
        }

        .swal2-container {
            z-index: 99999 !important;
        }

        /* 2. LÀM ĐẸP THANH CUỘN CHO GIỎ HÀNG TRƯỢT (MINI CART) */
        .cart-scroll::-webkit-scrollbar {
            width: 6px;
        }

        .cart-scroll::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 10px;
        }

        .cart-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

            .cart-scroll::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

        /* 3. CLASS TIỆN ÍCH: ẨN THANH CUỘN MẶC ĐỊNH (Nhưng vẫn cuộn được) */
        .hide-scrollbar {
            -ms-overflow-style: none; /* Dành cho Internet Explorer, Edge */
            scrollbar-width: none; /* Dành cho Firefox */
        }

            .hide-scrollbar::-webkit-scrollbar {
                display: none; /* Dành cho Chrome, Safari, Opera */
            }
    </style>
</head>
