                </div>
                <div>
                    <h4 class="font-bold text-sm tracking-wide text-orange-400">Trợ lý Mèo Cam 🐾</h4>
                    <p class="text-[11px] text-slate-300">Meow! Mình đang online nè</p>
                </div>
            </div>
            <button onclick="toggleChat()" class="w-8 h-8 rounded-full bg-white/10 hover:bg-rose-500 text-white flex items-center justify-center transition-colors">
                <i class="fa-solid fa-xmark text-sm"></i>
            </button>
        </div>

        <div id="chatMessages" class="p-4 h-[320px] overflow-y-auto bg-[#FAFCFF] flex flex-col gap-4 scrollbar-thin scrollbar-thumb-slate-200">
            <div class="flex gap-2 items-end animate-fade-in">
                <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center shrink-0 text-sm shadow-sm border border-orange-200">
                    <i class="fa-solid fa-cat"></i>
                </div>
                <div class="bg-white p-3 rounded-2xl rounded-bl-none shadow-sm border border-orange-100 text-[13px] text-slate-700 max-w-[80%] leading-relaxed">
                    Meow! 👋 Chào sen, mình là <strong>Mèo Cam</strong> của AuraHome.<br><br>Sen đang muốn tìm <strong>Camera AI</strong> hay <strong>Khóa cửa thông minh</strong> để mình vuốt râu tư vấn cho? 🐱
                </div>
            </div>
        </div>

        <div class="p-3 bg-white border-t border-slate-100">
            <form onsubmit="handleSendMessage(event)" class="flex items-center gap-2 m-0">
                <input type="text" id="chatInput" placeholder="Nhập tin nhắn cho Mèo Cam..."
                       class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-[13px] outline-none focus:border-orange-400 focus:bg-white transition-colors" required autocomplete="off">
                <button type="submit" class="size-10 bg-orange-500 text-white rounded-xl flex items-center justify-center hover:bg-orange-600 transition-colors shrink-0 shadow-[0_4px_10px_rgba(249,115,22,0.3)] active:scale-95">
                    <i class="fa-solid fa-paper-plane text-sm translate-y-[1px] -translate-x-[1px]"></i>
                </button>
            </form>
        </div>
    </div>
    <script>
        // ==========================================
        // 1. LOGIC ẨN/HIỆN POPUP & HỘP QUÀ
        // ==========================================
        document.addEventListener("DOMContentLoaded", function() {
            // Kiểm tra bộ nhớ trình duyệt (Hoạt động cho cả khách vãng lai và khách đã đăng nhập)
            const isClaimed = localStorage.getItem('wheelClaimed'); // Đã nhận quà chưa?
            const hasSeen = localStorage.getItem('hasSeenWheel');   // Đã từng thấy popup tự bật chưa?
            const giftBox = document.getElementById('floatingGiftBox');

            // BƯỚC 1: Nếu đã nhận quà (hoặc email đã dùng) -> Không làm gì cả, giấu sạch!
            if (isClaimed === 'true') {
                if (giftBox) giftBox.classList.add('hidden');
                return;
            }

            // BƯỚC 2: Nếu khách mới toanh -> Đợi 3s tự bật Popup (Chỉ bật 1 lần duy nhất)
            if (!hasSeen) {
                setTimeout(() => {
                    openLuckyWheel();
                    localStorage.setItem('hasSeenWheel', 'true'); // Đánh dấu là đã thấy
                }, 3000);
            }
            // BƯỚC 3: Nếu đã thấy rồi mà chưa quay -> Hiện cái hộp quà nhảy nhảy góc phải
            else {
                if (giftBox) giftBox.classList.remove('hidden');
            }
        });

        function openLuckyWheel() {
            const modal = document.getElementById('luckySpinModal') || document.getElementById('luckyWheelModal');
            const content = document.getElementById('luckySpinContent') || document.getElementById('luckyWheelContent');
            const giftBox = document.getElementById('floatingGiftBox');

            if (!modal || !content) return;

            // Giấu hộp quà đi khi Popup mở lên
            if (giftBox) giftBox.classList.add('hidden');

            modal.classList.remove('hidden');
            modal.classList.add('flex');

            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }, 10);
        }

        function executeCloseModal() {
            const modal = document.getElementById('luckySpinModal') || document.getElementById('luckyWheelModal');
            const content = document.getElementById('luckySpinContent') || document.getElementById('luckyWheelContent');
            const giftBox = document.getElementById('floatingGiftBox');
            const isClaimed = localStorage.getItem('wheelClaimed');

            if (!modal || !content) return;

            modal.classList.add('opacity-0');
            content.classList.add('scale-95');

            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');

                // CHỈ HIỆN HỘP QUÀ KHI KHÁCH CHƯA TRÚNG QUÀ
                if (isClaimed !== 'true' && giftBox) {
                    giftBox.classList.remove('hidden');
                }
            }, 300);
        }

        function closeSpinModal() { executeCloseModal(); }
        function closeLuckyWheel() { executeCloseModal(); }

        // ==========================================
        // 2. LOGIC QUAY BÁNH XE
        // ==========================================
        let isSpinning = false;

        function startSpin() {
            if (isSpinning) return;

            const emailInput = document.getElementById('spinEmail') || document.getElementById('wheelEmail');
            if (!emailInput) return;

            const email = emailInput.value.trim();
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

            if (!email || !emailRegex.test(email)) {
                Swal.fire({
                    title: 'Lỗi', text: 'Vui lòng nhập một email hợp lệ (vd: khach@gmail.com)!', icon: 'warning'
                });
                return;
            }

            isSpinning = true;
            const btn = document.getElementById('btnSpin');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang chờ...';

            fetch(`/Home/SpinWheel?email=${encodeURIComponent(email)}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if (!data.success) {
                    Swal.fire({
                        title: 'Rất tiếc', text: data.message, icon: 'warning'
                    });

                    isSpinning = false;
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-dharmachakra"></i> QUAY NGAY';

                    // TÍNH NĂNG MỚI: Nếu server C# báo email này đã từng quay rồi -> Đánh dấu là đã chơi luôn, thu hồi hộp quà!
                    if (data.message.toLowerCase().includes("đã tham gia")) {
                        localStorage.setItem('wheelClaimed', 'true');
                        setTimeout(() => executeCloseModal(), 1500); // Đóng popup sau 1.5s
                    }
                    return;
                }

                btn.innerHTML = 'ĐANG QUAY...';
                const wheel = document.getElementById('wheel');
                const degreePerSlice = 60;
                const targetDegree = 1800 + (360 - (data.prizeIndex * degreePerSlice)) - (degreePerSlice / 2);

                if(wheel) wheel.style.transform = `rotate(${targetDegree}deg)`;

                setTimeout(() => {
                    // ĐÁNH DẤU CHÍNH THỨC: ĐÃ NHẬN QUÀ THÀNH CÔNG -> VĨNH VIỄN GIẤU HỘP QUÀ
                    localStorage.setItem('wheelClaimed', 'true');

                    if (data.prizeIndex === 3) {
                        Swal.fire({
                            title: 'Thật tiếc...', text: data.prizeName, icon: 'info'
                        }).then(() => executeCloseModal());
                    } else {
                        Swal.fire({
                            icon: 'success',
                            title: 'Tuyệt vời!',
                            html: `Bạn đã trúng: <b class="text-lg text-brand-navy">${data.prizeName}</b><br><br>
                                   <div class="bg-cyan-50 p-3 rounded-lg border border-dashed border-cyan-400 mt-2">
                                      <span class="text-xs text-slate-500 uppercase font-bold block mb-1">Mã của bạn:</span>
                                      <strong class="text-2xl text-brand-cyan tracking-widest">${data.voucherCode}</strong>
                                   </div>`,
                            confirmButtonColor: '#06b6d4',
                            confirmButtonText: 'Mua hàng ngay'
                        }).then(() => executeCloseModal());
                    }

                    isSpinning = false;
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> ĐÃ NHẬN QUÀ';
                }, 4200);
            })
            .catch(error => {
                Swal.fire({ title: 'Lỗi', text: 'Không thể kết nối máy chủ', icon: 'error' });
                isSpinning = false;
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-dharmachakra"></i> QUAY NGAY';
            });
        }
            function toggleChat() {
            const chatWidget = document.getElementById('chatWidget');

            if (chatWidget.classList.contains('hidden')) {
                // Mở Chat
                chatWidget.classList.remove('hidden');
                setTimeout(() => {
                    chatWidget.classList.remove('scale-0', 'opacity-0');
                    chatWidget.classList.add('scale-100', 'opacity-100');
                }, 10); // Chờ xíu để CSS kịp render hiệu ứng phóng to
            } else {
                // Đóng Chat
                chatWidget.classList.remove('scale-100', 'opacity-100');
                chatWidget.classList.add('scale-0', 'opacity-0');
                setTimeout(() => {
                    chatWidget.classList.add('hidden');
                }, 300); // Chờ 0.3s cho hiệu ứng thu nhỏ xong mới ẩn hẳn
            }
        }

            function handleSendMessage(e) {
            e.preventDefault(); // Ngăn form tải lại trang
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            if (!message) return;

            const chatMessages = document.getElementById('chatMessages');

            // 1. In tin nhắn của Khách Hàng (Bên phải, màu xanh lam như cũ)
            const userMsgHtml = `
                <div class="flex gap-2 items-end justify-end animate-fade-in">
                    <div class="bg-cyan-500 text-white p-3 rounded-2xl rounded-br-none shadow-sm text-[13px] max-w-[80%] leading-relaxed">
                        ${message}
                    </div>
                </div>
            `;
            chatMessages.insertAdjacentHTML('beforeend', userMsgHtml);
            input.value = ''; // Xóa ô nhập
            chatMessages.scrollTop = chatMessages.scrollHeight; // Cuộn xuống cuối cùng

            // 2. Hiện hiệu ứng Mèo Cam "Đang gõ..."
            setTimeout(() => {
                const botTypingId = 'typing-' + Date.now();
                const botTypingHtml = `
                    <div id="${botTypingId}" class="flex gap-2 items-end animate-fade-in">
                        <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center shrink-0 text-sm shadow-sm border border-orange-200">
                            <i class="fa-solid fa-cat"></i>
                        </div>
                        <div class="bg-white px-4 py-3 rounded-2xl rounded-bl-none shadow-sm border border-slate-100 text-sm text-slate-400 w-fit flex gap-1 items-center">
                            <div class="w-1.5 h-1.5 bg-orange-300 rounded-full animate-bounce" style="animation-delay: 0ms;"></div>
                            <div class="w-1.5 h-1.5 bg-orange-300 rounded-full animate-bounce" style="animation-delay: 150ms;"></div>
                            <div class="w-1.5 h-1.5 bg-orange-300 rounded-full animate-bounce" style="animation-delay: 300ms;"></div>
                        </div>
                    </div>
                `;
                chatMessages.insertAdjacentHTML('beforeend', botTypingHtml);
                chatMessages.scrollTop = chatMessages.scrollHeight;

                // 3. Mèo Cam trả lời (Sau 1.5 giây)
                setTimeout(() => {
                    document.getElementById(botTypingId).remove();
                    const botReplyHtml = `
                        <div class="flex gap-2 items-end animate-fade-in">
                            <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-500 flex items-center justify-center shrink-0 text-sm shadow-sm border border-orange-200">
                                <i class="fa-solid fa-cat"></i>
                            </div>
                            <div class="bg-white p-3 rounded-2xl rounded-bl-none shadow-sm border border-orange-100 text-[13px] text-slate-700 max-w-[80%] leading-relaxed">
                                Meow! Tiếc quá, tay mình có đệm thịt nên gõ phím hơi chậm 🐾. <br><br>Sen cứ để lại <strong>Số điện thoại</strong> ở đây nhé, sếp lớn của mình sẽ gọi lại tư vấn trực tiếp cho sen ngay lập tức! 🐟
                            </div>
                        </div>
                    `;
                    chatMessages.insertAdjacentHTML('beforeend', botReplyHtml);
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }, 1500);

            }, 500);
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="~/js/login.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["LoginError"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                    const savedName = localStorage.getItem('savedGuestName');
                    const accountBtn = document.getElementById('headerAccountBtn'); // NHỚ ĐẶT ID NÀY CHO NÚT ACCOUNT
                if (savedName && accountBtn) {
                    // Nếu đã có Tên, đổi nút "Tra cứu" thành "Xin chào, Tên"
                    accountBtn.innerHTML = `<i class="fa-solid fa-user-check text-cyan-500"></i> Xin chào, <span class="font-bold text-slate-900">${savedName}</span>`;
                }
                // Gọi hàm mở Modal đăng nhập
                if (typeof openLoginModal === 'function') {
                    openLoginModal();
                }

                // Hiện thông báo lỗi
                Swal.fire({
                    icon: 'error',
                    title: 'Đăng nhập thất bại',
                    text: '@Html.Raw(TempData["LoginError"])',
                    confirmButtonColor: '#0f172a',
                    customClass: {
                        backdrop: 'swal-glass-backdrop' // Dùng luôn hiệu ứng kính mờ cho báo lỗi
                    }
                });
            });
        </script>
    }
</body>
</html>
