@using Microsoft.EntityFrameworkCore
@inject AISmartHome.Data.AISmartHomeDbContext _context
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // 1. Lấy Số điện thoại từ Session (đã lưu lúc khách đặt hàng hoặc tra cứu)
    string currentPhone = HttpContextAccessor.HttpContext?.Session.GetString("CustomerPhone") ?? HttpContextAccessor.HttpContext?.Session.GetString("VerifiedPhone");
    int cartCount = 0;
    int notifCount = 0;
    var recentOrders = new List<AISmartHome.Models.DonHang>();

    // ========================================================
    // PHẦN 1: LOGIC GIỎ HÀNG (Lấy ID linh hoạt từ Cookie)
    // ========================================================
    int maKhachHangHienTai = 0;

    if (Context.Request.Cookies.TryGetValue("GuestCustomerId", out string cookieId) && int.TryParse(cookieId, out int parsedId))
    {
        maKhachHangHienTai = parsedId;
    }

    // Truy vấn vào DB để đếm số lượng giỏ hàng của RIÊNG khách này
    if (maKhachHangHienTai > 0)
    {
        var currentCart = _context.GioHangs
            .Include(g => g.ChiTietGioHangs)
            .FirstOrDefault(g => g.MaKhachHang == maKhachHangHienTai);

        if (currentCart != null && currentCart.ChiTietGioHangs != null)
        {
            // SỬA DÒNG NÀY: Dùng .Count thay vì .Sum(...)
            cartCount = currentCart.ChiTietGioHangs.Count;
        }
    }

    // ========================================================
    // PHẦN 2: LOGIC THÔNG BÁO (Chỉ hiện đơn của SĐT đang dùng)
    // ========================================================
    if (!string.IsNullOrEmpty(currentPhone))
    {
        recentOrders = _context.DonHangs
            .Where(d => d.SoDienThoai == currentPhone || d.MaKhachHangNavigation.SoDienThoai == currentPhone)
            .OrderByDescending(d => d.NgayDatHang)
            .Take(5)
            .ToList();

        notifCount = recentOrders.Count(d => d.TrangThaiDonHang == "Chờ xử lý" || d.TrangThaiDonHang == "Đang giao");
    }
}
