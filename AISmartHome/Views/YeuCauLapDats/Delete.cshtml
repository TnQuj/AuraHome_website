@model AISmartHome.Models.YeuCauLapDat

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Bạn có thể đổi sang Layout của Admin nếu có
    ViewData["Title"] = "Xóa Yêu Cầu";
}

<main class="w-full min-h-[75vh] py-12 bg-slate-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="bg-white rounded-3xl shadow-lg border border-rose-100 overflow-hidden text-center relative">
            <div class="absolute top-0 w-full h-2 bg-rose-500"></div>

            <div class="p-8 pb-4">
                <div class="mx-auto w-20 h-20 bg-rose-100 text-rose-500 rounded-full flex items-center justify-center mb-6">
                    <i class="fa-solid fa-triangle-exclamation text-4xl"></i>
                </div>
                <h1 class="text-2xl font-black text-slate-800 mb-2">Bạn có chắc chắn muốn xóa?</h1>
                <p class="text-slate-500">Hành động này không thể hoàn tác. Toàn bộ dữ liệu của yêu cầu lắp đặt này sẽ bị xóa khỏi hệ thống.</p>
            </div>

            <div class="px-8 py-6 bg-slate-50/50 text-left mb-6 mx-8 rounded-2xl border border-slate-100">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4 border-b border-slate-200 pb-2">Thông tin yêu cầu</h3>
                <ul class="space-y-3">
                    <li class="flex justify-between">
                        <span class="text-slate-500">Mã YC:</span>
                        <span class="font-bold text-slate-800">#@Model.MaYeuCauLapDat</span>
                    </li>
                    <li class="flex justify-between">
                        <span class="text-slate-500">Đơn Hàng:</span>
                        <span class="font-bold text-slate-800">#@Model.MaDonHang</span>
                    </li>
                    <li class="flex justify-between">
                        <span class="text-slate-500">Ngày Lập:</span>
                        <span class="font-bold text-slate-800">@(Model.NgayLap?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                    </li>
                    <li class="flex flex-col mt-2">
                        <span class="text-slate-500 mb-1">Địa chỉ:</span>
                        <span class="font-medium text-slate-800 bg-white p-2 rounded border border-slate-200">@Model.DiaChiLapDat</span>
                    </li>
                </ul>
            </div>

            <div class="p-6 bg-slate-50 border-t border-slate-100 flex items-center justify-center gap-4">
                <a asp-action="Index" class="px-6 py-3 bg-white border border-slate-200 text-slate-600 font-bold rounded-xl hover:bg-slate-100 transition-colors">
                    Hủy bỏ
                </a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="MaYeuCauLapDat" />
                    <button type="submit" class="px-6 py-3 bg-rose-500 text-white font-bold rounded-xl hover:bg-rose-600 transition-colors shadow-lg shadow-rose-500/30 flex items-center gap-2">
                        <i class="fa-solid fa-trash-can"></i> Xác nhận Xóa
                    </button>
                </form>
            </div>
        </div>

    </div>
</main>