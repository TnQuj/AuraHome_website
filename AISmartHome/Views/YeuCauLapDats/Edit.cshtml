@model AISmartHome.Models.YeuCauLapDat

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Bạn có thể đổi sang Layout của Admin nếu có
        ViewData["Title"] = "Chỉnh sửa Yêu Cầu Lắp Đặt";
}

<main class="w-full min-h-[75vh] py-12 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-black text-brand-navy uppercase tracking-wide">Cập Nhật Yêu Cầu</h1>
                <p class="text-slate-500 text-sm mt-1">Mã YC: <strong class="text-brand-cyan">#@Model.MaYeuCauLapDat</strong></p>
            </div>
            <a asp-action="Index" class="text-slate-500 hover:text-brand-cyan transition-colors font-medium flex items-center gap-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100">
            <form asp-action="Edit" class="space-y-6">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-medium p-3 bg-rose-50 rounded-xl"></div>

                <input type="hidden" asp-for="MaYeuCauLapDat" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label asp-for="MaDonHang" class="block text-sm font-bold text-slate-700">Đơn Hàng (Khách Hàng)</label>

                        <select asp-for="MaDonHang" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-slate-50" asp-items="ViewBag.MaDonHang">
                            <option value="">-- Chọn đơn hàng --</option>
                        </select>
                        <span asp-validation-for="MaDonHang" class="text-rose-500 text-xs"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="MaNhanVien" class="block text-sm font-bold text-slate-700">Nhân Viên Phụ Trách</label>

                        <select asp-for="MaNhanVien" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-slate-50" asp-items="ViewBag.MaNhanVien">
                            <option value="">-- Chưa phân công --</option>
                        </select>
                        <span asp-validation-for="MaNhanVien" class="text-rose-500 text-xs"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="TrangThaiLapDat" class="block text-sm font-bold text-slate-700">Trạng Thái</label>
                        <select asp-for="TrangThaiLapDat" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-slate-50">
                            <option value="Chưa lắp đặt">Chưa lắp đặt</option>
                            <option value="Đang xử lý">Đang xử lý</option>
                            <option value="Đã hoàn thành">Đã hoàn thành</option>
                            <option value="Bị hủy">Bị hủy</option>
                        </select>
                        <span asp-validation-for="TrangThaiLapDat" class="text-rose-500 text-xs"></span>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="NgayLap" class="block text-sm font-bold text-slate-700">Ngày Lập</label>
                        <input asp-for="NgayLap" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-slate-50" />
                        <span asp-validation-for="NgayLap" class="text-rose-500 text-xs"></span>
                    </div>

                    <div class="space-y-4 md:col-span-2 p-6 bg-cyan-50/50 border border-cyan-100 rounded-2xl">
                        <h3 class="font-bold text-brand-navy border-b border-cyan-200 pb-2 mb-4 uppercase text-sm">
                            <i class="fa-solid fa-handshake text-brand-cyan mr-2"></i> Thông tin chốt với khách
                        </h3>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label asp-for="NgayLap" class="block text-sm font-bold text-slate-700">Ngày giờ hẹn lắp đặt</label>
                                <input asp-for="NgayLap" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-white" />                                <span asp-validation-for="NgayLap" class="text-rose-500 text-xs"></span>
                            </div>

                            <div class="space-y-2">
                                <label asp-for="PhiLapDat" class="block text-sm font-bold text-slate-700">Phí lắp đặt (VNĐ)</label>
                                <input asp-for="PhiLapDat" type="number" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-white" placeholder="VD: 500000" />
                                <span asp-validation-for="PhiLapDat" class="text-rose-500 text-xs"></span>
                            </div>

                            <div class="space-y-2 md:col-span-2">
                                <label asp-for="GhiChuBaoGia" class="block text-sm font-bold text-slate-700">Ghi chú thi công cho kỹ thuật viên</label>
                                <input asp-for="GhiChuBaoGia" type="text" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-white" placeholder="VD: Khoan tường 2 lỗ, đi 5m dây âm tường..." />
                                <span asp-validation-for="GhiChuBaoGia" class="text-rose-500 text-xs"></span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <label asp-for="DiaChiLapDat" class="block text-sm font-bold text-slate-700">Địa Chỉ Lắp Đặt</label>
                        <textarea asp-for="DiaChiLapDat" rows="3" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand-cyan/20 focus:border-brand-cyan transition-all text-slate-700 bg-slate-50"></textarea>
                        <span asp-validation-for="DiaChiLapDat" class="text-rose-500 text-xs"></span>
                    </div>
                </div>

                <div class="pt-6 border-t border-slate-100 flex justify-end">
                    <button type="submit" class="px-8 py-3.5 bg-brand-cyan text-white font-bold rounded-xl hover:bg-cyan-600 transition-colors shadow-lg shadow-brand-cyan/20 flex items-center gap-2">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}