@model IEnumerable<AISmartHome.Models.YeuCauLapDat>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Bạn có thể đổi sang Layout của Admin nếu có
    ViewData["Title"] = "Quản lý Yêu cầu lắp đặt";
}

<main class="w-full min-h-[75vh] py-12 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center">
                    <i class="fa-solid fa-screwdriver-wrench text-2xl"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-black text-brand-navy uppercase tracking-wide">Yêu cầu lắp đặt</h1>
                    <p class="text-slate-500 text-sm">Theo dõi và phân công công việc cho nhân viên</p>
                </div>
            </div>

            <a asp-action="Create" class="flex items-center gap-2 px-6 py-3 bg-brand-cyan text-white hover:bg-cyan-600 rounded-xl font-bold transition-all duration-300 shadow-lg shadow-brand-cyan/20 hover:-translate-y-0.5">
                <i class="fa-solid fa-plus"></i> Tạo yêu cầu mới
            </a>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="bg-slate-50 text-slate-500 font-bold uppercase text-[11px] tracking-wider">
                        <tr>
                            <th class="px-6 py-4">Mã YC</th>
                            <th class="px-6 py-4">Đơn hàng</th>
                            <th class="px-6 py-4">Nhân viên phụ trách</th>
                            <th class="px-6 py-4">Địa chỉ & Thời gian</th>
                            <th class="px-6 py-4">Trạng thái</th>
                            <th class="px-6 py-4 text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 font-black text-brand-navy">
                                        #@item.MaYeuCauLapDat
                                    </td>

                                    <td class="px-6 py-4">
                                        <div class="font-bold text-brand-navy text-[15px]">
                                            @(item.MaDonHangNavigation?.TenKhachHang ?? item.MaDonHangNavigation?.MaKhachHangNavigation?.TenKhachHang ?? "Khách hàng ẩn danh")
                                        </div>

                                        <div class="text-xs text-slate-500 font-semibold mt-1">
                                            <i class="fa-solid fa-receipt mr-1"></i> Đơn: #@item.MaDonHang
                                        </div>
                                    </td>


                                    <td class="px-6 py-4">
                                        @if (item.MaNhanVien != null)
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md bg-slate-100 border border-slate-200 text-slate-700 font-medium text-xs">
                                                <i class="fa-solid fa-user-tag text-brand-cyan"></i> NV-@item.MaNhanVienNavigation!.TenNhanVien
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 text-rose-500 text-xs font-bold">
                                                <i class="fa-solid fa-circle-exclamation"></i> Chưa phân công
                                            </span>
                                        }
                                    </td>

                                    <td class="px-6 py-4">
                                        <div class="text-slate-700 font-medium max-w-[200px] truncate" title="@item.DiaChiLapDat">
                                            @item.DiaChiLapDat
                                        </div>
                                        <div class="text-xs text-slate-400 mt-1 flex items-center gap-1">
                                            <i class="fa-regular fa-clock"></i>
                                            @(item.NgayLap?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
                                        </div>
                                    </td>

                                    <td class="px-6 py-4">
                                        @{
                                            var statusClass = item.TrangThaiLapDat switch
                                            {
                                                "Đã hoàn thành" => "bg-emerald-100 text-emerald-700 border-emerald-200",
                                                "Đang xử lý" => "bg-blue-100 text-blue-700 border-blue-200",
                                                "Chưa lắp đặt" => "bg-amber-100 text-amber-700 border-amber-200",
                                                "Bị hủy" => "bg-rose-100 text-rose-700 border-rose-200",
                                                _ => "bg-slate-100 text-slate-700 border-slate-200"
                                            };
                                        }
                                        <span class="px-3 py-1.5 @statusClass border text-xs font-bold rounded-full whitespace-nowrap">
                                            @item.TrangThaiLapDat
                                        </span>
                                    </td>

                                    <td class="px-6 py-4 text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.MaYeuCauLapDat"
                                               class="w-8 h-8 rounded-lg bg-slate-100 text-slate-600 hover:bg-brand-cyan hover:text-white flex items-center justify-center transition-colors" title="Chỉnh sửa">
                                                <i class="fa-solid fa-pen-to-square text-xs"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.MaYeuCauLapDat"
                                               class="w-8 h-8 rounded-lg bg-slate-100 text-slate-600 hover:bg-indigo-500 hover:text-white flex items-center justify-center transition-colors" title="Chi tiết">
                                                <i class="fa-solid fa-eye text-xs"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaYeuCauLapDat"
                                               class="w-8 h-8 rounded-lg bg-rose-50 text-rose-500 hover:bg-rose-600 hover:text-white flex items-center justify-center transition-colors" title="Xóa">
                                                <i class="fa-solid fa-trash-can text-xs"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-16 text-center text-slate-400">
                                    <i class="fa-solid fa-folder-open text-5xl mb-4 text-slate-200"></i>
                                    <p class="text-base font-medium">Chưa có yêu cầu lắp đặt nào.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>